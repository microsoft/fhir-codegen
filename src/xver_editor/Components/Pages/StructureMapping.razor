@page "/structuremapping/{FhirPackageKey:int}/{StructureKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;

@inject IDialogService DialogService
@inject IXverService Xver
@inject NavigationManager NavigationManager
@inject XverAppConfig ServerConfig

<PageTitle>@($"Mapping {PackageShortName}:{StructureName}")</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Structure mapping for @($"{PackageShortName}:{StructureName}")</FluentLabel>
    @* <FluentLabel Typo="Typography.Body">DB Key: @StructureKey</FluentLabel> *@

    @if ((Xver.IsOpen == false) || (Xver.DbConnection == null))
    {
        <FluentLabel Typo="Typography.Body">Database not open.</FluentLabel>
    }
    else if ((sdUiRec == null) || (sdGraphProjection == null))
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else if (sdUiRec.Projection.Count == 0)
    {
        <FluentLabel Typo="Typography.Body">No mappings found for this structure.</FluentLabel>
    }
    else
    {
        @* <FluentLabel Typo="Typography.Body">FHIR Specification: <FluentAnchor Appearance="Appearance.Hypertext" Href="@sdUiRec.GetFhirUrl()" Target="_blank">@StructureName</FluentAnchor></FluentLabel> *@
        @* <br/> *@

        <FluentLabel Typo="Typography.Header">Select a structure mapping group:</FluentLabel>
        <FluentDataGrid Items="@sdGraphProjection"
        ResizableColumns="false"
        GridTemplateColumns="@GetMappingTableColumns()"
        MultiLine="true"
        class="alternating-grid">
            <SelectColumn SelectMode="DataGridSelectMode.Single"
            TGridItem="DbGraphSd.DbSdRow"
            SelectFromEntireRow="true"
            Property="@(r => r.RowId == _selectedSdRowId)"
            OnSelect="@(e => StructureMappingRowSelected(e.Item, e.Selected))" />
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                <TemplateColumn Title="@_packages[packageIndex].ShortName" Tooltip="true" TooltipText="@(c => c.CellAt(packageIndex)?.Sd.UiDisplayLong)">
                    @{
                        DbGraphSd.DbSdCell? cell = context[packageIndex];
                    }
                    @if (cell != null)
                    {
                        <FluentStack Orientation="Orientation.Vertical">
                            <FluentLabel Typo="Typography.H6">@cell.Sd.Name</FluentLabel>
                            <FluentBadge Appearance="@(cell.Sd.Key == StructureKey ? Appearance.Accent : Appearance.Neutral)">
                                Elements: @cell.Elements.Count
                            </FluentBadge>
                        </FluentStack>
                    }
                </TemplateColumn>

                @if (i < _packages.Count - 1)
                {
                    <TemplateColumn Title="Comparison" TGridItem="DbGraphSd.DbSdRow">
                        @{
                            DbGraphSd.DbSdCell? cell = context[packageIndex];
                            // int cellIndex = packageIndex;
                            // DbStructureComparison? toRight = context[packageIndex]?.RightComparison;
                            // DbStructureComparison? fromRight = packageIndex < _packages.Count - 1 ? context[packageIndex + 1]?.LeftComparison : null;
                        }
                        @if ((cell == null) || (cell.RightCell == null))
                        {
                            @* <FluentButton>Add</FluentButton> *@
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical" Class="@(ClassForCell(cell.BidirectionalRight()))">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage())" />

                                    @if (cell.RightCell?.LeftComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightCell!.LeftComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightCell!.LeftComparison!.LastReviewedOn)}")"
                                        Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    @{
                                        string colKey = $"er-{context.RowId}-{packageIndex}";
                                        <div>
                                            <FluentButton Id="@($"{colKey}-btn")"
                                            Appearance="Appearance.Outline"
                                            OnClick="@(() => TogglePopover(colKey))">
                                                Edit
                                            </FluentButton>

                                            <FluentPopover AnchorId="@($"{colKey}-btn")"
                                            VerticalPosition="VerticalPosition.Top"
                                            FixedPlacement="true"
                                            Open="@IsPopoverOpen(colKey)"
                                            OpenChanged="@((value) => SetPopoverState(colKey, value))">
                                                <Header>
                                                    <FluentLabel Typo="Typography.Body">Select Bidirectional Relationship</FluentLabel>
                                                </Header>
                                                <Body>
                                                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                        <FluentCombobox Items="@_bidirectionalRelationships"
                                                        Name="@($"{colKey}-combo")"
                                                        Width="950px"
                                                        Height="700px"
                                                        Placeholder="Search for a relationship..."
                                                        OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                                        OptionText="@(i => i.Text)"
                                                        Multiple="false"
                                                        Autocomplete="ComboboxAutocomplete.Inline"
                                                        Autofocus="true"
                                                        Open="true"
                                                        SelectedOptionChanged="@(EventCallback.Factory.Create<Option<BidirectionalRelationshipCodes>>(this, (value) => UpdateSdRelationship(context.RowId, packageIndex, packageIndex + 1, value)))" />
                                                    </FluentStack>
                                                </Body>
                                            </FluentPopover>
                                        </div>
                                    }
                                    <FluentButton Appearance="Appearance.Outline" Title="Delete this Mapping" OnClick="@(() => DeleteSdMapping(context.RowId, packageIndex, packageIndex + 1))">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Delete())" Color="@Color.Error" />
                                    </FluentButton>

                                    @if (cell.RightComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightComparison!.LastReviewedOn)}")"
                                        Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage())" />
                                </FluentStack>
                            </FluentStack>
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

        <br />

        @if (_selectedSdRow != null)
        {
            <FluentDataGrid GenerateHeader="GenerateHeaderOption.None" TGridItem="string" DisplayMode="DataGridDisplayMode.Table" role="grid">
                <FluentDataGridRow RowType="DataGridRowType.Header">
                    <FluentDataGridCell GridColumn="1">
                        <FluentLabel Typo="Typography.Header">Add new mapping:</FluentLabel>
                    </FluentDataGridCell>
                </FluentDataGridRow>

                @foreach ((DbGraphSd.DbSdCell? cell, int cellIndex) in _selectedSdRow.Select((value, idx) => (value, idx)))
                {
                    if (cell == null)
                    {
                        continue;
                    }

                    <FluentDataGridRow>
                        <FluentDataGridCell GridColumn=1>@($"{_packages[cellIndex].ShortName}:{cell.Sd.Name}")</FluentDataGridCell>
                        <FluentDataGridCell GridColumn=2>
                            @if (cellIndex > 0)
                            {
                                int tpIndex = cellIndex - 1;
                                <div>
                                    <FluentButton Appearance="Appearance.Outline"
                                    Title="@($"Add new mapping from {_packages[cellIndex].ShortName}:{cell.Sd.Name} to {_packages[tpIndex].ShortName}")"
                                    OnClick="@(() => ShowStructureSelectionDialog(cellIndex, tpIndex))">
                                        <FluentLabel Typo="Typography.Body">@($"{_packages[cellIndex].ShortName}:{cell.Sd.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                    </FluentButton>
                                </div>
                            }
                        </FluentDataGridCell>
                        <FluentDataGridCell GridColumn=3>
                            @if (cellIndex < _lastPackageIndex)
                            {
                                int tpIndex = cellIndex + 1;
                                <div>
                                    <FluentButton Appearance="Appearance.Outline"
                                    Title="@($"Add new mapping from {_packages[cellIndex].ShortName}:{cell.Sd.Name} to {_packages[tpIndex].ShortName}")"
                                    OnClick="@(() => ShowStructureSelectionDialog(cellIndex, tpIndex))">
                                        <FluentLabel Typo="Typography.Body">@($"{_packages[cellIndex].ShortName}:{cell.Sd.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                    </FluentButton>
                                </div>
                            }
                        </FluentDataGridCell>
                    </FluentDataGridRow>
                }
            </FluentDataGrid> 
        }

        <hr />
        <FluentStack Orientation="Orientation.Horizontal">
            <FluentLabel Typo="Typography.Header">Review element mappings:</FluentLabel>
            <FluentButton IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" Appearance="Appearance.Outline" Title="Mark displayed mappings as reviewed" OnClick="@(() => MarkReviewed())">
                Mark Reviewed
            </FluentButton>
        </FluentStack>

        <FluentDataGrid Items="@elementGraphProjection"
        ResizableColumns="true"
        GridTemplateColumns="@GetMappingTableColumns()"
        MultiLine="true"
        ShowHover="true"
        class="alternating-grid">
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;

                <TemplateColumn Sortable="true"
                SortBy="@_elementSorters[packageIndex]"
                Title="@(_selectedSdRow?.CellAt(packageIndex)?.Sd.Name)"
                HeaderTooltip="@(_selectedSdRow?.CellAt(packageIndex)?.Sd.UiDisplayLong)"
                TooltipText="@(c => c[packageIndex]?.Element.UiDisplayLong ?? $"Add mapping to {_packages[packageIndex].ShortName}:{_selectedSdRow?.CellAt(packageIndex)?.Sd.Name}")"
                Tooltip="true">
                    @{
                        if (context[packageIndex] == null)
                        {
                            (bool neighborDown, bool neighborUp) = context.HasNeigbors(packageIndex);
                            if (neighborDown)
                            {
                                <FluentButton OnClick="@(() => ShowElementMappingDialog(context.RowId, packageIndex - 1, packageIndex))">Add mapping to @_packages[packageIndex].ShortName</FluentButton>
                            }

                            if (neighborDown && neighborUp)
                            {
                                <br/>
                            }

                            if (neighborUp)
                            {
                                <FluentButton OnClick="@(() => ShowElementMappingDialog(context.RowId, packageIndex + 1, packageIndex))">Add mapping to @_packages[packageIndex].ShortName</FluentButton>
                            }
                        }
                        else
                        {
                            string[] components = context[packageIndex]!.Element.Id.Split('.') ?? [];
                            int lastComponentIndex = components.Length - 1;
                            foreach ((string component, int componentIndex) in components.Select((value, idx) => (value, idx)))
                            {
                                Appearance ba = componentIndex == lastComponentIndex ? Appearance.Accent : Appearance.Neutral;
                                if (componentIndex == 0)
                                {
                                    if (lastComponentIndex == 0)
                                    {
                                        <FluentBadge Appearance="@ba">@component</FluentBadge>
                                    }
                                }
                                else
                                {
                                    <br />
                                    <FluentBadge Appearance="Appearance.Lightweight">.</FluentBadge>
                                    <FluentBadge Appearance="@ba">@component</FluentBadge>
                                }
                            }
                        }
                    }
                </TemplateColumn>

                @if (packageIndex < _lastPackageIndex)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" HeaderTooltip="@(GetComparisonColName(packageIndex))" TGridItem="DbGraphSd.DbElementRow">
                        @{
                            DbGraphSd.DbElementCell? cell = context[packageIndex];
                            // int cellIndex = packageIndex;
                            // DbElementComparison? toRight = context[packageIndex]?.RightComparison;
                            // DbElementComparison? fromRight = packageIndex < _packages.Count - 1 ? context[packageIndex + 1]?.LeftComparison : null;
                        }
                        @if ((cell == null) || (cell.RightCell == null))
                        {
                            @* <FluentBadge Fill="highlight" BackgroundColor="red" Color="white">ELSE</FluentBadge> *@
                            @* <FluentButton>Add</FluentButton> *@
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical" Class="@(ClassForCell(cell.BidirectionalRight()))">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>MISMATCHED</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage())" />

                                    @if (cell.RightCell?.LeftComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightCell!.LeftComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightCell!.LeftComparison!.LastReviewedOn)}")"
                                        Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    <FluentButton OnClick="@(() => ShowElementMappingDialog(context.RowId, packageIndex, packageIndex + 1))">Edit</FluentButton>

                                    @if (cell.RightComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightComparison!.LastReviewedOn)}")"
                                        Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage())" />
                                </FluentStack>

                                @if ((cell.RightCell?.LeftVsComparison != null) || (cell.RightVsComparison != null))
                                {
                                    <FluentStack Orientation="Orientation.Horizontal">
                                        @if ((cell.RightCell?.BoundValueSet != null) && (cell.RightCell?.LeftVsComparison != null))
                                        {
                                            <FluentAnchor Appearance="Appearance.Hypertext" Href="@($"valuesetmapping/{cell.RightCell.BoundValueSet.FhirPackageKey}/{cell.RightCell.BoundValueSet.Key}/?packageShort={_packages[packageIndex+1].ShortName}&vsName={cell.RightCell.BoundValueSet.Name}")">
                                                <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowCircleLeft())" />
                                            </FluentAnchor>

                                            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Info())" Title="@cell.RightCell.LeftVsComparison.TechnicalMessage" />
                                        }

                                        <FluentLabel Typo="Typography.Body">|</FluentLabel>

                                        @if ((cell.BoundValueSet != null) && (cell.RightVsComparison != null))
                                        {
                                            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Info())" Title="@cell.RightVsComparison.TechnicalMessage" />

                                            <FluentAnchor Appearance="Appearance.Hypertext" Href="@($"valuesetmapping/{cell.BoundValueSet.FhirPackageKey}/{cell.BoundValueSet.Key}/?packageShort={_packages[packageIndex].ShortName}&vsName={cell.BoundValueSet.Name}")">
                                                <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowCircleRight())" />
                                            </FluentAnchor>
                                        }

                                    </FluentStack>
                                }

                            </FluentStack>

                            @*                             <FluentCombobox Items="@_bidirectionalRelationships"
                                Name="@($"{context.RowNumber}-{packageIndex}-r-combo")"
                                Width="200px"
                                Height="700px"
                                Placeholder="Search for a relationship..."
                                OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                OptionText="@(i => i.Text)"
                                Value="@(cell.BidirectionalRight?.ToString() ?? string.Empty)"
                                Multiple="false"
                                Autocomplete="ComboboxAutocomplete.Inline"
                                Autofocus="true"
                                Open="true"
                                SelectedOptionChanged="@(EventCallback.Factory.Create<Option<BidirectionalRelationshipCodes>>(this, (value) => ElementRelationshipChanged(context, cell, value)))" />
                            <br/>
 *@
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

    }
</FluentStack>


<FluentDialog @ref="structureSelectionDialog"
Modal="true"
Hidden="@(visibleDialog != VisibleDialogCodes.StructureSelection)"
Class="sd-dialog-container">
    <FluentDialogHeader Visible="true">@structureDialogTitle</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Width="100%">
            <FluentTextField @bind-Value="structureSearchText" Placeholder="Type to filter structures..." @oninput="FilterStructures" />
            <div style="height: 400px; overflow-y: auto; margin-bottom: 16px;">
                <FluentDataGrid Items="@filteredStructures"
                ResizableColumns="true"
                GridTemplateColumns="80px 1fr 2fr"
                TGridItem="DbStructureDefinition">
                    <SelectColumn TGridItem="DbStructureDefinition"
                    SelectMode="DataGridSelectMode.Single"
                    SelectFromEntireRow="true"
                    @bind-SelectedItems="@selectedStructures" />
                    <PropertyColumn Title="Name" Property="@(sd => sd.Name)" Sortable="true" Tooltip="true" IsDefaultSortColumn="true" TooltipText="@(sd => sd.UiDisplayLong)" />
                    <PropertyColumn Title="Title" Property="@(sd => sd.Title)" Sortable="true" Tooltip="true" TooltipText="@(sd => sd.Title)"/>
                </FluentDataGrid>
            </div>

            @if (selectedStructure != null)
            {
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                        <FluentLabel Typo="Typography.H6">Selected Structure</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Name: @selectedStructure.Name</FluentLabel>
                        <FluentLabel Typo="Typography.Body">URL: @selectedStructure.UnversionedUrl</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Snapshot: @selectedStructure.SnapshotCount</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Title: @selectedStructure.Title</FluentLabel>
                    </FluentStack>
                </FluentCard>
            }

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.End">
                <FluentButton Appearance="Appearance.Outline" OnClick="CancelStructureSelection">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="SelectStructure" Disabled="@(selectedStructure == null)">Select</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentDialogBody>
</FluentDialog>



<FluentDialog @ref="elementMappingDialog"
Modal="true"
Hidden="@(visibleDialog != VisibleDialogCodes.ElementMapping)"
Class="ed-dialog-container">
    <FluentDialogHeader Visible="true">Edit Element Mapping</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentStack Orientation="Orientation.Horizontal" Width="100%">
                <div class="ed-tree-view-container">
                    <FluentTreeView @ref="elementMappingTreeLeft" Items="@mappingLeftItems" SelectedItem="@mappingLeftSelected" OnSelectedChange="HandleLeftMappingSelectionChanged">
                        <ItemTemplate>
                            <code>@context.Text</code>
                        </ItemTemplate>
                    </FluentTreeView>
                </div>
                @* <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowBidirectionalLeftRight())" /> *@
                <div class="ed-tree-view-container">
                    <FluentTreeView @ref="elementMappingTreeRight" Items="@mappingRightItems" SelectedItem="@mappingRightSelected" OnSelectedChange="HandleRightMappingSelectionChanged">
                        <ItemTemplate>
                            <code>@context.Text</code>
                        </ItemTemplate>
                    </FluentTreeView>
                </div>
            </FluentStack>
            <hr/>

            <FluentLabel Typo="Typography.Body"><b>Left:</b> @_packages[mappingLeftColId].ShortName @mappingLeftSd?.Sd.Name: <code>@mappingLeftSelected?.Text</code></FluentLabel>
            @* <FluentLabel Typo="Typography.Body">Maps as <code>@mapLRRelationship?.Text</code></FluentLabel> *@
            <FluentLabel Typo="Typography.Body"><b><code>Left to Right:</code></b></FluentLabel>
            <FluentLabel Typo="Typography.Body">Overall Relationship:</FluentLabel>
            <FluentCombobox Items="@_relationships"
                TOption="Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>"
                Class="full-width"
                Placeholder="Search for a relationship..."
                OptionValue="@(i => i?.Value.ToString() ?? string.Empty)"
                OptionText="@(i => i?.Text)"
                @bind-SelectedOption="@mapLRRelationship"
                Multiple="false"
                Autocomplete="ComboboxAutocomplete.Inline"/>
            @* <FluentLabel Typo="Typography.Body">Conceptually: <code>@mapLRConceptRelationship</code></FluentLabel> *@
            <FluentLabel Typo="Typography.Body">Concept Domain Relationship:</FluentLabel>
            <FluentCombobox Items="@_relationships"
                TOption="Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>"
                Class="full-width"
                Placeholder="Search for a relationship..."
                OptionValue="@(i => i?.Value.ToString() ?? string.Empty)"
                OptionText="@(i => i?.Text)"
                @bind-SelectedOption="@mapLRConceptRelationship"
                Multiple="false"
                Autocomplete="ComboboxAutocomplete.Inline" />
            <FluentLabel Typo="Typography.Body">Mapping Message:</FluentLabel>
            <FluentTextField @bind-Value="@mapLRMessage" Class="full-width" />
            <FluentTextArea @bind-Value="@mapLRUserMessage" Class="full-width" Rows="5" />

            <FluentLabel Typo="Typography.Body"><b>Right:</b> @_packages[mappingRightColId].ShortName @mappingRightSd?.Sd.Name: <code>@mappingRightSelected?.Text</code></FluentLabel>
            @* <FluentLabel Typo="Typography.Body">Maps as <code>@mapRLRelationship</code></FluentLabel> *@
            <FluentLabel Typo="Typography.Body"><b><code>Right to Left:</code></b></FluentLabel>
            <FluentLabel Typo="Typography.Body">Overall Relationship:</FluentLabel>
            <FluentCombobox Items="@_relationships"
                TOption="Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>"
                Class="full-width"
                Placeholder="Search for a relationship..."
                OptionValue="@(i => i?.Value.ToString() ?? string.Empty)"
                OptionText="@(i => i?.Text)"
                @bind-SelectedOption="@mapRLRelationship"
                Multiple="false"
                Autocomplete="ComboboxAutocomplete.Inline" />
            @* <FluentLabel Typo="Typography.Body">Conceptually: <code>@mapRLConceptRelationship</code></FluentLabel> *@
            <FluentLabel Typo="Typography.Body">Concept Domain Relationship:</FluentLabel>
            <FluentCombobox Items="@_relationships"
                TOption="Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>"
                Class="full-width"
                Placeholder="Search for a relationship..."
                OptionValue="@(i => i?.Value.ToString() ?? string.Empty)"
                OptionText="@(i => i?.Text)"
                @bind-SelectedOption="@mapRLConceptRelationship"
                Multiple="false"
                Autocomplete="ComboboxAutocomplete.Inline" />
            <FluentLabel Typo="Typography.Body">Mapping Message:</FluentLabel>
            <FluentTextField @bind-Value="@mapRLMessage" Class="full-width" />
            <FluentTextArea @bind-Value="@mapRLUserMessage" Class="full-width" Rows="5" />

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.Stretch">
                <FluentButton BackgroundColor="var(--error)" Color="#ffffff" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="DeleteElementMapping">Delete</FluentButton>
                <FluentSpacer />
