    private void UpdateConceptMapping()
    {
        if ((_focusConceptRow == null) ||
            (_selectedVsRow == null) ||
            (_selectedVsRow[mappingLeftColId] == null) ||
            (_selectedVsRow[mappingRightColId] == null))
        {
            ClearConceptSelection();
            return;
        }

        // resolve the selected tree items
        DbValueSetConcept? leftTreeConcept = (mappingLeftSelected == null) || string.IsNullOrEmpty(mappingLeftSelected.Id)
            ? null
            : _selectedVsRow[mappingLeftColId]!.Concepts.FirstOrDefault(e => e.FhirKey == mappingLeftSelected.Id);

        DbValueSetConcept? rightTreeConcept = (mappingRightSelected == null) || string.IsNullOrEmpty(mappingRightSelected.Id)
            ? null
            : _selectedVsRow[mappingRightColId]!.Concepts.FirstOrDefault(e => e.FhirKey == mappingRightSelected.Id);

        bool isLeftToRight = mappingLeftColId < mappingRightColId;

        bool addingLR = false;
        bool deletingLR = false;
        bool addingRL = false;
        bool deletingRL = false;

        // check if there is no left concept selected
        if (leftTreeConcept == null)
        {
            // check if we need to delete the Left to Right comparison record
            deletingLR = mapLRComparison != null;
        }
        else
        {
            // check if we need to create the Left to Right comparison record
            if (mapLRComparison == null)
            {
                mapLRComparison = DbValueSetConceptComparison.EmptyCopy;
                mapLRComparison.Key = Xver.ComparisonDb.GetConceptComparisonKey();
                addingLR = true;
            }

            mapLRComparison.PackageComparisonKey = _selectedVsRow[mappingLeftColId]!.RightComparison!.PackageComparisonKey;
            mapLRComparison.ValueSetComparisonKey = _selectedVsRow[mappingLeftColId]!.RightComparison!.Key;
            mapLRComparison.SourceFhirPackageKey = _selectedVsRow[mappingLeftColId]!.Vs.FhirPackageKey;
            mapLRComparison.SourceValueSetKey = _selectedVsRow[mappingLeftColId]!.Vs.Key;
            mapLRComparison.TargetFhirPackageKey = _selectedVsRow[mappingRightColId]!.Vs.FhirPackageKey;
            mapLRComparison.TargetValueSetKey = _selectedVsRow[mappingRightColId]!.Vs.Key;
            mapLRComparison.SourceConceptKey = leftTreeConcept.Key;
            mapLRComparison.TargetConceptKey = rightTreeConcept?.Key;
            mapLRComparison.Relationship = deletingRL ? null : mapLRRelationship?.Value;
            mapLRComparison.Message = mapLRMessage;
            mapLRComparison.NoMap = deletingRL ? true : null;
            mapLRComparison.IsGenerated = false;

            // if the comparison has changed, we cannot rely on the existing comparison information
            if (mapLRComparison.Key != _focusConceptRow[mappingLeftColId]?.RightComparison?.Key)
            {
                mapLRComparison.IsIdentical = null;
                mapLRComparison.CodesAreIdentical = null;
            }
        }

        // check if there is no right concept selected
        if (rightTreeConcept == null)
        {
            // check if we need to delete the Right to Left comparison record
            deletingRL = mapRLComparison != null;
        }
        else
        {
            if (mapRLComparison == null)
            {
                mapRLComparison = DbValueSetConceptComparison.EmptyCopy;
                mapRLComparison.Key = Xver.ComparisonDb.GetConceptComparisonKey();
                addingRL = true;
            }

            mapRLComparison.PackageComparisonKey = _selectedVsRow[mappingRightColId]!.LeftComparison!.PackageComparisonKey;
            mapRLComparison.ValueSetComparisonKey = _selectedVsRow[mappingRightColId]!.LeftComparison!.Key;
            mapRLComparison.SourceFhirPackageKey = _selectedVsRow[mappingRightColId]!.Vs.FhirPackageKey;
            mapRLComparison.SourceValueSetKey = _selectedVsRow[mappingRightColId]!.Vs.Key;
            mapRLComparison.TargetFhirPackageKey = _selectedVsRow[mappingLeftColId]!.Vs.FhirPackageKey;
            mapRLComparison.TargetValueSetKey = _selectedVsRow[mappingLeftColId]!.Vs.Key;
            mapRLComparison.SourceConceptKey = rightTreeConcept.Key;
            mapRLComparison.TargetConceptKey = leftTreeConcept?.Key;
            mapRLComparison.Relationship = deletingLR ? null : mapRLRelationship?.Value;
            mapRLComparison.Message = mapRLMessage;
            mapRLComparison.NoMap = deletingLR ? true : null;
            mapRLComparison.IsGenerated = false;

            // if the comparison has changed, we cannot rely on the existing comparison information
            if (mapRLComparison.Key != _focusConceptRow[mappingRightColId]?.LeftComparison?.Key)
            {
                mapRLComparison.IsIdentical = null;
                mapRLComparison.CodesAreIdentical = null;
            }
        }

        // fix inverse keys
        if (mapLRComparison != null)
        {
            mapLRComparison.InverseComparisonKey = mapRLComparison?.Key;
        }

        if (mapRLComparison != null)
        {
            mapRLComparison.InverseComparisonKey = mapLRComparison?.Key;
        }

        // update the database
        if (deletingLR)
        {
            mapLRComparison?.Delete(Xver.ComparisonDb.DbConnection);
        }
        else if (addingLR)
        {
            mapLRComparison!.Insert(Xver.ComparisonDb.DbConnection);
        }
        else
        {
            mapLRComparison!.Update(Xver.ComparisonDb.DbConnection);
        }

        if (deletingRL)
        {
            mapRLComparison?.Delete(Xver.ComparisonDb.DbConnection);
        }
        else if (addingRL)
        {
            mapRLComparison!.Insert(Xver.ComparisonDb.DbConnection);
        }
        else
        {
            mapRLComparison!.Update(Xver.ComparisonDb.DbConnection);
        }

        // force a reload of the content to get updating mappings
        LoadMappingRow(_selectedVsRow);

        // check bidirectional right for testing
        // if (conceptGraphProjection?.FirstOrDefault(cr => cr.RowId == _focusConceptRow.RowId) != null)
        // {
        //     Console.WriteLine(conceptGraphProjection!.FirstOrDefault(cr => cr.RowId == _focusConceptRow.RowId)![mappingLeftColId]?.VsCell);
        // }

        // go back to the main UI
        ClearConceptSelection();
    }

