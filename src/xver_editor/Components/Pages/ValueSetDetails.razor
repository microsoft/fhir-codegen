@page "/valuesets/{FhirPackageKey:int}/{ValueSetKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;
@using static Microsoft.Health.Fhir.Comparison.Models.DbGraphVs;

@inject IDialogService DialogService
@inject IXverService Xver
@inject NavigationManager NavigationManager
@inject XverAppConfig ServerConfig

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Value Set details for @ValueSetName (DB Key: @ValueSetKey)</FluentLabel>

    @if ((Xver.IsOpen == false) || (Xver.DbConnection == null))
    {
        <FluentLabel Typo="Typography.Body">Database not open.</FluentLabel>
    }
    else if (vsUiRec == null)
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else
    {
        <FluentTabs Width="100%" @ref="tabsComponent" ActiveTabId="@activeTabId">
            <FluentTab Id="overview" Label="Overview">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">Value Set Info</FluentLabel>
                    <FluentCard Width="100%">
                        <div style="padding: 16px;">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                                <FluentGrid Columns="2" ColumnSpan="2">
                                    <FluentGridItem>
                                        <FluentTextField Label="Name" Value="@vsUiRec.Vs.Name" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="ID" Value="@vsUiRec.Vs.Id" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="URL" Value="@vsUiRec.Vs.UnversionedUrl" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Version" Value="@vsUiRec.Vs.Version" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Description" Value="@vsUiRec.Vs.Description" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Publication Status" Value="@vsUiRec.Vs.Status.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Total Concepts" Value="@vsUiRec.Vs.ConceptCount.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Active Concrete Concepts" Value="@vsUiRec.Vs.ActiveConcreteConceptCount.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Can Expand" Value="@vsUiRec.Vs.CanExpand.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Has Escape-Value Code" Value="@vsUiRec.Vs.HasEscapeValveCode.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Strongest Binding Core" Value="@(vsUiRec.Vs.StrongestBindingCore?.ToString() ?? "None")" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Message" Value="@(vsUiRec.Vs.Message ?? "None")" ReadOnly="true" />
                                    </FluentGridItem>
                                </FluentGrid>
                            </FluentStack>
                        </div>
                    </FluentCard>

                    <FluentLabel Typo="Typography.H5">Referenced Systems</FluentLabel>
                    <FluentCard Width="100%">
                        <ul>
                            @foreach (string referencedSystem in (vsUiRec.Vs.ReferencedSystems ?? string.Empty).Split(", "))
                            {
                                <li><FluentTextField Value="@referencedSystem" ReadOnly="true" /></li>
                            }
                        </ul>
                    </FluentCard>

                    <FluentLabel Typo="Typography.H5">Bindings</FluentLabel>
                    <FluentCard Width="100%">
                        <div style="padding: 16px;">
                            <FluentDataGrid Items="@_boundElements" GridTemplateColumns="1fr 1.5fr 1fr 0.8fr 2fr" class="alternating-grid">
                                <PropertyColumn Title="Element" Property="@(e => e.Path)" Sortable="true" />
                                <PropertyColumn Title="Structure URL" Property="@(e => GetElementStructureUrl(e))" Sortable="true" />
                                <PropertyColumn Title="Binding" Property="@(e => e.BindingValueSet ?? string.Empty)" Sortable="true" />
                                <PropertyColumn Title="Strength" Property="@(e => e.ValueSetBindingStrength == null ? string.Empty : e.ValueSetBindingStrength.ToString())" Sortable="true" />
                                <PropertyColumn Title="Short Description" Property="@(e => e.Short ?? string.Empty)" Sortable="true" />
                            </FluentDataGrid>
                        </div>
                    </FluentCard>

                </FluentStack>
            </FluentTab>
            <FluentTab Id="mappingTable" Label="All-Version Mapping Table">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">All-Version Mapping Table</FluentLabel>
                    <FluentCard Width="100%">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                            <FluentLabel Typo="Typography.Body">Add mapping for @ValueSetName</FluentLabel>
                            @for (int i = 0; i < _packages.Count; i++)
                            {
                                int packageIndex = i;
                                if (_packages[packageIndex].Key != FhirPackageKey)
                                {
                                    continue;
                                }

                                if (packageIndex > 0)
                                {
                                    int tpIndex = packageIndex - 1;
                                    string dialogKey = $"add-vs-map-left";
                                    <div>
                                        <FluentButton Appearance="Appearance.Outline"
                                        Title="@($"Add new mapping to {_packages[tpIndex].ShortName}")"
                                        OnClick="@(() => ShowValueSetSelectionDialog(dialogKey, ValueSetKey, packageIndex, tpIndex))">
                                            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" />
                                            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowLeft())" />
                                        </FluentButton>
                                    </div>
                                }

                                if (packageIndex < (_packages.Count - 1))
                                {
                                    int tpIndex = packageIndex + 1;
                                    string dialogKey = $"add-vs-map-right";
                                    <div>
                                        <FluentButton Appearance="Appearance.Outline"
                                        Title="@($"Add new mapping to {_packages[packageIndex+1].ShortName}")"
                                        OnClick="@(() => ShowValueSetSelectionDialog(dialogKey, ValueSetKey, packageIndex, tpIndex))">
                                            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" />
                                            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowRight())" />
                                        </FluentButton>
                                    </div>
                                }
                            }
                        </FluentStack>
                        <div class="grid-container" style="padding: 16px;">
                            @if (vsUiRec.Projection.Count == 0)
                            {
                                <p>No mapping data available for this ValueSet.</p>
                            }
                            else
                            {
                                <FluentDataGrid Items="@graphProjection" ResizableColumns="true" GridTemplateColumns="@GetMappingTableColumns()" MultiLine="true" class="alternating-grid">
                                    @for (int i = 0; i < _packages.Count; i++)
                                    {
                                        int packageIndex = i;
                                        <TemplateColumn Title="@_packages[packageIndex].ShortName">
                                            @{
                                                DbVsCell? cell = context[packageIndex];
                                            }
                                            @if (cell != null)
                                            {
                                                <FluentStack Orientation="Orientation.Vertical">
                                                    <FluentLabel Typo="Typography.Header">@cell.Vs.Name</FluentLabel>
                                                    <FluentLabel Typo="Typography.Body">@cell.Vs.Id</FluentLabel>
                                                    <FluentBadge Appearance="@(cell.Vs.Key == ValueSetKey ? Appearance.Accent : Appearance.Neutral)">
                                                        Concepts: @cell.Concepts.Count
                                                    </FluentBadge>
                                                </FluentStack>
                                            }
                                        </TemplateColumn>

                                        @if (i < _packages.Count - 1)
                                        {
                                            <TemplateColumn Title="Comparison" TGridItem="DbVsRow">
                                                @{
                                                    DbVsCell? cell = context[packageIndex];
                                                    int cellIndex = packageIndex;
                                                    DbValueSetComparison? toRight = context[packageIndex]?.RightComparison;
                                                    DbValueSetComparison? fromRight = packageIndex < _packages.Count - 1 ? context[packageIndex + 1]?.LeftComparison : null;
                                                }
                                                @if (cell != null)
                                                {
                                                    @if (toRight != null)
                                                    {
                                                        <FluentStack Orientation="Orientation.Vertical">
                                                            <FluentIcon Value="@(new Icons.Regular.Size24.ArrowRight())" />
                                                            <FluentBadge Appearance="@(toRight.LastReviewedOn == null ? Appearance.Accent : Appearance.Neutral)">
                                                                @(toRight.LastReviewedOn == null ? "Unreviewed" : "Reviewed")
                                                            </FluentBadge>
                                                            <FluentButton OnClick="@(() => SelectComparison(context, toRight, cellIndex, cellIndex + 1))"
                                                            Appearance="Appearance.Outline" IconEnd="@(new Icons.Regular.Size16.WindowDevEdit())">
                                                                Details
                                                            </FluentButton>
                                                            <FluentLabel Typo="Typography.Body">DB Key: @toRight.Key</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@toRight.Relationship</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(GetDateDisplay(toRight.LastReviewedOn))</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(toRight.LastReviewedBy ?? string.Empty)</FluentLabel>
                                                        </FluentStack>
                                                    }

                                                    @if (fromRight != null)
                                                    {
                                                        <FluentStack Orientation="Orientation.Vertical">
                                                            <FluentIcon Value="@(new Icons.Regular.Size24.ArrowLeft())" />
                                                            <FluentBadge Appearance="@(fromRight.LastReviewedOn == null ? Appearance.Accent : Appearance.Neutral)">
                                                                @(fromRight.LastReviewedOn == null ? "Unreviewed" : "Reviewed")
                                                            </FluentBadge>
                                                            <FluentButton OnClick="@(() => SelectComparison(context, fromRight, cellIndex + 1, cellIndex))"
                                                            Appearance="Appearance.Outline"
                                                            IconEnd="@(new Icons.Regular.Size16.WindowDevEdit())">
                                                                Details
                                                            </FluentButton>
                                                            <FluentLabel Typo="Typography.Body">DB Key: @fromRight.Key</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@fromRight.Relationship</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(GetDateDisplay(fromRight.LastReviewedOn))</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(fromRight.LastReviewedBy ?? string.Empty)</FluentLabel>
                                                        </FluentStack>
                                                    }
                                                }
                                            </TemplateColumn>
                                        }
                                    }
                                </FluentDataGrid>
                            }
                        </div>
                    </FluentCard>
                </FluentStack>
            </FluentTab>
            <FluentTab Id="comparisonDetails" Label="Comparison Details">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">Comparison Details</FluentLabel>
                    @if ((selectedComparison == null) || (csCell == null) || (ctCell == null))
                    {
                        <FluentCard>
                            <FluentLabel Typo="Typography.Body">Please select a comparison to review.</FluentLabel>
                        </FluentCard>
                    }
                    else
                    {
                        <FluentCard Width="100%">
                            <FluentStack Orientation="Orientation.Vertical">
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentLabel Typo="Typography.H5">@selectedComparison.CompositeName</FluentLabel>
                                    <FluentButton Id="@($"del-vsc-btn")" Appearance="Appearance.Outline" Title="Delete this Mapping" OnClick="@(() => DeleteCurrentMapping())">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Delete())" Color="@Color.Error" />
                                    </FluentButton>

                                </FluentStack>

                                <FluentTextField Label="Comparison DB Key" Value="@selectedComparison.Key.ToString()" ReadOnly="true" />

                                <FluentDataGrid GenerateHeader="GenerateHeaderOption.None" TGridItem="string" DisplayMode="DataGridDisplayMode.Table" role="grid" class="full-width">
                                    <FluentDataGridRow RowType="DataGridRowType.Header">
                                        <FluentDataGridCell GridColumn=1 CellType="DataGridCellType.ColumnHeader" Style="width: 20%;"></FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2 CellType="DataGridCellType.ColumnHeader" Style="width: 40%;">Source</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3 CellType="DataGridCellType.ColumnHeader" Style="width: 40%;">Target</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Package</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@(csPackage?.NpmId ?? string.Empty)</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@(ctPackage?.NpmId ?? string.Empty)</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Id</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Vs.Id</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Vs.Id</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Name</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Vs.Name</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Vs.Name</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>URL</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Vs.UnversionedUrl</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Vs.UnversionedUrl</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Version</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Vs.Version</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Vs.Version</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Concept Count</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Vs.ConceptCount</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Vs.ConceptCount</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Active and Concrete</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Vs.ActiveConcreteConceptCount</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Vs.ActiveConcreteConceptCount</FluentDataGridCell>
                                    </FluentDataGridRow>
                                </FluentDataGrid>
                                <FluentLabel Typo="Typography.Body">ValueSet Relationship:</FluentLabel>
                                @{
                                    var rowKey = $"rel-vs";
                                    var relationship = selectedComparison.Relationship;
                                    <div>
                                        <FluentButton Id="@($"{rowKey}-btn")"
                                        Appearance="Appearance.Outline"
                                        OnClick="@(() => TogglePopover(rowKey))">
                                            @(relationship?.ToString() ?? "-")
                                        </FluentButton>

                                        <FluentPopover AnchorId="@($"{rowKey}-btn")"
                                        VerticalPosition="VerticalPosition.Top"
                                        FixedPlacement="true"
                                        Open="@IsPopoverOpen(rowKey)"
                                        OpenChanged="@((value) => SetPopoverState(rowKey, value))">
                                            <Header>
                                                <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                            </Header>
                                            <Body>
                                                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                    <FluentCombobox Items="@_relationships"
                                                    Name="@($"{rowKey}-combo")"
                                                    Width="950px"
                                                                    Height="700px"
                                                                    Placeholder="Search for a relationship..."
                                                    OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                                    OptionText="@(i => i.Text)"
                                                    Multiple="false"
                                                    Autocomplete="ComboboxAutocomplete.Inline"
                                                    Autofocus="true"
                                                    Open="true"
                                                    SelectedOptionChanged="@(EventCallback.Factory.Create<Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>>(this, (value) => UpdateVsRelationship(value)))" />
                                                </FluentStack>
                                            </Body>
                                        </FluentPopover>
                                    </div>
                                }
                                <FluentTextField Label="Message" @bind-Value="@selectedComparison.Message" Class="full-width" />
                                @* // add a div so that the combo box will display - otherwise it is truncated *@
                                <div class="fluent-pop-container-spacer-short"></div>
                            </FluentStack>

                        </FluentCard>

                        <FluentCard Width="100%">
                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                <FluentLabel Typo="Typography.H5">Concept Mapping</FluentLabel>
                                @{
                                    var popKey = "add-concept-row";
                                    <div>
                                        <FluentButton Id="@($"{popKey}-btn")" Appearance="Appearance.Outline" Title="Add new mapping row" OnClick="@(() => TogglePopover(popKey))">
                                            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.AddSquare())" Color="@Color.Success" />
                                        </FluentButton>

                                        <FluentPopover AnchorId="@($"{popKey}-btn")"
                                        VerticalPosition="VerticalPosition.Bottom"
                                        FixedPlacement="true"
                                        Open="@IsPopoverOpen(popKey)"
                                        OpenChanged="@((value) => SetPopoverState(popKey, value))">
                                            <Header>
                                                Select source concept...
                                            </Header>
                                            <Body>
                                                <FluentCombobox Items="@_sourceConcepts"
                                                Width="950px"
                                                                Height="700px"
                                                                Placeholder="Search for a concept..."
                                                OptionValue="@(i => i.Value?.Key.ToString() ?? string.Empty)"
                                                OptionText="@(i => i.Text)"
                                                Multiple="false"
                                                Autocomplete="ComboboxAutocomplete.Inline"
                                                Autofocus="true"
                                                Open="true"
                                                SelectedOptionChanged="@(EventCallback.Factory.Create<Option<DbValueSetConcept>>(this, (value) => AddConceptRow(value)))" />
                                            </Body>
                                        </FluentPopover>
                                    </div>
                                }
                                <FluentButton IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Save())" Appearance="Appearance.Outline" Title="Mark Reviewd and Save Changes" OnClick="@(() => SaveChanges())">
                                    Mark Reviewed and Save Changes
                                </FluentButton>
                                <FluentSwitch Label="Apply to inverse" @bind-Value="ApplyToInverse"></FluentSwitch>
                            </FluentStack>
                            <br />
                            <div class="grid-container">
                                <FluentDataGrid Items="conceptProjection" ShowHover="true" class="mapping-grid" RowSize="@DataGridRowSize.Large" GridTemplateColumns="80px 2fr 0.5fr 1fr 2fr" >
                                    <TemplateColumn Sortable="false">
                                        @{
                                            var rowKey = $"del-{context.RowId}";
                                            <div>
                                                <FluentButton Id="@($"{rowKey}-btn")"
                                                Appearance="Appearance.Outline"
                                                OnClick="@(() => TogglePopover(rowKey))"
                                                Title="Delete this row">
                                                    <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.SubtractSquare())" Color="@Color.Error" />
                                                </FluentButton>

                                                <FluentPopover AnchorId="@($"{rowKey}-btn")"
                                                VerticalPosition="VerticalPosition.Bottom"
                                                FixedPlacement="true"
                                                Open="@IsPopoverOpen(rowKey)"
                                                OpenChanged="@((value) => SetPopoverState(rowKey, value))">
                                                    <Body>
                                                        <FluentButton IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.CheckmarkCircleWarning())"
                                                        Appearance="Appearance.Outline"
                                                        OnClick="@(() => DeleteConceptRow(context))">
                                                            Confirm Delete
                                                        </FluentButton>
                                                    </Body>
                                                </FluentPopover>
                                            </div>
                                        }
                                    </TemplateColumn>

                                    <TemplateColumn Title="Source" Sortable="true" Tooltip="true" TooltipText="@(e => e[sourceColIndex]!.Concept.Display ?? e[sourceColIndex]!.Concept.FhirKey)">
                                        <FluentLabel Typo="Typography.Body">@context[sourceColIndex]!.Concept.UiDisplay</FluentLabel>
                                    </TemplateColumn>

                                    <TemplateColumn Title="NoMap" Sortable="false">
                                        @{
                                            var noMap = compareRight
                                                ? context[sourceColIndex]!.RightComparison?.NoMap
                                                : context[sourceColIndex]!.LeftComparison?.NoMap;

                                            <FluentCheckbox Value="@(noMap ?? false)" />
                                        }
                                    </TemplateColumn>

                                    <TemplateColumn Title="Relationship" Sortable="false">
                                        @{
                                            var rowKey = $"rel-{context.RowId}";
                                            var relationship = compareRight
                                                ? context[sourceColIndex]!.RightComparison?.Relationship
                                                : context[sourceColIndex]!.LeftComparison?.Relationship;
                                            <div>
                                                <FluentButton Id="@($"{rowKey}-btn")"
                                                Appearance="Appearance.Outline"
                                                OnClick="@(() => TogglePopover(rowKey))">
                                                    @(relationship?.ToString() ?? "-")
                                                </FluentButton>

                                                <FluentPopover AnchorId="@($"{rowKey}-btn")"
                                                VerticalPosition="VerticalPosition.Bottom"
                                                FixedPlacement="true"
                                                Open="@IsPopoverOpen(rowKey)"
                                                OpenChanged="@((value) => SetPopoverState(rowKey, value))">
                                                    <Header>
                                                        <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                                    </Header>
                                                    <Body>
                                                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                            <FluentCombobox Items="@_relationships"
                                                            Name="@($"{rowKey}-combo")"
                                                            Width="950px"
                                                                            Height="700px"
                                                                            Placeholder="Search for a relationship..."
                                                            OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                                            OptionText="@(i => i.Text)"
                                                            Multiple="false"
                                                            Autocomplete="ComboboxAutocomplete.Inline"
                                                            Autofocus="true"
                                                            Open="true"
                                                            SelectedOptionChanged="@(EventCallback.Factory.Create<Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>>(this, (value) => UpdateRelationship(context, value)))" />
                                                        </FluentStack>
                                                    </Body>
                                                </FluentPopover>
                                            </div>
                                        }
                                    </TemplateColumn>

                                    <TemplateColumn Title="Target" Sortable="true" Tooltip="true" TooltipText="@(e => e[targetColIndex]!.Concept.Display ?? e[targetColIndex]!.Concept.FhirKey)">
                                        @{
                                            var rowKey = $"target-{context.RowId}";
                                            var concept = context[targetColIndex]!.Concept;
                                            <div>
                                                <FluentButton Id="@($"{rowKey}-btn")"
                                                Appearance="Appearance.Outline"
                                                OnClick="@(() => TogglePopover(rowKey))">
                                                    @concept.UiDisplay
                                                </FluentButton>

                                                <FluentPopover AnchorId="@($"{rowKey}-btn")"
                                                VerticalPosition="VerticalPosition.Bottom"
                                                FixedPlacement="true"
                                                Open="@IsPopoverOpen(rowKey)"
                                                OpenChanged="@((value) => SetPopoverState(rowKey, value))"
                                                class="concept-popover-container"
                                                AutoFocus="true">
                                                    <Header>
                                                        <FluentLabel Typo="Typography.Body">Select Target Concept</FluentLabel>
                                                    </Header>
                                                    <Body>
                                                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                            <FluentCombobox Items="@_targetConcepts"
                                                            Width="950px"
                                                                            Height="700px"
                                                                            Placeholder="Search for a concept..."
                                                            OptionValue="@(i => i.Value?.Key.ToString() ?? string.Empty)"
                                                            OptionText="@(i => i.Text)"
                                                            Multiple="false"
                                                            Autocomplete="ComboboxAutocomplete.Inline"
                                                            Autofocus="true"
                                                            Open="true"
                                                            SelectedOptionChanged="@(EventCallback.Factory.Create<Option<DbValueSetConcept>>(this, (value) => UpdateTargetConcept(context, value)))"/>
                                                        </FluentStack>
                                                    </Body>
                                                </FluentPopover>
                                            </div>
                                        }
                                    </TemplateColumn>


                                </FluentDataGrid>
                            </div>
                            @* // add a div so that the combo box will display - otherwise it is truncated *@
                            <div class="fluent-pop-container-spacer-tall"></div>
                        </FluentCard>
                    }
                </FluentStack>
            </FluentTab>

        </FluentTabs>
    }
</FluentStack>

<FluentDialog @ref="valueSetSelectionDialog" 
Modal="true"
Hidden="@dialogHidden"
Class="vs-dialog-container">
    <FluentDialogHeader Visible="true">@valueSetDialogTitle</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentTextField @bind-Value="valueSetSearchText" 
            Placeholder="Type to filter value sets..."
            @oninput="FilterValueSets" />

            <div style="height: 400px; overflow-y: auto; margin-bottom: 16px;">
                <FluentDataGrid Items="@filteredValueSets" 
                ResizableColumns="true" 
                GridTemplateColumns="1fr 2fr 1fr"
                TGridItem="DbValueSet">
                    <SelectColumn
                    TGridItem="DbValueSet"
                    SelectMode="DataGridSelectMode.Single"
                    SelectFromEntireRow="true"
                    @bind-SelectedItems="@selectedValueSets" />
                    <PropertyColumn Title="Name" Property="@(vs => vs.Name)" Sortable="true" />
