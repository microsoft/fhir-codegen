@page "/structuremapping/{FhirPackageKey:int}/{StructureKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;

@inject IDialogService DialogService
@inject IXverService Xver
@inject NavigationManager NavigationManager
@inject XverAppConfig ServerConfig

<PageTitle>@($"Mapping {PackageShortName}:{StructureName}")</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Structure mapping for @($"{PackageShortName}:{StructureName}")</FluentLabel>
    @* <FluentLabel Typo="Typography.Body">DB Key: @StructureKey</FluentLabel> *@

    @if ((Xver.IsOpen == false) || (Xver.DbConnection == null))
    {
        <FluentLabel Typo="Typography.Body">Database not open.</FluentLabel>
    }
    else if ((sdUiRec == null) || (sdGraphProjection == null))
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else if (sdUiRec.Projection.Count == 0)
    {
        <FluentLabel Typo="Typography.Body">No mappings found for this structure.</FluentLabel>
    }
    else
    {
        <FluentLabel Typo="Typography.Body">FHIR Specification: <FluentAnchor Appearance="Appearance.Hypertext" Href="@sdUiRec.GetFhirUrl()" Target="_blank">@StructureName</FluentAnchor></FluentLabel>
        <br/>

        <FluentLabel Typo="Typography.Header">Select a structure mapping group:</FluentLabel>
        <FluentDataGrid Items="@sdGraphProjection"
        ResizableColumns="false"
        GridTemplateColumns="@GetMappingTableColumns()"
        MultiLine="true"
        class="alternating-grid">
            <SelectColumn SelectMode="DataGridSelectMode.Single"
            TGridItem="DbGraphSd.DbSdRow"
            SelectFromEntireRow="true"
            Property="@(r => r.RowId == _selectedSdRowId)"
            OnSelect="@(e => StructureMappingRowSelected(e.Item, e.Selected))" />
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                <TemplateColumn Title="@_packages[packageIndex].ShortName" Tooltip="true" TooltipText="@(c => c.CellAt(packageIndex)?.Sd.UiDisplayLong)">
                    @{
                        DbGraphSd.DbSdCell? cell = context[packageIndex];
                    }
                    @if (cell != null)
                    {
                        <FluentStack Orientation="Orientation.Vertical">
                            <FluentLabel Typo="Typography.H6">@cell.Sd.Name</FluentLabel>
                            <FluentBadge Appearance="@(cell.Sd.Key == StructureKey ? Appearance.Accent : Appearance.Neutral)">
                                Elements: @cell.Elements.Count
                            </FluentBadge>
                        </FluentStack>
                    }
                </TemplateColumn>

                @if (i < _packages.Count - 1)
                {
                    <TemplateColumn Title="Comparison" TGridItem="DbGraphSd.DbSdRow">
                        @{
                            DbGraphSd.DbSdCell? cell = context[packageIndex];
                            // int cellIndex = packageIndex;
                            // DbStructureComparison? toRight = context[packageIndex]?.RightComparison;
                            // DbStructureComparison? fromRight = packageIndex < _packages.Count - 1 ? context[packageIndex + 1]?.LeftComparison : null;
                        }
                        @if (cell == null)
                        {
                            <FluentButton>Add</FluentButton>
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage())" />
                                    <FluentButton>Edit</FluentButton>
                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage())" />
                                </FluentStack>
                            </FluentStack>
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

        <br />

        @if (_selectedSdRow != null)
        {
            <FluentDataGrid GenerateHeader="GenerateHeaderOption.None" TGridItem="string" DisplayMode="DataGridDisplayMode.Table" role="grid">
                <FluentDataGridRow RowType="DataGridRowType.Header">
                    <FluentDataGridCell GridColumn="1">
                        <FluentLabel Typo="Typography.Header">Add new mapping:</FluentLabel>
                    </FluentDataGridCell>
                </FluentDataGridRow>

                @foreach ((DbGraphSd.DbSdCell? cell, int cellIndex) in _selectedSdRow.Select((value, idx) => (value, idx)))
                {
                    if (cell == null)
                    {
                        continue;
                    }

                    <FluentDataGridRow>
                        <FluentDataGridCell GridColumn=1>@($"{_packages[cellIndex].ShortName}:{cell.Sd.Name}")</FluentDataGridCell>
                        <FluentDataGridCell GridColumn=2>
                            @if (cellIndex > 0)
                            {
                                int tpIndex = cellIndex - 1;
                                string dialogKey = $"add-lmap-{cell.Sd.Key}";
                                <div>
                                    <FluentButton Appearance="Appearance.Outline"
                                    Title="@($"Add new mapping from {_packages[cellIndex].ShortName}:{cell.Sd.Name} to {_packages[tpIndex].ShortName}")"
                                    OnClick="@(() => ShowStructureSelectionDialog(dialogKey, cellIndex, tpIndex))">
                                        <FluentLabel Typo="Typography.Body">@($"{_packages[cellIndex].ShortName}:{cell.Sd.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                    </FluentButton>
                                </div>
                            }
                        </FluentDataGridCell>
                        <FluentDataGridCell GridColumn=3>
                            @if (cellIndex < _lastPackageIndex)
                            {
                                int tpIndex = cellIndex + 1;
                                string dialogKey = $"add-rmap-{cell.Sd.Key}";
                                <div>
                                    <FluentButton Appearance="Appearance.Outline"
                                    Title="@($"Add new mapping from {_packages[cellIndex].ShortName}:{cell.Sd.Name} to {_packages[tpIndex].ShortName}")"
                                    OnClick="@(() => ShowStructureSelectionDialog(dialogKey, cellIndex, tpIndex))">
                                        <FluentLabel Typo="Typography.Body">@($"{_packages[cellIndex].ShortName}:{cell.Sd.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                    </FluentButton>
                                </div>
                            }
                        </FluentDataGridCell>
                    </FluentDataGridRow>
                }
            </FluentDataGrid> 
        }

        <hr />
        <FluentLabel Typo="Typography.Header">Review element mappings:</FluentLabel>

        <FluentDataGrid Items="@elementGraphProjection"
        ResizableColumns="true"
        GridTemplateColumns="@GetMappingTableColumns()"
        MultiLine="true"
        ShowHover="true"
        class="alternating-grid">
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;

                <TemplateColumn Sortable="true"
                SortBy="@_elementSorters[packageIndex]"
                HeaderTooltip="@(_selectedSdRow?.CellAt(packageIndex)?.Sd.UiDisplayLong)"
                Tooltip="true"
                TooltipText="@(c => c[packageIndex]?.Element.UiDisplayLong ?? $"Add mapping to {_packages[packageIndex].ShortName}:{_selectedSdRow?.CellAt(packageIndex)?.Sd.Name}")"
                Title="@(_selectedSdRow?.CellAt(packageIndex)?.Sd.Name)">
                    @{
                        if (context[packageIndex] == null)
                        {
                            (bool neighborDown, bool neighborUp) = context.HasNeigbors(packageIndex);
                            if (neighborDown)
                            {
                                <FluentButton>Add mapping to @_packages[packageIndex].ShortName</FluentButton>
                            }

                            if (neighborDown && neighborUp)
                            {
                                <br/>
                            }

                            if (neighborUp)
                            {
                                <FluentButton>Add mapping to @_packages[packageIndex].ShortName</FluentButton>
                            }
                        }
                        else
                        {
                            string[] components = context[packageIndex]!.Element.Id.Split('.') ?? [];
                            foreach ((string component, int componentIndex) in components.Select((value, idx) => (value, idx)))
                            {
                                Appearance ba = componentIndex == _lastPackageIndex ? Appearance.Accent : Appearance.Neutral;
                                if (componentIndex == 0)
                                {
                                    <FluentBadge Appearance="@ba">@component</FluentBadge>
                                }
                                else
                                {
                                    <br />
                                    <FluentBadge Appearance="Appearance.Lightweight">.</FluentBadge>
                                    <FluentBadge Appearance="@ba">@component</FluentBadge>
                                }
                            }
                        }
                    }
                </TemplateColumn>

                @if (packageIndex < _lastPackageIndex)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" HeaderTooltip="@(GetComparisonColName(packageIndex))" TGridItem="DbGraphSd.DbElementRow">
                        @{
                            DbGraphSd.DbElementCell? cell = context[packageIndex];
                            // int cellIndex = packageIndex;
                            // DbElementComparison? toRight = context[packageIndex]?.RightComparison;
                            // DbElementComparison? fromRight = packageIndex < _packages.Count - 1 ? context[packageIndex + 1]?.LeftComparison : null;
                        }
                        @if ((cell == null) || (cell.RightCell == null))
                        {
                            @* <FluentBadge Fill="highlight" BackgroundColor="red" Color="white">ELSE</FluentBadge> *@
                            @* <FluentButton>Add</FluentButton> *@
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage())" />
                                    <FluentButton>Edit</FluentButton>
                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage())" />
                                </FluentStack>
                            </FluentStack>

                            @*                             <FluentCombobox Items="@_bidirectionalRelationships"
                                Name="@($"{context.RowNumber}-{packageIndex}-r-combo")"
                                Width="200px"
                                Height="700px"
                                Placeholder="Search for a relationship..."
                                OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                OptionText="@(i => i.Text)"
                                Value="@(cell.BidirectionalRight?.ToString() ?? string.Empty)"
                                Multiple="false"
                                Autocomplete="ComboboxAutocomplete.Inline"
                                Autofocus="true"
                                Open="true"
                                SelectedOptionChanged="@(EventCallback.Factory.Create<Option<BidirectionalRelationshipCodes>>(this, (value) => ElementRelationshipChanged(context, cell, value)))" />
                            <br/>
 *@
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

    }
</FluentStack>


<FluentDialog @ref="structureSelectionDialog"
                Modal="true"
                Hidden="@dialogHidden"
                Class="sd-dialog-container">
    <FluentDialogHeader Visible="true">@structureDialogTitle</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Width="100%">
            <FluentTextField @bind-Value="structureSearchText" Placeholder="Type to filter structures..." @oninput="FilterStructures" />
            <div style="height: 400px; overflow-y: auto; margin-bottom: 16px;">
                <FluentDataGrid Items="@filteredStructures"
                                ResizableColumns="true"
                                GridTemplateColumns="80px 1fr 2fr"
                                TGridItem="DbStructureDefinition">
                    <SelectColumn TGridItem="DbStructureDefinition"
                                    SelectMode="DataGridSelectMode.Single"
                                    SelectFromEntireRow="true"
                                    @bind-SelectedItems="@selectedStructures" />
                    <PropertyColumn Title="Name" Property="@(sd => sd.Name)" Sortable="true" Tooltip="true" IsDefaultSortColumn="true" TooltipText="@(sd => sd.UiDisplayLong)" />
                    <PropertyColumn Title="Title" Property="@(sd => sd.Title)" Sortable="true" Tooltip="true" TooltipText="@(sd => sd.Title)"/>
                </FluentDataGrid>
            </div>

            @if (selectedStructure != null)
            {
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                        <FluentLabel Typo="Typography.H6">Selected Structure</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Name: @selectedStructure.Name</FluentLabel>
                        <FluentLabel Typo="Typography.Body">URL: @selectedStructure.UnversionedUrl</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Snapshot: @selectedStructure.SnapshotCount</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Title: @selectedStructure.Title</FluentLabel>
                    </FluentStack>
                </FluentCard>
            }

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.End">
                <FluentButton Appearance="Appearance.Outline" OnClick="CancelValueSetSelection">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="SelectStructure" Disabled="@(selectedStructure == null)">Select</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentDialogBody>
</FluentDialog>


@code {

    [Parameter]
    public int FhirPackageKey { get; set; }

    [Parameter]
    public int StructureKey { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "packageShort")]
    public string PackageShortName { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "sdName")]
    public string StructureName { get; set; } = string.Empty;

    [CascadingParameter]
    public INavTracker? NavTracker { get; set; } = null;

    private NavPageInfoRec[] _navPages => new NavPageInfoRec[]
    {
        new() { Display = $"{PackageShortName}: Structures", Link = $"/structures/{FhirPackageKey}?packageShort={PackageShortName}" },
        new() { Display = StructureName, Link = $"/structuremapping/{FhirPackageKey}/{StructureKey}/?packageShort={PackageShortName}&sdName={StructureName}" },
    };

    private Guid _selectedSdRowId = Guid.Empty;
    private DbGraphSd.DbSdRow? _selectedSdRow = null;

    private GridSort<DbGraphSd.DbElementRow>[] _elementSorters = [
        GridSort<DbGraphSd.DbElementRow>.ByAscending(r => r[0] == null ? int.MaxValue : r[0]!.Element.ResourceFieldOrder),
        GridSort<DbGraphSd.DbElementRow>.ByAscending(r => r[1] == null ? int.MaxValue : r[1]!.Element.ResourceFieldOrder),
        GridSort<DbGraphSd.DbElementRow>.ByAscending(r => r[2] == null ? int.MaxValue : r[2]!.Element.ResourceFieldOrder),
        GridSort<DbGraphSd.DbElementRow>.ByAscending(r => r[3] == null ? int.MaxValue : r[3]!.Element.ResourceFieldOrder),
        GridSort<DbGraphSd.DbElementRow>.ByAscending(r => r[4] == null ? int.MaxValue : r[4]!.Element.ResourceFieldOrder),
        GridSort<DbGraphSd.DbElementRow>.ByAscending(r => r[5] == null ? int.MaxValue : r[5]!.Element.ResourceFieldOrder),
        GridSort<DbGraphSd.DbElementRow>.ByAscending(r => r[6] == null ? int.MaxValue : r[6]!.Element.ResourceFieldOrder),
    ];

    private int _loadedStructureKey = -1;
    private SdRecForUi? sdUiRec = null;
    private List<DbFhirPackage> _packages = [];
    private int _lastPackageIndex = -1;
    private IQueryable<DbGraphSd.DbSdRow>? sdGraphProjection = null;
    private List<DbGraphSd.DbElementRow> initialElementProjection = [];
    private IQueryable<DbGraphSd.DbElementRow>? elementGraphProjection = null;

    private Option<BidirectionalRelationshipCodes>[] _bidirectionalRelationships = [
        new() { Text = "None", Value = BidirectionalRelationshipCodes.None },
        new() { Text = "Equivalent", Value = BidirectionalRelationshipCodes.Equivalent },
        new() { Text = "Newer Narrows", Value = BidirectionalRelationshipCodes.NewerNarrows },
        new() { Text = "Newer Broadens", Value = BidirectionalRelationshipCodes.NewerBroadens },
        new() { Text = "Related", Value = BidirectionalRelationshipCodes.Related },
        new() { Text = "NOT Related", Value = BidirectionalRelationshipCodes.NotRelated },
        new()
        {
            Text = "Mismatched",
            Value = BidirectionalRelationshipCodes.Mismatched,
            // Icon = (new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning(), null, "start"),
        },
    ];
    protected override void OnInitialized()
    {
        base.OnInitialized();
        NavTracker?.NotifyNav(_navPages);
        LoadStructure();
    }

    protected override void OnParametersSet()
    {
        if (StructureKey != _loadedStructureKey)
        {
            NavTracker?.NotifyNav(_navPages);
        }

        base.OnParametersSet();
        LoadStructure();
    }

    private string GetComparisonColName(int index) => _packages[index].ShortName + "-" + _packages[index + 1].ShortName;

    private void ElementRelationshipChanged(DbGraphSd.DbElementRow elementRow, DbGraphSd.DbElementCell? cell, object? value)
    {
        if (value is Option<BidirectionalRelationshipCodes> opt)
        {
            Console.Write("");
        }
    }

    private void StructureMappingRowSelected(DbGraphSd.DbSdRow r, bool selected)
    {
        if (selected == true)
        {
            _selectedSdRowId = r.RowId;
            LoadMappingRow(r);
            StateHasChanged();
        }
    }

    private string GetMappingTableColumns(bool addSelectionCol = false)
    {
        // Calculate the columns - we need one for each package plus comparison columns between them
        int packageCount = _packages.Count;
        int comparisonCount = packageCount - 1; // One less comparison column than packages

        // Build column template: package (1fr) + comparison (0.8fr) + package (1fr) + ...
        List<string> cols = [];

        if (addSelectionCol)
        {
            cols.Add("60 px");
        }

        for (int i = 0; i < packageCount; i++)
        {
            cols.Add("1fr"); // Package column

            if (i < comparisonCount)
            {
                cols.Add("0.8fr"); // Comparison column
            }
        }

        return string.Join(' ', cols);
    }


    // Track open state of popovers
    private Dictionary<string, bool> _popoverStates = new();

    private bool IsPopoverOpen(string key)
    {
        return _popoverStates.TryGetValue(key, out bool value) && value;
    }

    private void SetPopoverState(string key, bool value)
    {
        _popoverStates[key] = value;
        StateHasChanged();
    }

    private void TogglePopover(string key)
    {
        if (!_popoverStates.TryGetValue(key, out bool currentValue))
        {
            currentValue = false;
        }
        _popoverStates[key] = !currentValue;
        StateHasChanged();
    }


    // New fields for the structure selection dialog
    private FluentDialog? structureSelectionDialog;
    private string structureDialogTitle = "Select Target Structure...";
    private string structureSearchText = "";
    private List<DbStructureDefinition> allStructures = [];
    private IQueryable<DbStructureDefinition> filteredStructures = Enumerable.Empty<DbStructureDefinition>().AsQueryable();
    private DbStructureDefinition? selectedStructure => selectedStructures.FirstOrDefault();
    private IEnumerable<DbStructureDefinition> selectedStructures = [];
    private bool dialogHidden = true;

    // Dialog context data
    private string currentDialogKey = "";
    private int currentSourceStructureKey;
    private int currentSourcePackageIndex;
    private int currentTargetPackageIndex;

    // Show the ValueSet selection dialog with appropriate context
    private void ShowStructureSelectionDialog(string dialogKey, int sourcePackageIndex, int targetPackageIndex)
    {
        if (_selectedSdRow == null)
        {
            return;
        }

        currentDialogKey = dialogKey;
        currentSourceStructureKey = _selectedSdRow[sourcePackageIndex]!.Sd.Key;
        currentSourcePackageIndex = sourcePackageIndex;
        currentTargetPackageIndex = targetPackageIndex;

        // Set dialog title based on direction
        structureDialogTitle = $"Select target for {_packages[sourcePackageIndex].ShortName}:{_selectedSdRow[sourcePackageIndex]!.Sd.Name} to FHIR {_packages[targetPackageIndex].ShortName}";

        // Reset selection
        selectedStructures = [];
        structureSearchText = "";

        // Load structures for the target package
        LoadStructuresForPackage(targetPackageIndex);

        // Show dialog
        dialogHidden = false;
    }

    // Primary action handler for the dialog
    private void SelectStructure()
    {
        if (selectedStructure != null)
        {
            // Create a similar option object as used in the original code for compatibility
            Option<DbStructureDefinition> selectedOption = new()
                {
                    Text = selectedStructure.Name + " - " + selectedStructure.UnversionedUrl,
                    Value = selectedStructure
                };

            // Call the existing AddVsMapping with our selected value
            AddSdMapping(currentDialogKey, currentSourceStructureKey, currentSourcePackageIndex, currentTargetPackageIndex, selectedOption);
        }

        // valueSetSelectionDialog!.Hide();
        dialogHidden = true;
    }

    private void AddSdMapping(string popKey, int sourceStructureKey, int sourcePackageIndex, int targetPackageIndex, object? selectedValue)
    {
        if ((selectedValue == null) ||
            (selectedValue is not Option<DbStructureDefinition> selectedOption) ||
            (selectedOption.Value == null) ||
            (selectedOption.Value is not DbStructureDefinition targetSd))
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        // resolve the package comparison
        DbFhirPackageComparisonPair? packagePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[sourcePackageIndex].Key,
            TargetPackageKey: _packages[targetPackageIndex].Key);

        if (packagePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        DbFhirPackageComparisonPair? reversePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[targetPackageIndex].Key,
            TargetPackageKey: _packages[sourcePackageIndex].Key);

        if (reversePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // resolve the source value set
        DbStructureDefinition? sourceSd = DbStructureDefinition.SelectSingle(
            Xver.DbConnection,
            FhirPackageKey: _packages[sourcePackageIndex].Key,
            Key: sourceStructureKey);

        if (sourceSd == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // create a new value set comparison
        DbStructureComparison sdComparison = new()
        {
            Key = Xver.ComparisonDb.GetStructureComparisonKey(),
            PackageComparisonKey = packagePair.Key,
            SourceFhirPackageKey = packagePair.SourcePackageKey,
            TargetFhirPackageKey = packagePair.TargetPackageKey,
            SourceStructureKey = sourceStructureKey,
            SourceCanonicalVersioned = sourceSd.VersionedUrl,
            SourceCanonicalUnversioned = sourceSd.UnversionedUrl,
            SourceVersion = sourceSd.Version,
            SourceName = sourceSd.Name,
            TargetStructureKey = targetSd.Key,
            TargetCanonicalVersioned = targetSd.VersionedUrl,
            TargetCanonicalUnversioned = targetSd.UnversionedUrl,
            TargetVersion = targetSd.Version,
            TargetName = targetSd.Name,
            CompositeName = ComparisonDatabase.GetCompositeName(_packages[sourcePackageIndex], sourceSd, _packages[targetPackageIndex], targetSd),
            SourceOverviewConceptMapUrl = null,
            SourceStructureFmlUrl = null,
            Relationship = null,
            ConceptDomainRelationship = null,
            ValueDomainRelationship = null,
            IsGenerated = false,
            LastReviewedOn = null,
            LastReviewedBy = null,
            Message = null,
            IsIdentical = false,
        };

        DbComparisonCache<DbStructureComparison> sdComparisons = new();
        DbComparisonCache<DbElementComparison> elementComparisons = new();
        DbComparisonCache<DbElementTypeComparison> elementTypeComparisons = new();

        sdComparisons.CacheAdd(sdComparison);

        // run through the built-in comparison testing
        Xver.Comparer.DoStructureComparison(
            sdComparisons,
            elementComparisons,
            elementTypeComparisons,
            _packages[sourcePackageIndex],
            sourceSd,
            _packages[targetPackageIndex],
            targetSd,
            sdComparison,
            packagePair,
            reversePair);

        // apply our changes
        sdComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        sdComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        sdComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        elementComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        elementComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        elementComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        elementTypeComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        elementTypeComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        elementTypeComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        // force reload of our UI contents
        LoadStructure(true);

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    // Secondary action handler for the dialog
    private void CancelValueSetSelection()
    {
        // valueSetSelectionDialog!.Hide();
        dialogHidden = true;
    }

    // Load value sets for a specific package
    private void LoadStructuresForPackage(int packageIndex)
    {
        try
        {
            allStructures = DbStructureDefinition.SelectList(
                Xver.DbConnection,
                FhirPackageKey: _packages[packageIndex].Key,
                ArtifactClass: Microsoft.Health.Fhir.CodeGenCommon.Models.FhirArtifactClassEnum.PrimitiveType);

            allStructures.AddRange(DbStructureDefinition.SelectList(
                Xver.DbConnection,
                FhirPackageKey: _packages[packageIndex].Key,
                ArtifactClass: Microsoft.Health.Fhir.CodeGenCommon.Models.FhirArtifactClassEnum.ComplexType));

            allStructures.AddRange(DbStructureDefinition.SelectList(
                Xver.DbConnection,
                FhirPackageKey: _packages[packageIndex].Key,
                ArtifactClass: Microsoft.Health.Fhir.CodeGenCommon.Models.FhirArtifactClassEnum.Resource));

            filteredStructures = allStructures.AsQueryable();
        }
        catch (Exception)
        {
            allStructures = [];
            filteredStructures = Enumerable.Empty<DbStructureDefinition>().AsQueryable();
        }
    }

    // Filter value sets based on search text
    private void FilterStructures(ChangeEventArgs e)
    {
        string? searchText = e.Value?.ToString()?.ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredStructures = allStructures.AsQueryable();
        }
        else
        {
            filteredStructures = allStructures
                .Where(vs =>
                    vs.Name.Contains(searchText!, StringComparison.OrdinalIgnoreCase) ||
                    (vs.Title?.Contains(searchText!, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (vs.Description?.Contains(searchText!, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (vs.Id?.ToLowerInvariant()?.Contains(searchText!) ?? false))
                .AsQueryable();
        }
    }

    private void LoadPackages()
    {
        try
        {
            _packages = DbFhirPackage.SelectList(
                Xver.DbConnection,
                orderByProperties: [nameof(DbFhirPackage.ShortName)]);

            _lastPackageIndex = _packages.Count - 1;
        }
        catch (Exception)
        {
            _packages = [];
            _lastPackageIndex = -1;
        }
    }

    private string GetDateDisplay(DateTime? date) => date == null
        ? string.Empty
        : date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private void LoadMappingRow(DbGraphSd.DbSdRow row)
    {
        if (sdUiRec == null)
        {
            initialElementProjection = [];
            elementGraphProjection = initialElementProjection.AsQueryable();

            return;
        }

        if (_selectedSdRowId != row.RowId)
        {
            _selectedSdRowId = row.RowId;
            _selectedSdRow = row;
        }

        row.BuildProjection(fullJoin: true);

        initialElementProjection = row.Projection;
        elementGraphProjection = initialElementProjection.AsQueryable();

        StateHasChanged();
    }

    private void LoadStructure(bool forceReload = false)
    {
        try
        {
            if ((Xver.IsOpen == false) ||
                (Xver.DbConnection == null) ||
                (Xver.Comparer == null))
            {
                return;
            }

            if ((_loadedStructureKey == StructureKey) && !forceReload)
            {
                return;
            }

            _loadedStructureKey = StructureKey;

            if (_packages.Count == 0)
            {
                LoadPackages();
            }

            // Query Structures for the specified FhirPackageKey
            DbStructureDefinition? sd = DbStructureDefinition.SelectSingle(
                Xver.DbConnection,
                FhirPackageKey: FhirPackageKey,
                Key: StructureKey);

            if (sd == null)
            {
                return;
            }

            sdUiRec = new(Xver.DbConnection, sd, _packages);
            sdGraphProjection = sdUiRec.Projection.AsQueryable();

            _selectedSdRowId = Guid.Empty;
            if (sdUiRec.Projection.Count > 0)
            {
                LoadMappingRow(sdUiRec.Projection[0]);
            }
            else
            {
                _selectedSdRow = null;
                _selectedSdRowId = Guid.Empty;
            }

            StateHasChanged();
        }
        catch (Exception)
        {
        }
    }
}
