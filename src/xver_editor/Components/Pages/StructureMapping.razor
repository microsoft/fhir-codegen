    private (List<ITreeViewItem> items, ITreeViewItem? selectedItem) BuildTreeItemsForSd(DbGraphSd.DbSdCell sdCell, DbElement? selectedElement, int packageIndex)
    {
        if (sdCell.Elements.Count == 0)
        {
            return ([], null);
        }

        ILookup<int, DbElement> elementsByKey = sdCell.Elements.ToLookup(e => e.Key);
        ILookup<int, DbElement> elementsByParent = sdCell.Elements.ToLookup(e => e.ParentElementKey ?? -1);
        Dictionary<string, TreeViewItem> itemsById = [];

        ITreeViewItem? selectedItem = null;
        List<TreeViewItem> rootItems = [];

        // add a 'remove mapping' root
        rootItems.Add(new TreeViewItem
            {
                Id = string.Empty,
                Text = "No Map",
                Items = new List<TreeViewItem>(),
                Expanded = true,
                IconCollapsed = IconNoMap,
                IconExpanded = IconNoMap,
            });

        if (selectedElement == null)
        {
            selectedItem = rootItems[0];
        }

        foreach (DbElement element in sdCell.Elements.OrderBy(e => e.ResourceFieldOrder))
        {
            // this is the root
            if (element.ParentElementKey == null)
            {
                TreeViewItem item = new()
                {
                    Id = element.Id,
                    Text = _packages[packageIndex].ShortName + ": " + element.UiDisplayLong,
                    Items = new List<TreeViewItem>(),
                    Expanded = true,
                    IconCollapsed = IconFolderCollapsed,
                    IconExpanded = IconFolderExpanded,
                };
                itemsById[element.Id] = item;
                rootItems.Add(item);

                if (element.Id == selectedElement?.Id)
                {
                    selectedItem = item;
                }

                continue;
            }

            // resolve the parent element
            DbElement parentElement = elementsByKey[(int)element.ParentElementKey].First();
            if (!itemsById.TryGetValue(parentElement.Id, out TreeViewItem? parentItem))
            {
                parentItem = new TreeViewItem
                {
                    Id = parentElement.Id,
                    Text = parentElement.UiDisplayLong,
                    Items = new List<TreeViewItem>(),
                    Expanded = true,
                    IconCollapsed = parentElement.ChildElementCount == 0 ? IconElement : IconFolderCollapsed,
                    IconExpanded = parentElement.ChildElementCount == 0 ? IconElement : IconFolderExpanded,
                };
                itemsById[parentElement.Id] = parentItem;
            }

            TreeViewItem currentItem = new TreeViewItem
            {
                Id = element.Id,
                Text = element.UiDisplayLong,
                Items = new List<TreeViewItem>(),
                Expanded = true,
                IconCollapsed = element.ChildElementCount == 0 ? IconElement : IconFolderCollapsed,
                IconExpanded = element.ChildElementCount == 0 ? IconElement : IconFolderExpanded,
            };

            itemsById[element.Id] = currentItem;
            if ((selectedElement != null) &&
                (selectedElement.Id == element.Id))
            {
                selectedItem = currentItem;
            }

            if (parentItem.Items is null)
            {
                parentItem.Items = new List<TreeViewItem>
                {
                    currentItem,
                };
            }
            else if (parentItem.Items is List<TreeViewItem> childItems)
            {
                childItems.Add(currentItem);
            }
            else
            {
                currentItem.Items = [.. parentItem.Items, currentItem];
            }
        }

        return (rootItems.ToList<ITreeViewItem>(), selectedItem);
    }

    private void HandleLeftMappingSelectionChanged(FluentTreeItem item)
    {
        HandleMappingElementSelectionChanged(item, isLeft: true);
    }

    private void HandleRightMappingSelectionChanged(FluentTreeItem item)
    {
        HandleMappingElementSelectionChanged(item, isLeft: false);
    }

    private void HandleMappingElementSelectionChanged(FluentTreeItem item, bool isLeft)
    {
        if ((item == null) || (item.Id == null))
        {
            return;
        }

        string id = item.Id;

        foreach (ITreeViewItem tvItem in isLeft ? mappingLeftItems : mappingRightItems)
        {
            ITreeViewItem? foundItem = findItem(tvItem, id);
            if (foundItem != null)
            {
                if (isLeft)
                {
                    mappingLeftSelected = foundItem;
                }
                else
                {
                    mappingRightSelected = foundItem;
                }
                break;
            }
        }

        StateHasChanged();

        return;

        ITreeViewItem? findItem(ITreeViewItem currentItem, string id)
        {
            if (currentItem.Id == id)
            {
                return currentItem;
            }

            if ((!id.StartsWith(currentItem.Id)) ||
                (currentItem.Items == null))
            {
                return null;
            }

            foreach (ITreeViewItem childItem in currentItem.Items)
            {
                ITreeViewItem? foundItem = findItem(childItem, id);
                if (foundItem != null)
                {
                    return foundItem;
                }
            }

            return null;
        }
    }

