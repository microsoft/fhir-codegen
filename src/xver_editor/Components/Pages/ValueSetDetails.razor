    {
        if (selectedValueSet != null)
        {
            // Create a similar option object as used in the original code for compatibility
            var selectedOption = new Option<DbValueSet>
                {
                    Text = selectedValueSet.Name + " - " + selectedValueSet.UnversionedUrl,
                    Value = selectedValueSet
                };

            // Call the existing AddVsMapping with our selected value
            AddVsMapping(currentDialogKey, currentSourceValueSetKey, currentSourcePackageIndex, currentTargetPackageIndex, selectedOption);
        }

        // valueSetSelectionDialog!.Hide();
        dialogHidden = true;
    }

    // Secondary action handler for the dialog
