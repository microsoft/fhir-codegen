    // Load value sets for a specific package
    private void LoadValueSetsForPackage(int packageIndex)
    {
        try
        {
            allValueSets = DbValueSet.SelectList(
                Xver.DbConnection,
                FhirPackageKey: packageIndex,
                orderByProperties: [nameof(DbValueSet.Name)]);

            filteredValueSets = allValueSets.AsQueryable();
        }
        catch (Exception)
        {
            allValueSets = [];
            filteredValueSets = Enumerable.Empty<DbValueSet>().AsQueryable();
        }
    }

    // Filter value sets based on search text
    private void FilterValueSets(ChangeEventArgs e)
    {
        string? searchText = e.Value?.ToString()?.ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredValueSets = allValueSets.AsQueryable();
        }
        else
        {
            filteredValueSets = allValueSets
                .Where(vs =>
                    vs.Name.ToLowerInvariant().Contains(searchText!) ||
                    vs.UnversionedUrl.ToLowerInvariant().Contains(searchText!) ||
                    (vs.Id?.ToLowerInvariant()?.Contains(searchText!) ?? false))
                .AsQueryable();
        }
    }

    private string GetDateDisplay(DateTime? date) => date == null
        ? string.Empty
        : date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private async Task SaveChanges()
    {
        if (selectedComparison == null)
        {
            return;
        }

        string reviewer = ServerConfig.UserName;

        Xver.Comparer.ApplyVsConceptChanges(
            originalProjection,
            conceptProjection,
            sourceColIndex,
            compareRight,
            reviewer);

        // re-aggregate the concept comparisons for the value set if not manually set
        _ = Xver.Comparer.AggregateValueSetRelationships(selectedComparison);

        // check for rules trying to override a manually-set relationship
        if ((manualVsRelationship != null) &&
            (manualVsRelationship != selectedComparison.Relationship))
        {
            IDialogReference dialog = await DialogService.ShowConfirmationAsync(
                $"The ValueSet comparison wants to update to to <code>{selectedComparison.Relationship}</code>.",
                $"Computed: {selectedComparison.Relationship}",
                $"Specified: {manualVsRelationship}",
                "ValueSet Relationship");
            DialogResult result = await dialog.Result;

            if (result.Cancelled == true)
            {
                selectedComparison.Relationship = manualVsRelationship;
            }
        }
        else if ((initialVsRelationship != null) &&
                 (initialVsRelationship != selectedComparison.Relationship))
        {
            IDialogReference dialog = await DialogService.ShowConfirmationAsync(
                $"The ValueSet comparison wants to update to to <code>{selectedComparison.Relationship}</code>.",
                $"Computed: {selectedComparison.Relationship}",
                $"Old: {initialVsRelationship}",
                "ValueSet Relationship");
            DialogResult result = await dialog.Result;

            if (result.Cancelled == true)
            {
                selectedComparison.Relationship = manualVsRelationship;
            }
        }

        // mark this value set comparison as reviewed
        selectedComparison.LastReviewedOn = DateTime.UtcNow;
        selectedComparison.LastReviewedBy = reviewer;
        selectedComparison.Update(Xver.DbConnection);

        // check if the user wants to apply the inverse changes
        if (ApplyToInverse == true)
        {
            (DbValueSetComparison? inverse, bool? hasChanges) = Xver.Comparer.UpdateInversion(selectedComparison);

            // if there is an inverse and it is not reviewed or changed because of these changes, bring it up
            if ((inverse != null) &&
                ((inverse.LastReviewedOn == null) ||(hasChanges == true)))
            {
                // find the correct value set row in the projection
                DbVsRow? vsRow = graphProjection?.FirstOrDefault(v => v.RowId == comparisonFilteredVsRow.RowId);

                if (vsRow != null)
                {
                    // move the UI
                    SelectComparison(comparisonFilteredVsRow, inverse, targetColIndex, sourceColIndex);
                    return;
                }
            }
        }

        // clear our selected comparison
        ClearSelectedComparison();

        // force reload of the mapping table
        LoadValueSet(true);

        // move the UI back to the mapping table
        activeTabId = "mappingTable";
        StateHasChanged();

        return;
    }

    private void ClearSelectedComparison()
    {
        selectedComparison = null;
        _sourceConcepts = [];
        _targetConcepts = [];
        originalProjection = [];
        conceptProjection = Enumerable.Empty<DbVsConceptRow>().AsQueryable();
    }

    private async Task DeleteCurrentMapping()
    {
        if (selectedComparison == null)
        {
            return;
        }

        IDialogReference dialog = await DialogService.ShowConfirmationAsync(
            $"Deleting this mapping cannot be undone!<br/>Are you sure you wish to delete <code>{selectedComparison.CompositeName}</code>",
            "Confirm Delete",
            "Cancel",
            "Delete Mapping Confirmation");
        DialogResult result = await dialog.Result;

        if (result.Cancelled == true)
        {
            StateHasChanged();
            return;
        }

        // check for an inverse comaprison
        DbValueSetComparison? inverseComparison = selectedComparison.InverseComparisonKey != null
            ? DbValueSetComparison.SelectSingle(
                Xver.DbConnection,
                Key: selectedComparison.InverseComparisonKey)
            : null;

        if (inverseComparison != null)
        {
            IDialogReference inverseDialog = await DialogService.ShowConfirmationAsync(
                $"Would you also like to delete the inverse comparison: {inverseComparison.CompositeName} ({inverseComparison.Key})",
                "Yes",
                "No",
                "Delete Inverse");
            DialogResult inverseResult = await dialog.Result;

            // delete the inverse comparison if needed
            if (inverseResult.Cancelled == false)
            {
                // delete all the concept comparisons for this value set comparison
                List<DbValueSetConceptComparison> inverseConceptComparisonsToDelete = DbValueSetConceptComparison.SelectList(
                        Xver.DbConnection,
                        ValueSetComparisonKey: inverseComparison.Key);

                if (inverseConceptComparisonsToDelete.Count > 0)
                {
                    inverseConceptComparisonsToDelete.Delete(Xver.DbConnection);
                }

                // delete this value set comparison
                inverseComparison.Delete(Xver.DbConnection);
            }
        }

        // delete all the concept comparisons for this value set comparison
        List<DbValueSetConceptComparison> conceptComparisonsToDelete = DbValueSetConceptComparison.SelectList(
                Xver.DbConnection,
                ValueSetComparisonKey: selectedComparison.Key);

        if (conceptComparisonsToDelete.Count > 0)
        {
            conceptComparisonsToDelete.Delete(Xver.DbConnection);
        }

        // delete this value set comparison
        selectedComparison.Delete(Xver.DbConnection);

        // clear our selected comparison
        ClearSelectedComparison();

        // force reload of the mapping table
        LoadValueSet(true);

        // move the UI back to the mapping table
        activeTabId = "mappingTable";
        StateHasChanged();

        return;
    }

    private void AddVsMapping(string popKey, int sourceValueSetKey, int sourcePackageIndex, int targetPackageIndex, object? selectedValue)
    {
        if ((selectedValue == null) ||
            (selectedValue is not Option<DbValueSet> selectedOption) ||
            (selectedOption.Value == null) ||
            (selectedOption.Value is not DbValueSet targetVs))
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        // resolve the package comparison
        DbFhirPackageComparisonPair? packagePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[sourcePackageIndex].Key,
            TargetPackageKey: _packages[targetPackageIndex].Key);

        if (packagePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        DbFhirPackageComparisonPair? reversePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[targetPackageIndex].Key,
            TargetPackageKey: _packages[sourcePackageIndex].Key);

        if (reversePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // resolve the source value set
        DbValueSet? sourceVs = DbValueSet.SelectSingle(
            Xver.DbConnection,
            FhirPackageKey: _packages[sourcePackageIndex].Key,
            Key: sourceValueSetKey);

        if (sourceVs == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // create a new value set comparison
        DbValueSetComparison vsComparison = new()
        {
            Key = Xver.ComparisonDb.GetValueSetComparisonKey(),
            PackageComparisonKey = packagePair.Key,
            SourceFhirPackageKey = packagePair.SourcePackageKey,
            TargetFhirPackageKey = packagePair.TargetPackageKey,
            SourceValueSetKey = sourceValueSetKey,
            SourceCanonicalVersioned = sourceVs.VersionedUrl,
            SourceCanonicalUnversioned = sourceVs.UnversionedUrl,
            SourceVersion = sourceVs.Version,
            SourceName = sourceVs.Name,
            TargetValueSetKey = targetVs.Key,
            TargetCanonicalVersioned = targetVs.VersionedUrl,
            TargetCanonicalUnversioned = targetVs.UnversionedUrl,
            TargetVersion = targetVs.Version,
            TargetName = targetVs.Name,
            CompositeName = ComparisonDatabase.GetCompositeName(_packages[sourcePackageIndex], sourceVs, _packages[targetPackageIndex], targetVs),
            SourceConceptMapUrl = null,
            SourceConceptMapAdditionalUrls = null,
            Relationship = null,
            IsGenerated = false,
            LastReviewedOn = null,
            LastReviewedBy = null,
            Message = null,
            IsIdentical = false,
            CodesAreIdentical = false,
        };

        DbComparisonCache<DbValueSetComparison> vsComparisons = new();
        DbComparisonCache<DbValueSetConceptComparison> conceptComparisons = new();

        vsComparisons.CacheAdd(vsComparison);

        // run through the built-in comparison testing
        Xver.Comparer.DoValueSetComparison(
            vsComparisons,
            conceptComparisons,
            _packages[sourcePackageIndex],
            sourceVs,
            _packages[targetPackageIndex],
            targetVs,
            vsComparison,
            packagePair,
            reversePair);

        // apply our changes
        vsComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        vsComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        vsComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        conceptComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        conceptComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        conceptComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        // force reload of our UI contents
        LoadValueSet(true);

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    private void UpdateVsRelationship(object? selectedValue)
    {
        string popKey = "rel-vs";

        if (selectedComparison == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        if ((selectedValue != null) &&
            (selectedValue is Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?> r))
        {
            selectedComparison.Relationship = r.Value;
            manualVsRelationship = r.Value;
        }

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    private void AddConceptRow(object? selectedValue)
    {
        if ((comparisonFilteredVsRow != null) &&
            (csCell != null) &&
            (ctCell != null) &&
            (selectedValue != null) &&
            (selectedValue is Option<DbValueSetConcept> concept) &&
            (concept.Value != null))
        {
            // DbVsConceptRow row = new(_packages.Count, sourceColIndex, conceptProjection.Count());
            DbVsConceptRow row = new(vsUiRec!.Graph, comparisonFilteredVsRow);
            row[sourceColIndex] = new()
            {
                Row = row,
                VsCell = csCell,
                Concept = concept.Value,
            };

            row[targetColIndex] = new()
            {
                Row = row,
                VsCell = ctCell,
                Concept = DbValueSetConcept.EmptyCopy,
            };

            if (compareRight)
            {
                row[targetColIndex]!.LeftCell = row[sourceColIndex];
                row[targetColIndex]!.LeftComparison = DbValueSetConceptComparison.EmptyCopy;
                row[targetColIndex]!.LeftConcept = row[sourceColIndex]!.Concept;
            }
            else
            {
                row[targetColIndex]!.RightCell = row[sourceColIndex];
                row[targetColIndex]!.RightComparison = DbValueSetConceptComparison.EmptyCopy;
                row[targetColIndex]!.RightConcept = row[sourceColIndex]!.Concept;
            }

            List<DbVsConceptRow> cp = [row, .. conceptProjection];

            conceptProjection = cp.AsQueryable();
        }

        // Close the popover after selection
        string key = $"add-concept-row";
        SetPopoverState(key, false);
        StateHasChanged();
    }

    private void DeleteConceptRow(DbVsConceptRow rowToRemove)
    {
        List<DbVsConceptRow> cp = [];
        foreach (DbVsConceptRow row in conceptProjection)
        {
            if (row.RowId != rowToRemove.RowId)
            {
                cp.Add(row);
            }
        }

        conceptProjection = cp.AsQueryable();

        // Close the popover after selection
        string key = $"del-{rowToRemove.RowId}";
        SetPopoverState(key, false);
        StateHasChanged();
        StateHasChanged();
    }

    private void UpdateRelationship(DbVsConceptRow conceptRow, object? selectedValue)
    {
        if ((conceptRow != null) &&
            (conceptRow[sourceColIndex] != null))
        {
            if (compareRight && conceptRow[sourceColIndex]!.RightComparison != null)
            {
                if ((selectedValue != null) &&
                    (selectedValue is Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?> r))
                {
                    // Update the concept in the target cell
                    conceptRow[sourceColIndex]!.RightComparison!.Relationship = r.Value;
                }
                else
                {
                    conceptRow[sourceColIndex]!.RightComparison!.Relationship = null;
                }
            }
            else if (!compareRight && conceptRow[sourceColIndex]!.LeftComparison != null)
            {
                if ((selectedValue != null) &&
                    (selectedValue is Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?> r))
                {
                    // Update the concept in the target cell
                    conceptRow[sourceColIndex]!.LeftComparison!.Relationship = r.Value;
                }
                else
                {
                    conceptRow[sourceColIndex]!.LeftComparison!.Relationship = null;
                }
            }

            // Close the popover after selection
            string key = $"rel-{conceptRow.RowId}";
            SetPopoverState(key, false);
            StateHasChanged();
        }
    }

    private void UpdateTargetConcept(DbVsConceptRow conceptRow, object? selectedValue)
    {
        if ((conceptRow != null) &&
            (conceptRow[targetColIndex] != null))
        {
            if ((selectedValue != null) &&
                (selectedValue is Option<DbValueSetConcept> newConcept))
            {
                // Update the concept in the target cell
                conceptRow[targetColIndex]!.Concept = newConcept.Value!;
            }
            else
            {
                conceptRow[targetColIndex]!.Concept = DbValueSetConcept.EmptyCopy;
            }

            // Close the popover after selection
            string key = $"target-{conceptRow.RowId}";
            SetPopoverState(key, false);
            StateHasChanged();
        }
    }

    private void SelectComparison(
        DbVsRow valueSetRow,
        DbValueSetComparison comparison,
        int sourceCellIndex,
        int targetCellIndex)
    {
        comparisonFilteredVsRow = valueSetRow.ShallowCopy(true);

        compareRight = sourceCellIndex < targetCellIndex;
        selectedComparison = comparison;
        initialVsRelationship = comparison.Relationship;
        manualVsRelationship = null;

        sourceColIndex = sourceCellIndex;
        csCell = valueSetRow[sourceCellIndex];
        csPackage = _packages[sourceCellIndex];

        targetColIndex = targetCellIndex;
        ctCell = valueSetRow[targetCellIndex];
        ctPackage = _packages[targetCellIndex];

        List<DbValueSetConcept> sourceConcepts = DbValueSetConcept.SelectList(
            Xver.DbConnection,
            FhirPackageKey: csCell!.Vs.FhirPackageKey,
            ValueSetKey: csCell!.Vs.Key,
            Inactive: false,
            Abstract: false,
            orderByProperties: [nameof(DbValueSetConcept.System), nameof(DbValueSetConcept.Code)]);

        _sourceConcepts = sourceConcepts.Select(c => new Option<DbValueSetConcept>()
        {
            Text = c.UiDisplayLong,
            Value = c,
        }).ToList();

        List<DbValueSetConcept> targetConcepts = DbValueSetConcept.SelectList(
            Xver.DbConnection,
            FhirPackageKey: ctCell!.Vs.FhirPackageKey,
            ValueSetKey: ctCell!.Vs.Key,
            Inactive: false,
            Abstract: false,
            orderByProperties: [nameof(DbValueSetConcept.System), nameof(DbValueSetConcept.Code)]);

        _targetConcepts = [ new ()
        {
            Text = "-No Concept-",
            Value = DbValueSetConcept.EmptyCopy,
        }];

        _targetConcepts.AddRange(targetConcepts.Select(c => new Option<DbValueSetConcept>()
        {
            Text = c.UiDisplayLong,
            Value = c,
        }));

        // grab the current projection
        originalProjection = comparisonFilteredVsRow.Projection;    // vsUiRec!.Graph.Projection.ProjectConcepts(comparisonFilteredVsRow, sourceCellIndex);

        // make sure we have cells for targets
        foreach (DbVsConceptRow conceptRow in originalProjection)
        {
            if (conceptRow[targetColIndex] == null)
            {
                conceptRow[targetColIndex] = new()
                {
                    Row = conceptRow,
                    VsCell = valueSetRow[targetCellIndex]!,
                    Concept = DbValueSetConcept.EmptyCopy,
                };

                if (compareRight)
                {
                    conceptRow[targetColIndex]!.LeftCell = conceptRow[sourceColIndex];
                    conceptRow[targetColIndex]!.LeftComparison = DbValueSetConceptComparison.EmptyCopy;
                    conceptRow[targetColIndex]!.LeftConcept = conceptRow[sourceColIndex]!.Concept;
                }
                else
                {
                    conceptRow[targetColIndex]!.RightCell = conceptRow[sourceColIndex];
                    conceptRow[targetColIndex]!.RightComparison = DbValueSetConceptComparison.EmptyCopy;
                    conceptRow[targetColIndex]!.RightConcept = conceptRow[sourceColIndex]!.Concept;
                }
            }
        }

        conceptProjection = originalProjection.AsQueryable();

        activeTabId = "comparisonDetails";
        StateHasChanged();
    }

    private void LoadPackages()
    {
        try
        {
            _packages = DbFhirPackage.SelectList(
                Xver.DbConnection,
                orderByProperties: [nameof(DbFhirPackage.ShortName)]);
        }
        catch (Exception)
        {
            _packages = [];
        }
    }

    private void LoadValueSet(bool forceReload = false)
    {
        try
        {
            if ((Xver.IsOpen == false) ||
                (Xver.DbConnection == null) ||
                (Xver.Comparer == null))
            {
                return;
            }

            if ((_loadedValueSetKey == ValueSetKey) && !forceReload)
            {
                return;
            }

            _loadedValueSetKey = ValueSetKey;

            if (_packages.Count == 0)
            {
                LoadPackages();
            }

            // Query ValueSets for the specified FhirPackageKey
            DbValueSet? vs = DbValueSet.SelectSingle(
                Xver.DbConnection,
                FhirPackageKey: FhirPackageKey,
                Key: ValueSetKey);

            if (vs == null)
            {
                return;
            }

            _boundElements = DbElement.SelectList(
                Xver.DbConnection,
                BindingValueSetKey: ValueSetKey,
                orderByProperties: [nameof(DbElement.Key)])
                .AsQueryable();

            foreach (DbElement element in _boundElements)
            {
                if (_boundStructures.ContainsKey(element.StructureKey))
                {
                    continue;
                }

                DbStructureDefinition? structure = DbStructureDefinition.SelectSingle(
                    Xver.DbConnection,
                    Key: element.StructureKey);
                if (structure != null)
                {
                    _boundStructures[element.StructureKey] = structure;
                }
            }

            vsUiRec = new(Xver.DbConnection, vs, _packages);
            graphProjection = vsUiRec.Projection.AsQueryable();
            StateHasChanged();
        }
        catch (Exception)
        {
        }
    }
}
