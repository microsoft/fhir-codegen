    private async Task DeleteVsMapping(Guid vsRowId, int leftColIndex, int rightColIndex)
    {
        // resolve the structure mapping row
        DbGraphVs.DbVsRow? vsRow = vsGraphProjection?.FirstOrDefault(r => r.RowId == vsRowId);

        if (vsRow == null)
        {
            return;
        }

        // resolve the two sd cells
        DbGraphVs.DbVsCell? vsLeftCell = vsRow[leftColIndex];
        DbGraphVs.DbVsCell? vsRightCell = vsRow[rightColIndex];

        if ((vsLeftCell == null) || (vsRightCell == null))
        {
            return;
        }

        VisibleDialogCodes previousDialogState = visibleDialog;

        // need to hide the dialog because these all use the same dialog service
        visibleDialog = VisibleDialogCodes.Confirmation;

        IDialogReference dialog = await DialogService.ShowConfirmationAsync(
            $"This will delete ALL comparison records between:<br/>" +
                $"FHIR {_packages[leftColIndex].ShortName}:<br/><code>{vsLeftCell.Vs.UiDisplayLong}</code><br/>" +
                $" - and -<br/>" +
                $"FHIR {_packages[leftColIndex].ShortName}:<br/><code>{vsRightCell.Vs.UiDisplayLong}</code>",
            "Confirm Delete",
            "Cancel",
            "Value Set Mapping");
        DialogResult result = await dialog.Result;

        // regardless of response, go back to previous screen
        visibleDialog = previousDialogState;

        if (result.Cancelled == true)
        {
            // nothing else to do
            return;
        }

        // resolve the value set comparisons
        DbValueSetComparison? vsLR = vsLeftCell.RightComparison;
        DbValueSetComparison? vsRL = vsRightCell.LeftComparison;

        // delete database records
        try
        {
            if (vsLR != null)
            {
                DbValueSetConceptComparison.Delete(Xver.ComparisonDb.DbConnection, ValueSetComparisonKey: vsLR.Key);
                vsLR.Delete(Xver.ComparisonDb.DbConnection);
            }
        }
        catch { }

        try
        {
            if (vsRL != null)
            {
                DbValueSetConceptComparison.Delete(Xver.ComparisonDb.DbConnection, ValueSetComparisonKey: vsRL.Key);
                vsRL.Delete(Xver.ComparisonDb.DbConnection);
            }
        }
        catch { }

        // need to go to main screen since we do not know what was deleted
        visibleDialog = VisibleDialogCodes.None;

        // force a reload of the content to get updated mappings
        LoadValueSet(true);
    }

    private void AddVsMapping(string popKey, int sourceValueSetKey, int sourcePackageIndex, int targetPackageIndex, object? selectedValue)
    {
        if ((selectedValue == null) ||
            (selectedValue is not Option<DbValueSet> selectedOption) ||
            (selectedOption.Value == null) ||
            (selectedOption.Value is not DbValueSet targetVs))
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        // resolve the package comparison
        DbFhirPackageComparisonPair? packagePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[sourcePackageIndex].Key,
            TargetPackageKey: _packages[targetPackageIndex].Key);

        if (packagePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        DbFhirPackageComparisonPair? reversePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[targetPackageIndex].Key,
            TargetPackageKey: _packages[sourcePackageIndex].Key);

        if (reversePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // resolve the source value set
        DbValueSet? sourceVs = DbValueSet.SelectSingle(
            Xver.DbConnection,
            FhirPackageKey: _packages[sourcePackageIndex].Key,
            Key: sourceValueSetKey);

        if (sourceVs == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // create a new value set comparison
        DbValueSetComparison vsComparison = new()
            {
                Key = Xver.ComparisonDb.GetValueSetComparisonKey(),
                PackageComparisonKey = packagePair.Key,
                SourceFhirPackageKey = packagePair.SourcePackageKey,
                TargetFhirPackageKey = packagePair.TargetPackageKey,
                SourceValueSetKey = sourceValueSetKey,
                SourceCanonicalVersioned = sourceVs.VersionedUrl,
                SourceCanonicalUnversioned = sourceVs.UnversionedUrl,
                SourceVersion = sourceVs.Version,
                SourceName = sourceVs.Name,
                TargetValueSetKey = targetVs.Key,
                TargetCanonicalVersioned = targetVs.VersionedUrl,
                TargetCanonicalUnversioned = targetVs.UnversionedUrl,
                TargetVersion = targetVs.Version,
                TargetName = targetVs.Name,
                CompositeName = ComparisonDatabase.GetCompositeName(_packages[sourcePackageIndex], sourceVs, _packages[targetPackageIndex], targetVs),
                SourceConceptMapUrl = null,
                SourceConceptMapAdditionalUrls = null,
                Relationship = null,
                IsGenerated = false,
                LastReviewedOn = null,
                LastReviewedBy = null,
                Message = null,
                IsIdentical = false,
                CodesAreIdentical = false,
            };

        DbComparisonCache<DbValueSetComparison> vsComparisons = new();
        DbComparisonCache<DbValueSetConceptComparison> conceptComparisons = new();

        vsComparisons.CacheAdd(vsComparison);

        // run through the built-in comparison testing
        Xver.Comparer.DoValueSetComparison(
            vsComparisons,
            conceptComparisons,
            _packages[sourcePackageIndex],
            sourceVs,
            _packages[targetPackageIndex],
            targetVs,
            vsComparison,
            packagePair,
            reversePair);

        // apply our changes
        vsComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        vsComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        vsComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        conceptComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        conceptComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        conceptComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        // force reload of our UI contents
        LoadValueSet(true);

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    private void UpdateVsRelationship(Guid vsRowId, int leftColIndex, int rightColIndex, object? selectedValue)
    {
        string popKey = $"er-{vsRowId}-{leftColIndex}";

        DbGraphVs.DbVsRow? vsRow = vsGraphProjection?.FirstOrDefault(r => r.RowId == vsRowId);

        if (vsRow == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        if ((selectedValue == null) ||
            (selectedValue is not Option<BidirectionalRelationshipCodes> brOpt))
        {
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // resolve the left and right vs cells
        DbGraphVs.DbVsCell? vsLeftCell = vsRow[leftColIndex];
        DbGraphVs.DbVsCell? vsRightCell = vsRow[rightColIndex];

        if ((vsLeftCell == null) || (vsRightCell == null))
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // resolve the value set comparisons
        DbValueSetComparison? vsLR = vsLeftCell.RightComparison;
        DbValueSetComparison? vsRL = vsRightCell.LeftComparison;

        if ((vsLR == null) || (vsRL == null))
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // update the comparisons based on the bidirectional comparison
        vsLR.Relationship = brOpt.Value.LeftToRight();
        vsRL.Relationship = brOpt.Value.RightToLeft();

        // update the database
        vsLR.Update(Xver.ComparisonDb.DbConnection);
        vsRL.Update(Xver.ComparisonDb.DbConnection);

        // update the projection for the UI
        vsRow[leftColIndex]!.RightComparison!.Relationship = vsLR.Relationship;
        vsRow[rightColIndex]!.LeftComparison!.Relationship = vsRL.Relationship;

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    // Secondary action handler for the dialog
    private void CancelValueSetSelection()
    {
        // valueSetSelectionDialog!.Hide();
        visibleDialog = VisibleDialogCodes.None;
    }

    // Load value sets for a specific package
    private void LoadValueSetsForPackage(int packageIndex)
    {
        try
        {
            allValueSets = DbValueSet.SelectList(
                Xver.DbConnection,
                FhirPackageKey: _packages[packageIndex].Key,
                orderByProperties: [nameof(DbValueSet.Name)]);

            filteredValueSets = allValueSets.AsQueryable();
        }
        catch (Exception)
        {
            allValueSets = [];
            filteredValueSets = Enumerable.Empty<DbValueSet>().AsQueryable();
        }
    }

    // Filter value sets based on search text
    private void FilterValueSets(ChangeEventArgs e)
    {
        string? searchText = e.Value?.ToString()?.ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredValueSets = allValueSets.AsQueryable();
        }
        else
        {
            filteredValueSets = allValueSets
                .Where(vs =>
                    vs.Name.ToLowerInvariant().Contains(searchText!) ||
                    vs.UnversionedUrl.ToLowerInvariant().Contains(searchText!) ||
                    (vs.Id?.ToLowerInvariant()?.Contains(searchText!) ?? false))
                .AsQueryable();
        }
    }

    private void LoadPackages()
    {
        try
        {
            _packages = DbFhirPackage.SelectList(
                Xver.DbConnection,
                orderByProperties: [nameof(DbFhirPackage.ShortName)]);
            _lastPackageIndex = _packages.Count - 1;
        }
        catch (Exception)
        {
            _packages = [];
            _lastPackageIndex = -1;
        }
    }

    private string GetDateDisplay(DateTime? date) => date == null
        ? string.Empty
        : date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private void LoadMappingRow(DbGraphVs.DbVsRow row)
    {
        if (vsUiRec == null)
        {
            initialConceptProjection = [];
            conceptGraphProjection = initialConceptProjection.AsQueryable();

            return;
        }

        if (_selectedVsRowId != row.RowId)
        {
            _selectedVsRowId = row.RowId;
            _selectedVsRow = row;
        }

        row.BuildConceptProjection(fullJoin: true);

        initialConceptProjection = row.Projection;
        conceptGraphProjection = initialConceptProjection.AsQueryable();
        StateHasChanged();
    }

    private void LoadValueSet(bool forceReload = false)
    {
        try
        {
            if ((Xver.IsOpen == false) ||
                (Xver.DbConnection == null) ||
                (Xver.Comparer == null))
            {
                return;
            }

            if ((_loadedVsKey == ValueSetKey) && !forceReload)
            {
                return;
            }

            _loadedVsKey = ValueSetKey;

            if (_packages.Count == 0)
            {
                LoadPackages();
            }

            // Query Structures for the specified FhirPackageKey
            DbValueSet? vs = DbValueSet.SelectSingle(
                Xver.DbConnection,
                FhirPackageKey: FhirPackageKey,
                Key: ValueSetKey);

            if (vs == null)
            {
                return;
            }

            vsUiRec = new(Xver.DbConnection, vs, _packages);
            vsGraphProjection = vsUiRec.Projection.AsQueryable();

            if (vsUiRec.Projection.Count > 0)
            {
                LoadMappingRow(vsUiRec.Projection[0]);
            }
            else
            {
                _selectedVsRowId = Guid.Empty;
                _selectedVsRow = null;
            }

            StateHasChanged();
        }
        catch (Exception)
        {
        }
    }
}
