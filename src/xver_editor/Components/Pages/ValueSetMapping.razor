@page "/valuesetmapping/{FhirPackageKey:int}/{ValueSetKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;


@inject IDialogService DialogService
@inject IXverService Xver
@inject NavigationManager NavigationManager
@inject XverAppConfig ServerConfig

<PageTitle>@($"Mapping {PackageShortName}:{ValueSetName}")</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Mapping Details details for @PackageShortName @ValueSetName</FluentLabel>

    @if ((Xver.IsOpen == false) || (Xver.DbConnection == null))
    {
        <FluentLabel Typo="Typography.Body">Database not open.</FluentLabel>
    }
    else if ((vsUiRec == null) || (vsGraphProjection == null))
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else if (vsUiRec.Projection.Count == 0)
    {
        <FluentLabel Typo="Typography.Body">No mappings found for this structure.</FluentLabel>
    }
    else
    {
        <FluentLabel Typo="Typography.Header">Select a structure mapping group:</FluentLabel>
        <FluentDataGrid Items="@vsGraphProjection"
        ResizableColumns="false"
        GridTemplateColumns="@GetMappingTableColumns(true)"
        MultiLine="true"
        class="alternating-grid">
            <SelectColumn SelectMode="DataGridSelectMode.Single"
            TGridItem="DbGraphVs.DbVsRow"
            SelectFromEntireRow="true"
            Property="@(r => r.RowId == _selectedVsRowId)"
            OnSelect="@(e => ValueSetMappingRowSelected(e.Item, e.Selected))" />
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                <TemplateColumn Title="@_packages[packageIndex].ShortName" Tooltip="true" TooltipText="@(c => c.CellAt(packageIndex)?.Vs.UiDisplayLong)">
                    @{
                        DbGraphVs.DbVsCell? cell = context[packageIndex];
                    }
                    @if (cell != null)
                    {
                        <FluentStack Orientation="Orientation.Vertical">
                            <FluentLabel Typo="Typography.H6">@cell.Vs.Name</FluentLabel>
                            <FluentBadge Appearance="@(cell.Vs.Key == ValueSetKey ? Appearance.Accent : Appearance.Neutral)">
                                Concepts: @cell.Concepts.Count
                            </FluentBadge>
                        </FluentStack>
                    }
                </TemplateColumn>

                @if (packageIndex < _packages.Count - 1)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" TGridItem="DbGraphVs.DbVsRow">
                        @{
                            DbGraphVs.DbVsCell? cell = context[packageIndex];
                        }
                        @if ((cell == null) || (cell.RightCell == null))
                        {
                            @* <FluentButton>Add</FluentButton> *@
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                                Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                                Title="@(cell.FromRightMessage())" />

                                    @if (cell.RightCell?.LeftComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightCell!.LeftComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightCell!.LeftComparison!.LastReviewedOn)}")"
                                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    @{
                                        string colKey = $"er-{context.RowId}-{packageIndex}";
                                        <div>
                                            <FluentButton Id="@($"{colKey}-btn")"
                                            Appearance="Appearance.Outline"
                                            OnClick="@(() => TogglePopover(colKey))">
                                                Edit
                                            </FluentButton>

                                            <FluentPopover AnchorId="@($"{colKey}-btn")"
                                            VerticalPosition="VerticalPosition.Top"
                                            FixedPlacement="true"
                                            Open="@IsPopoverOpen(colKey)"
                                            OpenChanged="@((value) => SetPopoverState(colKey, value))">
                                                <Header>
                                                    <FluentLabel Typo="Typography.Body">Select Bidirectional Relationship</FluentLabel>
                                                </Header>
                                                <Body>
                                                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                        <FluentCombobox Items="@_bidirectionalRelationships"
                                                        Name="@($"{colKey}-combo")"
                                                        Width="950px"
                                                        Height="700px"
                                                        Placeholder="Search for a relationship..."
                                                        OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                                        OptionText="@(i => i.Text)"
                                                        Multiple="false"
                                                        Autocomplete="ComboboxAutocomplete.Inline"
                                                        Autofocus="true"
                                                        Open="true"
                                                        SelectedOptionChanged="@(EventCallback.Factory.Create<Option<BidirectionalRelationshipCodes>>(this, (value) => UpdateVsRelationship(context.RowId, packageIndex, packageIndex + 1, value)))" />
                                                    </FluentStack>
                                                </Body>
                                            </FluentPopover>
                                        </div>
                                    }

                                    <FluentButton Appearance="Appearance.Outline" Title="Delete this Mapping" OnClick="@(() => DeleteVsMapping(context.RowId, packageIndex, packageIndex + 1))">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Delete())" Color="@Color.Error" />
                                    </FluentButton>

                                    @if (cell.RightComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightComparison!.LastReviewedOn)}")"
                                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                                Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                                Title="@(cell.ToRightMessage())" />
                                </FluentStack>
                            </FluentStack>
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

        <br />

        @if (_selectedVsRow != null)
        {
            <FluentDataGrid GenerateHeader="GenerateHeaderOption.None" TGridItem="string" DisplayMode="DataGridDisplayMode.Table" >
                <FluentDataGridRow RowType="DataGridRowType.Header">
                    <FluentDataGridCell GridColumn="1">
                        <FluentLabel Typo="Typography.Header">Add new mapping:</FluentLabel>
                    </FluentDataGridCell>
                </FluentDataGridRow>

                @foreach ((DbGraphVs.DbVsCell? cell, int cellIndex) in _selectedVsRow.Select((value, idx) => (value, idx)))
                {
                    if (cell == null)
                    {
                        continue;
                    }

                    <FluentDataGridRow RowType="DataGridRowType.Default">
                        <FluentDataGridCell GridColumn=1>@($"{_packages[cellIndex].ShortName}:{cell.Vs.Name}")</FluentDataGridCell>
                        <FluentDataGridCell GridColumn=2>
                            @if (cellIndex > 0)
                            {
                                int tpIndex = cellIndex - 1;
                                <div>
                                    <FluentButton Appearance="Appearance.Outline"
                                    Title="@($"Add new mapping from {_packages[cellIndex].ShortName}:{cell.Vs.Name} to {_packages[tpIndex].ShortName}")"
                                    OnClick="@(() => ShowValueSetSelectionDialog(cellIndex, tpIndex))">
                                        <FluentLabel Typo="Typography.Body">@($"{_packages[cellIndex].ShortName}:{cell.Vs.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                    </FluentButton>
                                </div>
                            }
                        </FluentDataGridCell>
                        <FluentDataGridCell GridColumn=3>
                            @if (cellIndex < _lastPackageIndex)
                            {
                                int tpIndex = cellIndex + 1;
                                <div>
                                    <FluentButton Appearance="Appearance.Outline"
                                    Title="@($"Add new mapping from {_packages[cellIndex].ShortName}:{cell.Vs.Name} to {_packages[tpIndex].ShortName}")"
                                    OnClick="@(() => ShowValueSetSelectionDialog(cellIndex, tpIndex))">
                                        <FluentLabel Typo="Typography.Body">@($"{_packages[cellIndex].ShortName}:{cell.Vs.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                    </FluentButton>
                                </div>
                            }
                        </FluentDataGridCell>
                    </FluentDataGridRow>
                }
            </FluentDataGrid>
        }

        <hr />

        <FluentStack Orientation="Orientation.Horizontal">
            <FluentLabel Typo="Typography.Header">Review concept mappings:</FluentLabel>
            <FluentButton IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" Appearance="Appearance.Outline" Title="Mark displayed mappings as reviewed" OnClick="@(() => MarkReviewed())">
                Mark Reviewed
            </FluentButton>
        </FluentStack>

        <FluentDataGrid Items="@conceptGraphProjection"
        ResizableColumns="true"
        GridTemplateColumns="@GetMappingTableColumns()"
        MultiLine="true"
        ShowHover="true"
        GenerateHeader="GenerateHeaderOption.Sticky">
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                <TemplateColumn Sortable="true"
                SortBy="@_conceptSorters[packageIndex]"
                HeaderTooltip="@(_selectedVsRow?.CellAt(packageIndex)?.Vs.UiDisplayLong)"
                Tooltip="true"
                TooltipText="@(c => c[packageIndex]?.Concept.UiDisplayLong ?? $"Add mapping to {_packages[packageIndex].ShortName}:{_selectedVsRow?.CellAt(packageIndex)?.Vs.Name}")"
                Title="@(_selectedVsRow?.CellAt(packageIndex)?.Vs.Name)">
                    @{
                        if (context[packageIndex] == null)
                        {
                            (bool neighborDown, bool neighborUp) = context.HasNeigbors(packageIndex);
                            if (neighborDown)
                            {
                                <FluentButton OnClick="@(() => ShowConceptMappingDialog(context.RowId, packageIndex - 1, packageIndex))">Add mapping to @_packages[packageIndex].ShortName</FluentButton>
                            }

                            if (neighborDown && neighborUp)
                            {
                                <br />
                            }

                            if (neighborUp)
                            {
                                <FluentButton OnClick="@(() => ShowConceptMappingDialog(context.RowId, packageIndex + 1, packageIndex))">Add mapping to @_packages[packageIndex].ShortName</FluentButton>
                            }
                        }
                        else
                        {
                            <FluentBadge Appearance="Appearance.Accent">@(context[packageIndex]?.Concept.Code)</FluentBadge>
                        }
                    }
                </TemplateColumn>


                // add a comparison column if we are between two packages
                @if (packageIndex < _lastPackageIndex)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" HeaderTooltip="@(GetComparisonColName(packageIndex))" TGridItem="DbGraphVs.DbVsConceptRow">
                        @{
                            DbGraphVs.DbVsConceptCell? cell = context[packageIndex];
                        }
                        @if ((cell == null) || (cell.RightCell == null))
                        {
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>MISMATCHED</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                                Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                                Title="@(cell.FromRightMessage())" />

                                    @if (cell.RightCell?.LeftComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightCell!.LeftComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightCell!.LeftComparison!.LastReviewedOn)}")"
                                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    <FluentButton OnClick="@(() => ShowConceptMappingDialog(context.RowId, packageIndex, packageIndex + 1))">Edit</FluentButton>

                                    @if (cell.RightComparison?.LastReviewedOn == null)
                                    {
                                        <FluentIcon Title="Unreviewed" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Question())" />
                                    }
                                    else
                                    {
                                        <FluentIcon Title="@($"Reviewed by: {cell.RightComparison!.LastReviewedBy} on {GetDateDisplay(cell.RightComparison!.LastReviewedOn)}")"
                                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Checkmark())" />
                                    }

                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                                Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                                Title="@(cell.ToRightMessage())" />
                                </FluentStack>
                            </FluentStack>

                            @*                             <FluentCombobox Items="@_bidirectionalRelationships"
                                Name="@($"{context.RowNumber}-{packageIndex}-r-combo")"
                                Width="200px"
                                Height="700px"
                                Placeholder="Search for a relationship..."
                                OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                OptionText="@(i => i.Text)"
                                Value="@(cell.BidirectionalRight?.ToString() ?? string.Empty)"
                                Multiple="false"
                                Autocomplete="ComboboxAutocomplete.Inline"
                                Autofocus="true"
                                Open="true"
                                SelectedOptionChanged="@(EventCallback.Factory.Create<Option<BidirectionalRelationshipCodes>>(this, (value) => ElementRelationshipChanged(context, cell, value)))" />
                            <br/>
    *@
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

    }
</FluentStack>

<FluentDialog @ref="valueSetSelectionDialog"
Modal="true"
Hidden="@(visibleDialog != VisibleDialogCodes.ValueSetSelection)"
Class="vs-dialog-container">
    <FluentDialogHeader Visible="true">@valueSetDialogTitle</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentTextField @bind-Value="valueSetSearchText"
            Placeholder="Type to filter value sets..."
            @oninput="FilterValueSets" />

            <div style="height: 400px; overflow-y: auto; margin-bottom: 16px;">
                <FluentDataGrid Items="@filteredValueSets"
                ResizableColumns="true"
                GridTemplateColumns="80px 1fr 2fr 1fr"
                TGridItem="DbValueSet">
                    <SelectColumn TGridItem="DbValueSet"
                    SelectMode="DataGridSelectMode.Single"
                    SelectFromEntireRow="true"
                    @bind-SelectedItems="@selectedValueSets" />
                    <PropertyColumn Title="Name" Property="@(vs => vs.Name)" IsDefaultSortColumn="true" Sortable="true" Tooltip="true" TooltipText="@(vs => vs.UiDisplayLong)" />
                    <PropertyColumn Title="URL" Property="@(vs => vs.UnversionedUrl)" Sortable="true" Tooltip="true" TooltipText="@(vs => vs.UnversionedUrl)" />
                    <PropertyColumn Title="Version" Property="@(vs => vs.Version)" Sortable="true" Tooltip="true" TooltipText="@(vs => vs.Version)" />
                </FluentDataGrid>
            </div>

            @if (selectedValueSet != null)
            {
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                        <FluentLabel Typo="Typography.H6">Selected Value Set</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Name: @selectedValueSet.Name</FluentLabel>
                        <FluentLabel Typo="Typography.Body">URL: @selectedValueSet.VersionedUrl</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Title: @selectedValueSet.Title</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Description: @selectedValueSet.Description</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Concepts: @selectedValueSet.ConceptCount</FluentLabel>
                    </FluentStack>
                </FluentCard>
            }

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.End">
                <FluentButton Appearance="Appearance.Outline" OnClick="CancelValueSetSelection">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="SelectValueSet" Disabled="@(selectedValueSet == null)">Select</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentDialogBody>

</FluentDialog>


<FluentDialog @ref="conceptMappingDialog"
Modal="true"
Hidden="@(visibleDialog != VisibleDialogCodes.ConceptMapping)"
Class="concept-dialog-container">
    <FluentDialogHeader Visible="true">Edit Concept Mapping</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentStack Orientation="Orientation.Horizontal" Width="100%">
                <div class="concept-tree-view-container">
                    <FluentTreeView @ref="conceptMappingTreeLeft" Items="@mappingLeftItems" SelectedItem="@mappingLeftSelected" OnSelectedChange="HandleLeftMappingSelectionChanged">
                        <ItemTemplate>
                            <code>@context.Text</code>
                        </ItemTemplate>
                    </FluentTreeView>
                </div>
                @* <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowBidirectionalLeftRight())" /> *@
                <div class="concept-tree-view-container">
                    <FluentTreeView @ref="conceptMappingTreeRight" Items="@mappingRightItems" SelectedItem="@mappingRightSelected" OnSelectedChange="HandleRightMappingSelectionChanged">
                        <ItemTemplate>
                            <code>@context.Text</code>
                        </ItemTemplate>
                    </FluentTreeView>
                </div>
            </FluentStack>
            <hr />

            <FluentLabel Typo="Typography.Body"><b>Left:</b> @_packages[mappingLeftColId].ShortName @mappingLeftSd?.Vs.Name: <code>@mappingLeftSelected?.Text</code></FluentLabel>
            @* <FluentLabel Typo="Typography.Body">Maps as <code>@mapLRRelationship?.Text</code></FluentLabel> *@
            <FluentLabel Typo="Typography.Body"><b><code>Left to Right:</code></b></FluentLabel>
            <FluentLabel Typo="Typography.Body">Relationship:</FluentLabel>
            <FluentCombobox Items="@_relationships"
            Class="full-width"
            Placeholder="Search for a relationship..."
            OptionValue="@(i => i?.Value.ToString() ?? string.Empty)"
            OptionText="@(i => i?.Text)"
            @bind-SelectedOption="@mapLRRelationship"
            Multiple="false"
            Autocomplete="ComboboxAutocomplete.Inline" />
            <FluentLabel Typo="Typography.Body">Mapping Message:</FluentLabel>
            <FluentTextField @bind-Value="@mapLRMessage" Class="full-width" />

            <FluentLabel Typo="Typography.Body"><b>Right:</b> @_packages[mappingRightColId].ShortName @mappingRightSd?.Vs.Name: <code>@mappingRightSelected?.Text</code></FluentLabel>
            @* <FluentLabel Typo="Typography.Body">Maps as <code>@mapRLRelationship</code></FluentLabel> *@
            <FluentLabel Typo="Typography.Body"><b><code>Right to Left:</code></b></FluentLabel>
            <FluentLabel Typo="Typography.Body">Relationship:</FluentLabel>
            <FluentCombobox Items="@_relationships"
            Class="full-width"
            Placeholder="Search for a relationship..."
            OptionValue="@(i => i?.Value.ToString() ?? string.Empty)"
            OptionText="@(i => i?.Text)"
            @bind-SelectedOption="@mapRLRelationship"
            Multiple="false"
            Autocomplete="ComboboxAutocomplete.Inline" />
            <FluentLabel Typo="Typography.Body">Mapping Message:</FluentLabel>
            <FluentTextField @bind-Value="@mapRLMessage" Class="full-width" />

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.Stretch">
                <FluentButton BackgroundColor="var(--error)" Color="#ffffff" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="DeleteConceptMapping">Delete</FluentButton>
                <FluentSpacer/>
                <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.Prohibited())" OnClick="CancelConceptSelection">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size16.Save())" OnClick="UpdateConceptMapping">Update</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentDialogBody>
</FluentDialog>


@code {
    private enum VisibleDialogCodes
    {
        None,
        ValueSetSelection,
        ConceptMapping,
        Confirmation,
    }

    [Parameter]
    public int FhirPackageKey { get; set; }

    [Parameter]
    public int ValueSetKey { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "packageShort")]
    public string PackageShortName { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "vsName")]
    public string ValueSetName { get; set; } = string.Empty;

    [CascadingParameter]
    public INavTracker? NavTracker { get; set; } = null;

    private NavPageInfoRec[] _navPages => new NavPageInfoRec[]
    {
        new() { Display = $"{PackageShortName}: ValueSets", Link = $"/valuesets/{FhirPackageKey}?packageShort={PackageShortName}" },
        new() { Display = ValueSetName, Link = $"/valuesetmapping/{FhirPackageKey}/{ValueSetKey}/?packageShort={PackageShortName}&vsName={ValueSetName}" },
    };

    private Guid _selectedVsRowId = Guid.Empty;
    private DbGraphVs.DbVsRow? _selectedVsRow = null;

    private GridSort<DbGraphVs.DbVsConceptRow>[] _conceptSorters = [
        GridSort<DbGraphVs.DbVsConceptRow>.ByAscending(r => r[0] == null ? string.Empty : r[0]!.Concept.Code),
        GridSort<DbGraphVs.DbVsConceptRow>.ByAscending(r => r[1] == null ? string.Empty : r[1]!.Concept.Code),
        GridSort<DbGraphVs.DbVsConceptRow>.ByAscending(r => r[2] == null ? string.Empty : r[2]!.Concept.Code),
        GridSort<DbGraphVs.DbVsConceptRow>.ByAscending(r => r[3] == null ? string.Empty : r[3]!.Concept.Code),
        GridSort<DbGraphVs.DbVsConceptRow>.ByAscending(r => r[4] == null ? string.Empty : r[4]!.Concept.Code),
        GridSort<DbGraphVs.DbVsConceptRow>.ByAscending(r => r[5] == null ? string.Empty : r[5]!.Concept.Code),
        GridSort<DbGraphVs.DbVsConceptRow>.ByAscending(r => r[6] == null ? string.Empty : r[6]!.Concept.Code),
    ];

    private int _loadedVsKey = -1;
    private VsRecForUi? vsUiRec = null;
    private List<DbFhirPackage> _packages = [];
    private int _lastPackageIndex = -1;
    private IQueryable<DbGraphVs.DbVsRow>? vsGraphProjection = null;
    private List<DbGraphVs.DbVsConceptRow> initialConceptProjection = [];
    private IQueryable<DbGraphVs.DbVsConceptRow>? conceptGraphProjection = null;

    private Option<BidirectionalRelationshipCodes>[] _bidirectionalRelationships = [
        new() { Text = "None", Value = BidirectionalRelationshipCodes.None },
        new() { Text = "Equivalent", Value = BidirectionalRelationshipCodes.Equivalent },
        new() { Text = "Newer Narrows", Value = BidirectionalRelationshipCodes.NewerNarrows },
        new() { Text = "Newer Broadens", Value = BidirectionalRelationshipCodes.NewerBroadens },
        new() { Text = "Related", Value = BidirectionalRelationshipCodes.Related },
        new() { Text = "NOT Related", Value = BidirectionalRelationshipCodes.NotRelated },
        new()
        {
            Text = "Mismatched",
            Value = BidirectionalRelationshipCodes.Mismatched,
            // Icon = (new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning(), null, "start"),
        },
    ];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        NavTracker?.NotifyNav(_navPages);
        LoadValueSet();
    }

    protected override void OnParametersSet()
    {
        if (ValueSetKey != _loadedVsKey)
        {
            NavTracker?.NotifyNav(_navPages);
        }

        base.OnParametersSet();
        LoadValueSet();
    }

    private string GetComparisonColName(int index) => _packages[index].ShortName + "-" + _packages[index + 1].ShortName;

    private void ElementRelationshipChanged(DbGraphVs.DbVsConceptRow elementRow, DbGraphVs.DbVsConceptCell? cell, object? value)
    {
        if (value is Option<BidirectionalRelationshipCodes> opt)
        {
            Console.Write("");
        }
    }

    private void ValueSetMappingRowSelected(DbGraphVs.DbVsRow r, bool selected)
    {
        if (selected == true)
        {
            LoadMappingRow(r);
            StateHasChanged();
        }
    }

    private string GetMappingTableColumns(bool addSelectionCol = false)
    {
        // Calculate the columns - we need one for each package plus comparison columns between them
        int packageCount = _packages.Count;
        int comparisonCount = packageCount - 1; // One less comparison column than packages

        // Build column template: package (1fr) + comparison (0.8fr) + package (1fr) + ...
        List<string> cols = [];

        if (addSelectionCol)
        {
            cols.Add("60 px");
        }

        for (int i = 0; i < packageCount; i++)
        {
            cols.Add("1fr"); // Package column

            if (i < comparisonCount)
            {
                cols.Add("0.8fr"); // Comparison column
            }
        }

        return string.Join(' ', cols);
    }

