    private void UpdateRelationship(DbElementRow elementRow, object? selectedValue, string? relationshipCategory = null)
    {
        if ((elementRow == null) ||
            (elementRow[sourceColIndex] == null))
        {
            return;
        }

        if (compareRight && elementRow[sourceColIndex]!.RightComparison != null)
        {
            if ((selectedValue != null) &&
                (selectedValue is Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?> r))
            {
                // Update the relationship in the target cell
                switch (relationshipCategory)
                {
                    case "cd":
                        elementRow[sourceColIndex]!.RightComparison!.ConceptDomainRelationship = r.Value;
                        break;
                    case "vd":
                        elementRow[sourceColIndex]!.RightComparison!.ValueDomainRelationship = r.Value;
                        break;
                    default:
                        elementRow[sourceColIndex]!.RightComparison!.Relationship = r.Value;
                        break;
                }
            }
            else
            {
                switch (relationshipCategory)
                {
                    case "cd":
                        elementRow[sourceColIndex]!.RightComparison!.ConceptDomainRelationship = null;
                        break;
                    case "vd":
                        elementRow[sourceColIndex]!.RightComparison!.ValueDomainRelationship = null;
                        break;
                    default:
                        elementRow[sourceColIndex]!.RightComparison!.Relationship = null;
                        break;
                }
            }
        }
        else if (!compareRight && elementRow[sourceColIndex]!.LeftComparison != null)
        {
            if ((selectedValue != null) &&
                (selectedValue is Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?> r))
            {
                // Update the relationship in the target cell
                switch (relationshipCategory)
                {
                    case "cd":
                        elementRow[sourceColIndex]!.LeftComparison!.ConceptDomainRelationship = r.Value;
                        break;
                    case "vd":
                        elementRow[sourceColIndex]!.LeftComparison!.ValueDomainRelationship = r.Value;
                        break;
                    default:
                        elementRow[sourceColIndex]!.LeftComparison!.Relationship = r.Value;
                        break;
                }

            }
            else
            {
                switch (relationshipCategory)
                {
                    case "cd":
                        elementRow[sourceColIndex]!.LeftComparison!.ConceptDomainRelationship = null;
                        break;
                    case "vd":
                        elementRow[sourceColIndex]!.LeftComparison!.ValueDomainRelationship = null;
                        break;
                    default:
                        elementRow[sourceColIndex]!.LeftComparison!.Relationship = null;
                        break;
                }
            }
        }

        // Close the popover after selection
        string key = relationshipCategory switch
        {
            "cd" => $"rel-cd-{elementRow.RowNumber}",
            "vd" => $"rel-vd-{elementRow.RowNumber}",
            _ => $"rel-{elementRow.RowNumber}"
        };
        SetPopoverState(key, false);
        StateHasChanged();
    }

