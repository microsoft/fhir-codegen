@page "/valuesetmapping/{FhirPackageKey:int}/{ValueSetKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;

@inject IDialogService DialogService
@inject IXverService Xver
@inject NavigationManager NavigationManager
@inject XverAppConfig ServerConfig

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Value Set details for @ValueSetName (DB Key: @ValueSetKey)</FluentLabel>

    @if ((Xver.IsOpen == false) || (Xver.DbConnection == null))
    {
        <FluentLabel Typo="Typography.Body">Database not open.</FluentLabel>
    }
    else if ((vsUiRec == null) || (vsGraphProjection == null))
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else if (vsUiRec.Projection.Count == 0)
    {
        <FluentLabel Typo="Typography.Body">No mappings found for this structure.</FluentLabel>
    }
    else
    {
        <FluentLabel Typo="Typography.Header">Select a structure mapping group:</FluentLabel>
        <FluentDataGrid Items="@vsGraphProjection"
        ResizableColumns="false"
        GridTemplateColumns="@GetMappingTableColumns(true)"
        MultiLine="true"
        class="alternating-grid">
            <SelectColumn SelectMode="DataGridSelectMode.Single"
            TGridItem="DbVsRow"
            SelectFromEntireRow="true"
            Property="@(r => r.RowNumber == _selectedVsRowNumber)"
            OnSelect="@(e => StructureMappingRowSelected(e.Item, e.Selected))" />
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                <TemplateColumn Title="@_packages[packageIndex].ShortName">
                    @{
                        DbVsCell? cell = context[packageIndex];
                    }
                    @if (cell != null)
                    {
                        <FluentStack Orientation="Orientation.Vertical">
                            <FluentLabel Typo="Typography.H6">@cell.Vs.Name</FluentLabel>
                            <FluentBadge Appearance="@(cell.Vs.Key == ValueSetKey ? Appearance.Accent : Appearance.Neutral)">
                                Concepts: @cell.Concepts.Count
                            </FluentBadge>
                        </FluentStack>
                    }
                </TemplateColumn>

                @if (packageIndex < _packages.Count - 1)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" TGridItem="DbVsRow">
                        @{
                            DbVsCell? cell = context[packageIndex];
                        }
                        @if (cell == null)
                        {
                            <FluentButton>Add</FluentButton>
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowNumber}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage)" />
                                    <FluentButton>Edit</FluentButton>
                                    <FluentIcon id="@($"tr-{context.RowNumber}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage)" />
                                </FluentStack>
                            </FluentStack>
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

        <br />
        <hr />
        <FluentLabel Typo="Typography.Header">Review element mappings:</FluentLabel>

        <FluentDataGrid Items="@conceptGraphProjection"
                        ResizableColumns="false"
                        GridTemplateColumns="@GetMappingTableColumns()"
                        MultiLine="true"
                        ShowHover="true"
                        class="alternating-grid">
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                <TemplateColumn Title="@_mappingColNames[packageIndex]" Tooltip="true" TooltipText="@(c => c[packageIndex]?.Concept.UiDisplayLong)">
                    @{
                        DbVsConceptCell? cell = context[packageIndex];
                    }
                    @if (cell != null)
                    {
                        <FluentLabel Typo="Typography.H6">@cell.Concept.Code</FluentLabel>
                    }
                    else
                    {
                        <FluentLabel Typo="Typography.Body"><em>No map target for @_packages[packageIndex].ShortName</em></FluentLabel>
                    }
                </TemplateColumn>

                // add a comparison column if we are between two packages
                @if (packageIndex < _packages.Count - 1)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" TGridItem="DbVsConceptRow">
                        @{
                            DbVsConceptCell? cell = context[packageIndex];
                        }
                        @if (cell == null)
                        {
                            <FluentButton>Add</FluentButton>
                        }
                        else if (cell.BidirectionalRight != null)
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowNumber}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage)" />
                                    <FluentButton>Edit</FluentButton>
                                    <FluentIcon id="@($"tr-{context.RowNumber}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage)" />
                                </FluentStack>
                            </FluentStack>

                            @*                             <FluentCombobox Items="@_bidirectionalRelationships"
                                Name="@($"{context.RowNumber}-{packageIndex}-r-combo")"
                                Width="200px"
                                Height="700px"
                                Placeholder="Search for a relationship..."
                                OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                OptionText="@(i => i.Text)"
                                Value="@(cell.BidirectionalRight?.ToString() ?? string.Empty)"
                                Multiple="false"
                                Autocomplete="ComboboxAutocomplete.Inline"
                                Autofocus="true"
                                Open="true"
                                SelectedOptionChanged="@(EventCallback.Factory.Create<Option<BidirectionalRelationshipCodes>>(this, (value) => ElementRelationshipChanged(context, cell, value)))" />
                            <br/>
    *@
                        }
                        else
                        {

                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

    }
</FluentStack>

@code {

    [Parameter]
    public int FhirPackageKey { get; set; }

    [Parameter]
    public int ValueSetKey { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "packageShort")]
    public string PackageShortName { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "vsName")]
    public string ValueSetName { get; set; } = string.Empty;

    [CascadingParameter]
    public INavTracker? NavTracker { get; set; } = null;

    private NavPageInfoRec[] _navPages => new NavPageInfoRec[]
    {
        new() { Display = $"{PackageShortName}: ValueSets", Link = $"/valuesets/{FhirPackageKey}?packageShort={PackageShortName}" },
        new() { Display = ValueSetName, Link = $"/valuesetmapping/{FhirPackageKey}/{ValueSetKey}/?packageShort={PackageShortName}&vsName={ValueSetName}" },
    };

    int _selectedVsRowNumber = -1;

    private int _loadedVsKey = -1;
    private VsRecForUi? vsUiRec = null;
    private List<DbFhirPackage> _packages = [];
    private string[] _mappingColNames = [];
    private IQueryable<DbVsRow>? vsGraphProjection = null;
    private List<DbVsConceptRow> initialConceptProjection = [];
    private IQueryable<DbVsConceptRow>? conceptGraphProjection = null;

    private Option<BidirectionalRelationshipCodes>[] _bidirectionalRelationships = [
        new() { Text = "None", Value = BidirectionalRelationshipCodes.None },
        new() { Text = "Equivalent", Value = BidirectionalRelationshipCodes.Equivalent },
        new() { Text = "Newer Narrows", Value = BidirectionalRelationshipCodes.NewerNarrows },
        new() { Text = "Newer Broadens", Value = BidirectionalRelationshipCodes.NewerBroadens },
        new() { Text = "Related", Value = BidirectionalRelationshipCodes.Related },
        new() { Text = "NOT Related", Value = BidirectionalRelationshipCodes.NotRelated },
        new()
        {
            Text = "Mismatched",
            Value = BidirectionalRelationshipCodes.Mismatched,
            // Icon = (new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning(), null, "start"),
        },
    ];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        NavTracker?.NotifyNav(_navPages);
        LoadValueSet();
    }

    protected override void OnParametersSet()
    {
        if (ValueSetKey != _loadedVsKey)
        {
            NavTracker?.NotifyNav(_navPages);
        }

        base.OnParametersSet();
        LoadValueSet();
    }

    private string GetMappingColName(int index) => _mappingColNames.Length == 0
        ? string.Empty
        : _mappingColNames[index];

    private string GetComparisonColName(int index) => _packages[index].ShortName + "-" + _packages[index + 1].ShortName;

    private void ElementRelationshipChanged(DbVsConceptRow elementRow, DbVsConceptCell? cell, object? value)
    {
        if (value is Option<BidirectionalRelationshipCodes> opt)
        {
            Console.Write("");
        }
    }

    private void StructureMappingRowSelected(DbVsRow r, bool selected)
    {
        if (selected == true)
        {
            LoadMappingRow(r);
            StateHasChanged();
        }
    }

    private string GetMappingTableColumns(bool addSelectionCol = false)
    {
        // Calculate the columns - we need one for each package plus comparison columns between them
        int packageCount = _packages.Count;
        int comparisonCount = packageCount - 1; // One less comparison column than packages

        // Build column template: package (1fr) + comparison (0.8fr) + package (1fr) + ...
        List<string> cols = [];

        if (addSelectionCol)
        {
            cols.Add("60 px");
        }

        for (int i = 0; i < packageCount; i++)
        {
            cols.Add("1fr"); // Package column

            if (i < comparisonCount)
            {
                cols.Add("0.8fr"); // Comparison column
            }
        }

        return string.Join(' ', cols);
    }


    private void LoadPackages()
    {
        try
        {
            _packages = DbFhirPackage.SelectList(
                Xver.DbConnection,
                orderByProperties: [nameof(DbFhirPackage.ShortName)]);
        }
        catch (Exception)
        {
            _packages = [];
        }
    }

    private string GetDateDisplay(DateTime? date) => date == null
        ? string.Empty
        : date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private void LoadMappingRow(DbVsRow row)
    {
        if (vsUiRec == null)
        {
            initialConceptProjection = [];
            conceptGraphProjection = initialConceptProjection.AsQueryable();

            return;
        }

        if (_selectedVsRowNumber != row.RowNumber)
        {
            _selectedVsRowNumber = row.RowNumber;
        }

        initialConceptProjection = vsUiRec.Graph.ProjectConcepts(row);
        conceptGraphProjection = initialConceptProjection.AsQueryable();
        StateHasChanged();
    }

    private void LoadValueSet(bool forceReload = false)
    {
        try
        {
            if ((Xver.IsOpen == false) ||
                (Xver.DbConnection == null) ||
                (Xver.Comparer == null))
            {
                return;
            }

            if ((_loadedVsKey == ValueSetKey) && !forceReload)
            {
                return;
            }

            _loadedVsKey = ValueSetKey;

            if (_packages.Count == 0)
            {
                LoadPackages();
            }

            // Query Structures for the specified FhirPackageKey
            DbValueSet? vs = DbValueSet.SelectSingle(
                Xver.DbConnection,
                FhirPackageKey: FhirPackageKey,
                Key: ValueSetKey);

            if (vs == null)
            {
                return;
            }

            vsUiRec = new(Xver.DbConnection, vs, _packages);
            vsGraphProjection = vsUiRec.Projection.AsQueryable();

            if (vsUiRec.Projection.Count > 0)
            {
                List<string> mappingColNames = [];
                for (int i = 0; i < _packages.Count; i++)
                {
                    mappingColNames.Add(_packages[i].ShortName + ":" + (vsUiRec.Projection[0].Cells[i]?.Vs.Name ?? "-"));
                }
                _mappingColNames = mappingColNames.ToArray();

                LoadMappingRow(vsUiRec.Projection[0]);
            }
            else
            {
                _selectedVsRowNumber = -1;
            }

            StateHasChanged();
        }
        catch (Exception)
        {
        }
    }
}
