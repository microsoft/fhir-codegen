    private void BuildElementTrees(DbGraphSd.DbElementRow focusRow, int sourceCol, int targetCol)
    {
        mappingLeftSelected = null;
        mappingRightSelected = null;

        if ((_selectedSdRow == null) ||
            (_selectedSdRow[sourceCol] == null) ||
            (_selectedSdRow[targetCol] == null))
        {
            ClearElementSelection();

            return;
        }

        bool isLeftToRight = sourceCol < targetCol;

        mappingLeftColId = isLeftToRight ? sourceCol: targetCol;
        mappingRightColId = isLeftToRight ? targetCol : sourceCol;

        mappingLeftSd = _selectedSdRow[mappingLeftColId];
        mapLRComparison = isLeftToRight ? focusRow[mappingLeftColId]?.RightComparison : focusRow[mappingRightColId]?.LeftComparison;
        mappingRightSd = _selectedSdRow[mappingRightColId];
        mapRLComparison = isLeftToRight ? focusRow[mappingRightColId]?.LeftComparison : focusRow[mappingLeftColId]?.RightComparison;

        (mappingLeftItems, mappingLeftSelected) = BuildTreeItemsForSd(mappingLeftSd!, focusRow[mappingLeftColId]?.Element, mappingLeftColId);
        (mappingRightItems, mappingRightSelected) = BuildTreeItemsForSd(mappingRightSd!, focusRow[mappingRightColId]?.Element, mappingRightColId);

        mapLRRelationship = mapLRComparison?.Relationship == null
            ? null
            : _relationships.FirstOrDefault(ro => ro.Value == mapLRComparison.Relationship);
        mapLRConceptRelationship = mapLRComparison?.ConceptDomainRelationship == null
            ? null
            : _relationships.FirstOrDefault(ro => ro.Value == mapLRComparison.ConceptDomainRelationship);
        mapLRMessage = mapLRComparison?.TechnicalMessage;
        mapLRUserMessage = mapLRComparison?.UserMessage;

        mapRLRelationship = mapRLComparison?.Relationship == null
            ? null
            : _relationships.FirstOrDefault(ro => ro.Value == mapRLComparison.Relationship);
        mapRLConceptRelationship = mapRLComparison?.ConceptDomainRelationship == null
            ? null
            : _relationships.FirstOrDefault(ro => ro.Value == mapRLComparison.ConceptDomainRelationship);
        mapRLMessage = mapRLComparison?.TechnicalMessage;
        mapRLUserMessage = mapRLComparison?.UserMessage;
    }

