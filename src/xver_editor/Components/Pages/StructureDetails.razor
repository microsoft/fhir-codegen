    private void SelectComparison(
        DbSdRow structureRow,
        DbStructureComparison comparison,
        int sourceCellIndex,
        int targetCellIndex)
    {
        comparisonFilteredSdRow = structureRow.ShallowCopy(null, sourceCellIndex, targetCellIndex);

        compareRight = sourceCellIndex < targetCellIndex;
        selectedComparison = comparison;
        initialSdRelationship = comparison.Relationship;
        manualSdRelationship = null;

        sourceColIndex = sourceCellIndex;
        csCell = structureRow[sourceCellIndex];
        csPackage = _packages[sourceCellIndex];

        targetColIndex = targetCellIndex;
        ctCell = structureRow[targetCellIndex];
        ctPackage = _packages[targetCellIndex];

        List<DbElement> sourceElements = DbElement.SelectList(
            Xver.DbConnection,
            FhirPackageKey: csCell!.Sd.FhirPackageKey,
            StructureKey: csCell!.Sd.Key,
            orderByProperties: [nameof(DbElement.ResourceFieldOrder)]);

        _sourceElements = sourceElements.Select(c => new Option<DbElement>()
            {
                Text = c.UiDisplayLong,
                Value = c,
            }).ToList();

        List<DbElement> targetConcepts = DbElement.SelectList(
            Xver.DbConnection,
            FhirPackageKey: ctCell!.Sd.FhirPackageKey,
            StructureKey: ctCell!.Sd.Key,
            orderByProperties: [nameof(DbElement.Id)]);

        _targetElements = [ new ()
        {
            Text = "-No Concept-",
            Value = DbElement.EmptyCopy,
        }];

        _targetElements.AddRange(targetConcepts.Select(c => new Option<DbElement>()
            {
                Text = c.UiDisplayLong,
                Value = c,
            }));

        // grab the current projection
        originalProjection = sdUiRec!.Graph.ProjectElements(comparisonFilteredSdRow, sourceCellIndex);

        // make sure we have cells for targets
        foreach (DbElementRow elementRow in originalProjection)
        {
            if (elementRow[targetColIndex] == null)
            {
                elementRow[targetColIndex] = new()
                    {
                        SdCell = structureRow[targetCellIndex]!,
                        Element = DbElement.EmptyCopy,
                    };

                if (compareRight)
                {
                    elementRow[targetColIndex]!.LeftCell = elementRow[sourceColIndex];
                    elementRow[targetColIndex]!.LeftComparison = DbElementComparison.EmptyCopy;
                    elementRow[targetColIndex]!.LeftElement = elementRow[sourceColIndex]!.Element;
                }
                else
                {
                    elementRow[targetColIndex]!.RightCell = elementRow[sourceColIndex];
                    elementRow[targetColIndex]!.RightComparison = DbElementComparison.EmptyCopy;
                    elementRow[targetColIndex]!.RightElement = elementRow[sourceColIndex]!.Element;
                }
            }
        }

        UpdateMappingTracking(originalProjection);

        activeTabId = "comparisonDetails";
        StateHasChanged();
    }

    private void UpdateMappingTracking(List<DbElementRow> rows)
    {
        elementProjection = rows;
        ILookup<string, DbElementRow> sourceProjectionLookup = elementProjection.ToLookup(x => x[sourceColIndex]?.Element.Id ?? string.Empty);

        List<ElementRecForUi> mappings = [];
        foreach (Option<DbElement> optElement in _sourceElements)
        {
            mappings.Add(new()
            {
                Element = optElement.Value!,
                Text = optElement.Text ?? string.Empty,
                ElementProjections = sourceProjectionLookup[optElement.Value!.Id].Select(row => new ElementProjectionForUi()
                {
                    Row = row,
                    SourceCell = row[sourceColIndex]!,
                    TargetCell = row[targetColIndex]!,
                    Comparison = compareRight ? row[sourceColIndex]!.RightComparison! : row[sourceColIndex]!.LeftComparison!,
                }).AsQueryable(),
            });
        }

        _mappings = mappings.AsQueryable();
    }

    private void LoadPackages()
    {
        try
        {
            _packages = DbFhirPackage.SelectList(
                Xver.DbConnection,
                orderByProperties: [nameof(DbFhirPackage.ShortName)]);
        }
        catch (Exception)
        {
            _packages = [];
        }
    }

    private void LoadStructure(bool forceReload = false)
    {
        try
        {
            if ((Xver.IsOpen == false) ||
                (Xver.DbConnection == null) ||
                (Xver.Comparer == null))
            {
                return;
            }

            if ((_loadedStructureKey == StructureKey) && !forceReload)
            {
                return;
            }

            _loadedStructureKey = StructureKey;

            if (_packages.Count == 0)
            {
                LoadPackages();
            }

            // Query Structures for the specified FhirPackageKey
            DbStructureDefinition? sd = DbStructureDefinition.SelectSingle(
                Xver.DbConnection,
                FhirPackageKey: FhirPackageKey,
                Key: StructureKey);

            if (sd == null)
            {
                return;
            }

            sdUiRec = new(Xver.DbConnection, sd, _packages);
            graphProjection = sdUiRec.Projection.AsQueryable();
            StateHasChanged();
        }
        catch (Exception)
        {
        }
    }
