@page "/valuesetmapping/{FhirPackageKey:int}/{ValueSetKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;


@inject IDialogService DialogService
@inject IXverService Xver
@inject NavigationManager NavigationManager
@inject XverAppConfig ServerConfig

<PageTitle>@($"Mapping {PackageShortName}:{ValueSetName}")</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Mapping Details details for @PackageShortName @ValueSetName</FluentLabel>

    @if ((Xver.IsOpen == false) || (Xver.DbConnection == null))
    {
        <FluentLabel Typo="Typography.Body">Database not open.</FluentLabel>
    }
    else if ((vsUiRec == null) || (vsGraphProjection == null))
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else if (vsUiRec.Projection.Count == 0)
    {
        <FluentLabel Typo="Typography.Body">No mappings found for this structure.</FluentLabel>
    }
    else
    {
        <FluentLabel Typo="Typography.Header">Select a structure mapping group:</FluentLabel>
        <FluentDataGrid Items="@vsGraphProjection"
        ResizableColumns="false"
        GridTemplateColumns="@GetMappingTableColumns(true)"
        MultiLine="true"
        class="alternating-grid">
            <SelectColumn SelectMode="DataGridSelectMode.Single"
            TGridItem="DbGraphVs.DbVsRow"
            SelectFromEntireRow="true"
            Property="@(r => r.RowId == _selectedVsRowId)"
            OnSelect="@(e => StructureMappingRowSelected(e.Item, e.Selected))" />
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                <TemplateColumn Title="@_packages[packageIndex].ShortName">
                    @{
                        DbGraphVs.DbVsCell? cell = context[packageIndex];
                    }
                    @if (cell != null)
                    {
                        <FluentStack Orientation="Orientation.Vertical">
                            <FluentLabel Typo="Typography.H6">@cell.Vs.Name</FluentLabel>
                            <FluentBadge Appearance="@(cell.Vs.Key == ValueSetKey ? Appearance.Accent : Appearance.Neutral)">
                                Concepts: @cell.Concepts.Count
                            </FluentBadge>
                        </FluentStack>
                    }
                </TemplateColumn>

                @if (packageIndex < _packages.Count - 1)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" TGridItem="DbGraphVs.DbVsRow">
                        @{
                            DbGraphVs.DbVsCell? cell = context[packageIndex];
                        }
                        @if (cell == null)
                        {
                            <FluentButton>Add</FluentButton>
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage())" />
                                    <FluentButton>Edit</FluentButton>
                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage())" />
                                </FluentStack>
                            </FluentStack>
                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

        <br />

        @if (_selectedVsRow != null)
        {
            <FluentLabel Typo="Typography.Header">Add new mapping:</FluentLabel>
                @foreach (DbGraphVs.DbVsCell? cell in _selectedVsRow)
                {
                    if (cell == null)
                    {
                        continue;
                    }

                    <FluentStack Orientation="Orientation.Horizontal">
                        @if (cell.FhirPackageIndex > 0)
                        {
                            int tpIndex = cell.FhirPackageIndex - 1;
                            string dialogKey = $"add-lmap-{cell.Vs.Key}";
                            <div>
                                @* <FluentIcon Value="@(new Icons.Regular.Size20.Add())" /> *@
                                @* <FluentIcon Value="@(new Icons.Regular.Size20.ArrowLeft())" /> *@
                                <FluentButton Appearance="Appearance.Outline"
                                              Title="@($"Add new mapping to {_packages[tpIndex].ShortName}")"
                                              OnClick="@(() => ShowValueSetSelectionDialog(dialogKey, ValueSetKey, cell.FhirPackageIndex, tpIndex))">
                                    <FluentLabel Typo="Typography.Body">@($"{_packages[cell.FhirPackageIndex].ShortName}:{cell.Vs.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                </FluentButton>
                            </div>
                        }

                        @if (cell.FhirPackageIndex < (_packages.Count - 1))
                        {
                            int tpIndex = cell.FhirPackageIndex + 1;
                            string dialogKey = $"add-rmap-{cell.Vs.Key}";
                            <div>
                                @* <FluentIcon Value="@(new Icons.Regular.Size20.Add())" /> *@
                                @* <FluentIcon Value="@(new Icons.Regular.Size20.ArrowRight())" /> *@
                            <FluentButton Appearance="Appearance.Outline"
                                              Title="@($"Add new mapping to {_packages[tpIndex].ShortName}")"
                                              OnClick="@(() => ShowValueSetSelectionDialog(dialogKey, ValueSetKey, cell.FhirPackageIndex, tpIndex))">
                                    <FluentLabel Typo="Typography.Body">@($"{_packages[cell.FhirPackageIndex].ShortName}:{cell.Vs.Name} to FHIR {_packages[tpIndex].ShortName}")</FluentLabel>
                                </FluentButton>
                            </div>
                        }
                    </FluentStack>
                }
        }

        <hr />
        <FluentLabel Typo="Typography.Header">Review element mappings:</FluentLabel>

        <FluentDataGrid Items="@conceptGraphProjection"
                        ResizableColumns="true"
                        GridTemplateColumns="@GetMappingTableColumns()"
                        MultiLine="true"
                        ShowHover="true"
                        GenerateHeader="GenerateHeaderOption.Sticky"
                        class="alternating-grid">
            @for (int i = 0; i < _packages.Count; i++)
            {
                int packageIndex = i;
                
                <PropertyColumn Sortable="true"
                                Title="@(_selectedVsRow?.CellAt(packageIndex)?.Vs.Name)"
                                Tooltip="true"
                                TooltipText="@(c => c[packageIndex]?.Concept.UiDisplayLong)"
                                Property="@(r => r[packageIndex] == null ? "-" : r[packageIndex]!.Concept.Code)">
                </PropertyColumn>


                // add a comparison column if we are between two packages
                @if (packageIndex < _packages.Count - 1)
                {
                    <TemplateColumn Title="@(GetComparisonColName(packageIndex))" TGridItem="DbGraphVs.DbVsConceptRow">
                        @{
                            DbGraphVs.DbVsConceptCell? cell = context[packageIndex];
                        }
                        @if ((cell == null) || (cell.RightCell == null))
                        {
                            <FluentButton>Add</FluentButton>
                        }
                        else if (cell.BidirectionalRight() != null)
                        {
                            <FluentStack Orientation="Orientation.Vertical">
                                @if (cell.BidirectionalRight() == BidirectionalRelationshipCodes.Mismatched)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                        <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning())" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body"><code>@(cell.BidirectionalRight()?.ToString() ?? string.Empty)</code></FluentLabel>
                                }

                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentIcon id="@($"fr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleLeft())"
                                    Title="@(cell.FromRightMessage())" />
                                    <FluentButton>Edit</FluentButton>
                                    <FluentIcon id="@($"tr-{context.RowId}-{packageIndex}-message")"
                                    Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.ArrowCircleRight())"
                                    Title="@(cell.ToRightMessage())" />
                                </FluentStack>
                            </FluentStack>

                            @*                             <FluentCombobox Items="@_bidirectionalRelationships"
                                Name="@($"{context.RowNumber}-{packageIndex}-r-combo")"
                                Width="200px"
                                Height="700px"
                                Placeholder="Search for a relationship..."
                                OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                OptionText="@(i => i.Text)"
                                Value="@(cell.BidirectionalRight?.ToString() ?? string.Empty)"
                                Multiple="false"
                                Autocomplete="ComboboxAutocomplete.Inline"
                                Autofocus="true"
                                Open="true"
                                SelectedOptionChanged="@(EventCallback.Factory.Create<Option<BidirectionalRelationshipCodes>>(this, (value) => ElementRelationshipChanged(context, cell, value)))" />
                            <br/>
    *@
                        }
                        else
                        {

                        }
                    </TemplateColumn>
                }
            }
        </FluentDataGrid>

        <!-- Add a grid for unused codes -->
@*         <FluentDataGrid GridTemplateColumns="@GetMappingTableColumns()"
        GenerateHeader="GenerateHeaderOption.None"
        TGridItem="string"
        class="alternating-grid"
        DisplayMode="DataGridDisplayMode.Grid"
        MultiLine="true"
        ResizableColumns="false">
            <FluentDataGridRow>
                @for (int i = 0; i < _packages.Count; i++)
                {
                    int packageIndex = i;
                    <FluentDataGridCell title="@(_selectedVsRow?.CellAt(packageIndex)?.Vs.Name)">
                        <FluentLabel Typo="Typography.H6">@_selectedVsRow?.CellAt(packageIndex)?.Vs.Name</FluentLabel>
                    </FluentDataGridCell>

                    // add a comparison column if we are between two packages
                    @if (packageIndex < _packages.Count - 1)
                    {
                        <FluentDataGridCell>
                            <FluentLabel Typo="Typography.H4">@GetComparisonColName(packageIndex)</FluentLabel>
                        </FluentDataGridCell>
                    }
                }
            </FluentDataGridRow>
        </FluentDataGrid>
 *@

    }
</FluentStack>



<FluentDialog @ref="valueSetSelectionDialog"
                Modal="true"
                Hidden="@dialogHidden"
                Class="vs-dialog-container">
    <FluentDialogHeader Visible="true">@valueSetDialogTitle</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentTextField @bind-Value="valueSetSearchText"
            Placeholder="Type to filter value sets..."
            @oninput="FilterValueSets" />

            <div style="height: 400px; overflow-y: auto; margin-bottom: 16px;">
                <FluentDataGrid Items="@filteredValueSets"
                ResizableColumns="true"
                GridTemplateColumns="1fr 2fr 1fr"
                TGridItem="DbValueSet">
                    <SelectColumn TGridItem="DbValueSet"
                    SelectMode="DataGridSelectMode.Single"
                    SelectFromEntireRow="true"
                    @bind-SelectedItems="@selectedValueSets" />
                    <PropertyColumn Title="Name" Property="@(vs => vs.Name)" Sortable="true" />
                    <PropertyColumn Title="URL" Property="@(vs => vs.UnversionedUrl)" Sortable="true" />
                    <PropertyColumn Title="Version" Property="@(vs => vs.Version)" Sortable="true" />
                </FluentDataGrid>
            </div>

            @if (selectedValueSet != null)
            {
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                        <FluentLabel Typo="Typography.H6">Selected Value Set</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Name: @selectedValueSet.Name</FluentLabel>
                        <FluentLabel Typo="Typography.Body">URL: @selectedValueSet.UnversionedUrl</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Concepts: @selectedValueSet.ConceptCount</FluentLabel>
                    </FluentStack>
                </FluentCard>
            }

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.End">
                <FluentButton Appearance="Appearance.Outline" OnClick="CancelValueSetSelection">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="SelectValueSet" Disabled="@(selectedValueSet == null)">Select</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentDialogBody>

</FluentDialog>


@code {

    [Parameter]
    public int FhirPackageKey { get; set; }

    [Parameter]
    public int ValueSetKey { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "packageShort")]
    public string PackageShortName { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "vsName")]
    public string ValueSetName { get; set; } = string.Empty;

    [CascadingParameter]
    public INavTracker? NavTracker { get; set; } = null;

    private NavPageInfoRec[] _navPages => new NavPageInfoRec[]
    {
        new() { Display = $"{PackageShortName}: ValueSets", Link = $"/valuesets/{FhirPackageKey}?packageShort={PackageShortName}" },
        new() { Display = ValueSetName, Link = $"/valuesetmapping/{FhirPackageKey}/{ValueSetKey}/?packageShort={PackageShortName}&vsName={ValueSetName}" },
    };

    private Guid _selectedVsRowId = Guid.Empty;

    private DbGraphVs.DbVsRow? _selectedVsRow = null;
    private int _loadedVsKey = -1;
    private VsRecForUi? vsUiRec = null;
    private List<DbFhirPackage> _packages = [];
    private IQueryable<DbGraphVs.DbVsRow>? vsGraphProjection = null;
    private List<DbGraphVs.DbVsConceptRow> initialConceptProjection = [];
    private IQueryable<DbGraphVs.DbVsConceptRow>? conceptGraphProjection = null;

    private Option<BidirectionalRelationshipCodes>[] _bidirectionalRelationships = [
        new() { Text = "None", Value = BidirectionalRelationshipCodes.None },
        new() { Text = "Equivalent", Value = BidirectionalRelationshipCodes.Equivalent },
        new() { Text = "Newer Narrows", Value = BidirectionalRelationshipCodes.NewerNarrows },
        new() { Text = "Newer Broadens", Value = BidirectionalRelationshipCodes.NewerBroadens },
        new() { Text = "Related", Value = BidirectionalRelationshipCodes.Related },
        new() { Text = "NOT Related", Value = BidirectionalRelationshipCodes.NotRelated },
        new()
        {
            Text = "Mismatched",
            Value = BidirectionalRelationshipCodes.Mismatched,
            // Icon = (new Microsoft.FluentUI.AspNetCore.Components.Icons.Color.Size20.Warning(), null, "start"),
        },
    ];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        NavTracker?.NotifyNav(_navPages);
        LoadValueSet();
    }

    protected override void OnParametersSet()
    {
        if (ValueSetKey != _loadedVsKey)
        {
            NavTracker?.NotifyNav(_navPages);
        }

        base.OnParametersSet();
        LoadValueSet();
    }

    private string GetComparisonColName(int index) => _packages[index].ShortName + "-" + _packages[index + 1].ShortName;

    private void ElementRelationshipChanged(DbGraphVs.DbVsConceptRow elementRow, DbGraphVs.DbVsConceptCell? cell, object? value)
    {
        if (value is Option<BidirectionalRelationshipCodes> opt)
        {
            Console.Write("");
        }
    }

    private void StructureMappingRowSelected(DbGraphVs.DbVsRow r, bool selected)
    {
        if (selected == true)
        {
            LoadMappingRow(r);
            StateHasChanged();
        }
    }

    private string GetMappingTableColumns(bool addSelectionCol = false)
    {
        // Calculate the columns - we need one for each package plus comparison columns between them
        int packageCount = _packages.Count;
        int comparisonCount = packageCount - 1; // One less comparison column than packages

        // Build column template: package (1fr) + comparison (0.8fr) + package (1fr) + ...
        List<string> cols = [];

        if (addSelectionCol)
        {
            cols.Add("60 px");
        }

        for (int i = 0; i < packageCount; i++)
        {
            cols.Add("1fr"); // Package column

            if (i < comparisonCount)
            {
                cols.Add("0.8fr"); // Comparison column
            }
        }

        return string.Join(' ', cols);
    }

    // Track open state of popovers
    private Dictionary<string, bool> _popoverStates = new();

    private bool IsPopoverOpen(string key)
    {
        return _popoverStates.TryGetValue(key, out bool value) && value;
    }

    private void SetPopoverState(string key, bool value)
    {
        _popoverStates[key] = value;
        StateHasChanged();
    }

    private void TogglePopover(string key)
    {
        if (!_popoverStates.TryGetValue(key, out bool currentValue))
        {
            currentValue = false;
        }
        _popoverStates[key] = !currentValue;
        StateHasChanged();
    }


    // New fields for the ValueSet selection dialog
    private FluentDialog? valueSetSelectionDialog;
    private string valueSetDialogTitle = "Select Target Value Set...";
    private string valueSetSearchText = "";
    private List<DbValueSet> allValueSets = [];
    private IQueryable<DbValueSet> filteredValueSets = Enumerable.Empty<DbValueSet>().AsQueryable();
    private DbValueSet? selectedValueSet => selectedValueSets.FirstOrDefault();
    private IEnumerable<DbValueSet> selectedValueSets = [];
    private bool dialogHidden = true;

    // Dialog context data
    private string currentDialogKey = "";
    private int currentSourceValueSetKey;
    private int currentSourcePackageIndex;
    private int currentTargetPackageIndex;

    // Show the ValueSet selection dialog with appropriate context
    private void ShowValueSetSelectionDialog(string dialogKey, int sourceValueSetKey, int sourcePackageIndex, int targetPackageIndex)
    {
        currentDialogKey = dialogKey;
        currentSourceValueSetKey = sourceValueSetKey;
        currentSourcePackageIndex = sourcePackageIndex;
        currentTargetPackageIndex = targetPackageIndex;

        // Set dialog title based on direction
        valueSetDialogTitle = $"Select Value Set from {_packages[targetPackageIndex].ShortName}";

        // Reset selection
        selectedValueSets = [];
        valueSetSearchText = "";

        // Load value sets for the target package
        LoadValueSetsForPackage(targetPackageIndex);

        // Show dialog
        // valueSetSelectionDialog?.Show();
        dialogHidden = false;
    }

    // Primary action handler for the dialog
    private void SelectValueSet()
    {
        if (selectedValueSet != null)
        {
            // Create a similar option object as used in the original code for compatibility
            Option<DbValueSet> selectedOption = new()
            {
                Text = selectedValueSet.Name + " - " + selectedValueSet.UnversionedUrl,
                Value = selectedValueSet
            };

            // Call the existing AddVsMapping with our selected value
            AddVsMapping(currentDialogKey, currentSourceValueSetKey, currentSourcePackageIndex, currentTargetPackageIndex, selectedOption);
        }

        // valueSetSelectionDialog!.Hide();
        dialogHidden = true;
    }


    private void AddVsMapping(string popKey, int sourceValueSetKey, int sourcePackageIndex, int targetPackageIndex, object? selectedValue)
    {
        if ((selectedValue == null) ||
            (selectedValue is not Option<DbValueSet> selectedOption) ||
            (selectedOption.Value == null) ||
            (selectedOption.Value is not DbValueSet targetVs))
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        // resolve the package comparison
        DbFhirPackageComparisonPair? packagePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[sourcePackageIndex].Key,
            TargetPackageKey: _packages[targetPackageIndex].Key);

        if (packagePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        DbFhirPackageComparisonPair? reversePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[targetPackageIndex].Key,
            TargetPackageKey: _packages[sourcePackageIndex].Key);

        if (reversePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // resolve the source value set
        DbValueSet? sourceVs = DbValueSet.SelectSingle(
            Xver.DbConnection,
            FhirPackageKey: _packages[sourcePackageIndex].Key,
            Key: sourceValueSetKey);

        if (sourceVs == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // create a new value set comparison
        DbValueSetComparison vsComparison = new()
            {
                Key = Xver.ComparisonDb.GetValueSetComparisonKey(),
                PackageComparisonKey = packagePair.Key,
                SourceFhirPackageKey = packagePair.SourcePackageKey,
                TargetFhirPackageKey = packagePair.TargetPackageKey,
                SourceValueSetKey = sourceValueSetKey,
                SourceCanonicalVersioned = sourceVs.VersionedUrl,
                SourceCanonicalUnversioned = sourceVs.UnversionedUrl,
                SourceVersion = sourceVs.Version,
                SourceName = sourceVs.Name,
                TargetValueSetKey = targetVs.Key,
                TargetCanonicalVersioned = targetVs.VersionedUrl,
                TargetCanonicalUnversioned = targetVs.UnversionedUrl,
                TargetVersion = targetVs.Version,
                TargetName = targetVs.Name,
                CompositeName = ComparisonDatabase.GetCompositeName(_packages[sourcePackageIndex], sourceVs, _packages[targetPackageIndex], targetVs),
                SourceConceptMapUrl = null,
                SourceConceptMapAdditionalUrls = null,
                Relationship = null,
                IsGenerated = false,
                LastReviewedOn = null,
                LastReviewedBy = null,
                Message = null,
                IsIdentical = false,
                CodesAreIdentical = false,
            };

        DbComparisonCache<DbValueSetComparison> vsComparisons = new();
        DbComparisonCache<DbValueSetConceptComparison> conceptComparisons = new();

        vsComparisons.CacheAdd(vsComparison);

        // run through the built-in comparison testing
        Xver.Comparer.DoValueSetComparison(
            vsComparisons,
            conceptComparisons,
            _packages[sourcePackageIndex],
            sourceVs,
            _packages[targetPackageIndex],
            targetVs,
            vsComparison,
            packagePair,
            reversePair);

        // apply our changes
        vsComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        vsComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        vsComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        conceptComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        conceptComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        conceptComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        // force reload of our UI contents
        LoadValueSet(true);

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    // Secondary action handler for the dialog
    private void CancelValueSetSelection()
    {
        // valueSetSelectionDialog!.Hide();
        dialogHidden = true;
    }

    // Load value sets for a specific package
    private void LoadValueSetsForPackage(int packageIndex)
    {
        try
        {
            allValueSets = DbValueSet.SelectList(
                Xver.DbConnection,
                FhirPackageKey: _packages[packageIndex].Key,
                orderByProperties: [nameof(DbValueSet.Name)]);

            filteredValueSets = allValueSets.AsQueryable();
        }
        catch (Exception)
        {
            allValueSets = [];
            filteredValueSets = Enumerable.Empty<DbValueSet>().AsQueryable();
        }
    }

    // Filter value sets based on search text
    private void FilterValueSets(ChangeEventArgs e)
    {
        string? searchText = e.Value?.ToString()?.ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredValueSets = allValueSets.AsQueryable();
        }
        else
        {
            filteredValueSets = allValueSets
                .Where(vs =>
                    vs.Name.ToLowerInvariant().Contains(searchText!) ||
                    vs.UnversionedUrl.ToLowerInvariant().Contains(searchText!) ||
                    (vs.Id?.ToLowerInvariant()?.Contains(searchText!) ?? false))
                .AsQueryable();
        }
    }

    private void LoadPackages()
    {
        try
        {
            _packages = DbFhirPackage.SelectList(
                Xver.DbConnection,
                orderByProperties: [nameof(DbFhirPackage.ShortName)]);
        }
        catch (Exception)
        {
            _packages = [];
        }
    }

    private string GetDateDisplay(DateTime? date) => date == null
        ? string.Empty
        : date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private void LoadMappingRow(DbGraphVs.DbVsRow row)
    {
        if (vsUiRec == null)
        {
            initialConceptProjection = [];
            conceptGraphProjection = initialConceptProjection.AsQueryable();

            return;
        }

        if (_selectedVsRowId != row.RowId)
        {
            _selectedVsRowId = row.RowId;
            _selectedVsRow = row;
        }

        row.BuildConceptProjection(fullJoin: true);

        initialConceptProjection = row.Projection;
        conceptGraphProjection = initialConceptProjection.AsQueryable();
        StateHasChanged();
    }

    private void LoadValueSet(bool forceReload = false)
    {
        try
        {
            if ((Xver.IsOpen == false) ||
                (Xver.DbConnection == null) ||
                (Xver.Comparer == null))
            {
                return;
            }

            if ((_loadedVsKey == ValueSetKey) && !forceReload)
            {
                return;
            }

            _loadedVsKey = ValueSetKey;

            if (_packages.Count == 0)
            {
                LoadPackages();
            }

            // Query Structures for the specified FhirPackageKey
            DbValueSet? vs = DbValueSet.SelectSingle(
                Xver.DbConnection,
                FhirPackageKey: FhirPackageKey,
                Key: ValueSetKey);

            if (vs == null)
            {
                return;
            }

            vsUiRec = new(Xver.DbConnection, vs, _packages);
            vsGraphProjection = vsUiRec.Projection.AsQueryable();

            if (vsUiRec.Projection.Count > 0)
            {
                LoadMappingRow(vsUiRec.Projection[0]);
            }
            else
            {
                _selectedVsRowId = Guid.Empty;
                _selectedVsRow = null;
            }

            StateHasChanged();
        }
        catch (Exception)
        {
        }
    }
}
