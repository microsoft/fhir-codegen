@page "/structures/{FhirPackageKey:int}/{StructureKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;

@inject IDialogService DialogService
@inject IXverService Xver
@inject NavigationManager NavigationManager
@inject XverAppConfig ServerConfig

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Structure details for @StructureName (DB Key: @StructureKey)</FluentLabel>

    @if ((Xver.IsOpen == false) || (Xver.DbConnection == null))
    {
        <FluentLabel Typo="Typography.Body">Database not open.</FluentLabel>
    }
    else if (sdUiRec == null)
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else
    {
        <FluentTabs Width="100%" @ref="tabsComponent" ActiveTabId="@activeTabId">
            <FluentTab Id="overview" Label="Overview">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">Structure Info</FluentLabel>
                    <FluentCard Width="100%">
                        <div style="padding: 16px;">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                                <FluentGrid Columns="2" ColumnSpan="2">
                                    <FluentGridItem>
                                        <FluentTextField Label="Name" Value="@sdUiRec.Sd.Name" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="ID" Value="@sdUiRec.Sd.Id" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="URL" Value="@sdUiRec.Sd.UnversionedUrl" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Version" Value="@sdUiRec.Sd.Version" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Category" Value="@sdUiRec.Sd.ArtifactClass.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Description" Value="@sdUiRec.Sd.Description" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Publication Status" Value="@sdUiRec.Sd.Status.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Snapshot Elements" Value="@sdUiRec.Sd.SnapshotCount.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Differential Elements" Value="@sdUiRec.Sd.DifferentialCount.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Message" Value="@(sdUiRec.Sd.Message ?? "None")" ReadOnly="true" />
                                    </FluentGridItem>
                                </FluentGrid>
                            </FluentStack>
                        </div>
                    </FluentCard>

                </FluentStack>
            </FluentTab>
            <FluentTab Id="mappingTable" Label="All-Version Mapping Table">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">All-Version Mapping Table</FluentLabel>
                    <FluentCard Width="100%">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                            <FluentLabel Typo="Typography.Body">Add mapping for @StructureName</FluentLabel>
                            @for (int i = 0; i < _packages.Count; i++)
                            {
                                int packageIndex = i;
                                if (_packages[packageIndex].Key != FhirPackageKey)
                                {
                                    continue;
                                }

                                if (packageIndex > 0)
                                {
                                    int tpIndex = packageIndex - 1;
                                    string dialogKey = $"add-sd-map-left";
                                    <div>
                                        <FluentButton Appearance="Appearance.Outline"
                                        Title="@($"Add new mapping to {_packages[tpIndex].ShortName}")"
                                        OnClick="@(() => ShowStructureSelectionDialog(dialogKey, StructureKey, packageIndex, tpIndex))">
                                            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" />
                                            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowLeft())" />
                                        </FluentButton>
                                    </div>
                                }

                                if (packageIndex < (_packages.Count - 1))
                                {
                                    int tpIndex = packageIndex + 1;
                                    string dialogKey = $"add-sd-map-right";
                                    <div>
                                        <FluentButton Appearance="Appearance.Outline"
                                        Title="@($"Add new mapping to {_packages[packageIndex+1].ShortName}")"
                                        OnClick="@(() => ShowStructureSelectionDialog(dialogKey, StructureKey, packageIndex, tpIndex))">
                                            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" />
                                            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowRight())" />
                                        </FluentButton>
                                    </div>
                                }
                            }
                        </FluentStack>
                        <div class="grid-container" style="padding: 16px;">
                            @if (sdUiRec.Projection.Count == 0)
                            {
                                <p>No mapping data available for this Structure.</p>
                            }
                            else
                            {
                                <FluentDataGrid Items="@graphProjection" ResizableColumns="true" GridTemplateColumns="@GetMappingTableColumns()" MultiLine="true" class="alternating-grid">
                                    @for (int i = 0; i < _packages.Count; i++)
                                    {
                                        int packageIndex = i;
                                        <TemplateColumn Title="@_packages[packageIndex].ShortName">
                                            @{
                                                DbSdCell? cell = context[packageIndex];
                                            }
                                            @if (cell != null)
                                            {
                                                <FluentStack Orientation="Orientation.Vertical">
                                                    <FluentLabel Typo="Typography.Header">@cell.Sd.Name</FluentLabel>
                                                    <FluentLabel Typo="Typography.Body">@cell.Sd.Id</FluentLabel>
                                                    <FluentBadge Appearance="@(cell.Sd.Key == StructureKey ? Appearance.Accent : Appearance.Neutral)">
                                                        Concepts: @cell.Elements.Count
                                                    </FluentBadge>
                                                </FluentStack>
                                            }
                                        </TemplateColumn>

                                        @if (i < _packages.Count - 1)
                                        {
                                            <TemplateColumn Title="Comparison" TGridItem="DbSdRow">
                                                @{
                                                    DbSdCell? cell = context[packageIndex];
                                                    int cellIndex = packageIndex;
                                                    DbStructureComparison? toRight = context[packageIndex]?.RightComparison;
                                                    DbStructureComparison? fromRight = packageIndex < _packages.Count - 1 ? context[packageIndex + 1]?.LeftComparison : null;
                                                }
                                                @if (cell != null)
                                                {
                                                    @if (toRight != null)
                                                    {
                                                        <FluentStack Orientation="Orientation.Vertical">
                                                            <FluentIcon Value="@(new Icons.Regular.Size24.ArrowRight())" />
                                                            <FluentBadge Appearance="@(toRight.LastReviewedOn == null ? Appearance.Accent : Appearance.Neutral)">
                                                                @(toRight.LastReviewedOn == null ? "Unreviewed" : "Reviewed")
                                                            </FluentBadge>
                                                            <FluentButton OnClick="@(() => SelectComparison(context, toRight, cellIndex, cellIndex + 1))"
                                                            Appearance="Appearance.Outline" IconEnd="@(new Icons.Regular.Size16.WindowDevEdit())">
                                                                Details
                                                            </FluentButton>
                                                            <FluentLabel Typo="Typography.Body">DB Key: @toRight.Key</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@toRight.Relationship</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(GetDateDisplay(toRight.LastReviewedOn))</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(toRight.LastReviewedBy ?? string.Empty)</FluentLabel>
                                                        </FluentStack>
                                                    }

                                                    @if (fromRight != null)
                                                    {
                                                        <FluentStack Orientation="Orientation.Vertical">
                                                            <FluentIcon Value="@(new Icons.Regular.Size24.ArrowLeft())" />
                                                            <FluentBadge Appearance="@(fromRight.LastReviewedOn == null ? Appearance.Accent : Appearance.Neutral)">
                                                                @(fromRight.LastReviewedOn == null ? "Unreviewed" : "Reviewed")
                                                            </FluentBadge>
                                                            <FluentButton OnClick="@(() => SelectComparison(context, fromRight, cellIndex + 1, cellIndex))"
                                                            Appearance="Appearance.Outline"
                                                            IconEnd="@(new Icons.Regular.Size16.WindowDevEdit())">
                                                                Details
                                                            </FluentButton>
                                                            <FluentLabel Typo="Typography.Body">DB Key: @fromRight.Key</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@fromRight.Relationship</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(GetDateDisplay(fromRight.LastReviewedOn))</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(fromRight.LastReviewedBy ?? string.Empty)</FluentLabel>
                                                        </FluentStack>
                                                    }
                                                }
                                            </TemplateColumn>
                                        }
                                    }
                                </FluentDataGrid>
                            }
                        </div>
                    </FluentCard>
                </FluentStack>
            </FluentTab>
            <FluentTab Id="comparisonDetails" Label="Comparison Details">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">Comparison Details</FluentLabel>
                    @if ((selectedComparison == null) || (csCell == null) || (ctCell == null))
                    {
                        <FluentCard>
                            <FluentLabel Typo="Typography.Body">Please select a comparison to review.</FluentLabel>
                        </FluentCard>
                    }
                    else
                    {
                        <FluentCard Width="100%">
                            <FluentStack Orientation="Orientation.Vertical">
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentLabel Typo="Typography.H5">@selectedComparison.CompositeName</FluentLabel>
                                    <FluentButton Id="@($"del-sdc-btn")" Appearance="Appearance.Outline" Title="Delete this Mapping" OnClick="@(() => DeleteCurrentMapping())">
                                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Delete())" Color="@Color.Error" />
                                    </FluentButton>

                                </FluentStack>

                                <FluentTextField Label="Comparison DB Key" Value="@selectedComparison.Key.ToString()" ReadOnly="true" />

                                <FluentDataGrid GenerateHeader="GenerateHeaderOption.None" TGridItem="string" DisplayMode="DataGridDisplayMode.Table" role="grid" class="full-width">
                                    <FluentDataGridRow RowType="DataGridRowType.Header">
                                        <FluentDataGridCell GridColumn=1 CellType="DataGridCellType.ColumnHeader" Style="width: 20%;"></FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2 CellType="DataGridCellType.ColumnHeader" Style="width: 40%;">Source</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3 CellType="DataGridCellType.ColumnHeader" Style="width: 40%;">Target</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Package</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@(csPackage?.NpmId ?? string.Empty)</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@(ctPackage?.NpmId ?? string.Empty)</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Id</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.Id</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.Id</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Name</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.Name</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.Name</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>URL</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.UnversionedUrl</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.UnversionedUrl</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Version</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.Version</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.Version</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Title</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.Title</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.Title</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Description</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.Description</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.Description</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Comment</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.Comment</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.Comment</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Snapshot Count</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.SnapshotCount</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.SnapshotCount</FluentDataGridCell>
                                    </FluentDataGridRow>
                                    <FluentDataGridRow>
                                        <FluentDataGridCell GridColumn=1>Differential Count</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=2>@csCell.Sd.DifferentialCount</FluentDataGridCell>
                                        <FluentDataGridCell GridColumn=3>@ctCell.Sd.DifferentialCount</FluentDataGridCell>
                                    </FluentDataGridRow>
                                </FluentDataGrid>

                                <FluentLabel Typo="Typography.H5">Structure Relationship:</FluentLabel>
                                @{
                                    string relationshipRowKey = $"rel-sd";
                                    Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship? relationship = selectedComparison.Relationship;
                                    <div>
                                        <FluentButton Id="@($"{relationshipRowKey}-btn")"
                                        Appearance="Appearance.Outline"
                                        OnClick="@(() => TogglePopover(relationshipRowKey))">
                                            @(relationship?.ToString() ?? "-")
                                        </FluentButton>

                                        <FluentPopover AnchorId="@($"{relationshipRowKey}-btn")"
                                        VerticalPosition="VerticalPosition.Top"
                                        FixedPlacement="true"
                                        Open="@IsPopoverOpen(relationshipRowKey)"
                                        OpenChanged="@((value) => SetPopoverState(relationshipRowKey, value))">
                                            <Header>
                                                <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                            </Header>
                                            <Body>
                                                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                    <FluentCombobox Items="@_relationships"
                                                    Name="@($"{relationshipRowKey}-combo")"
                                                    Width="950px"
                                                                    Height="700px"
                                                                    Placeholder="Search for a relationship..."
                                                    OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                                    OptionText="@(i => i.Text)"
                                                    Multiple="false"
                                                    Autocomplete="ComboboxAutocomplete.Inline"
                                                    Autofocus="true"
                                                    Open="true"
                                                    SelectedOptionChanged="@(EventCallback.Factory.Create<Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>>(this, (value) => UpdateSdRelationship(value)))" />
                                                </FluentStack>
                                            </Body>
                                        </FluentPopover>
                                    </div>
                                }

                                <FluentLabel Typo="Typography.H5">Structure Concept-Domain Relationship:</FluentLabel>
                                @{
                                    string cdRowKey = $"rel-cd";
                                    Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship? cdRelationship = selectedComparison.ConceptDomainRelationship;
                                    <div>
                                        <FluentButton Id="@($"{cdRowKey}-btn")"
                                        Appearance="Appearance.Outline"
                                        OnClick="@(() => TogglePopover(cdRowKey))">
                                            @(cdRelationship?.ToString() ?? "-")
                                        </FluentButton>

                                        <FluentPopover AnchorId="@($"{cdRowKey}-btn")"
                                        VerticalPosition="VerticalPosition.Top"
                                        FixedPlacement="true"
                                        Open="@IsPopoverOpen(cdRowKey)"
                                        OpenChanged="@((value) => SetPopoverState(cdRowKey, value))">
                                            <Header>
                                                <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                            </Header>
                                            <Body>
                                                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                    <FluentCombobox Items="@_relationships"
                                                    Name="@($"{cdRowKey}-combo")"
                                                    Width="950px"
                                                                    Height="700px"
                                                                    Placeholder="Search for a relationship..."
                                                    OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                                    OptionText="@(i => i.Text)"
                                                    Multiple="false"
                                                    Autocomplete="ComboboxAutocomplete.Inline"
                                                    Autofocus="true"
                                                    Open="true"
                                                    SelectedOptionChanged="@(EventCallback.Factory.Create<Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>>(this, (value) => UpdateSdRelationship(value, "cd")))" />
                                                </FluentStack>
                                            </Body>
                                        </FluentPopover>
                                    </div>
                                }

                                <FluentLabel Typo="Typography.H5">Structure Value-Domain Relationship:</FluentLabel>
                                @{
                                    string vdRowKey = $"rel-vd";
                                    Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship? vdRelationship = selectedComparison.ValueDomainRelationship;
                                    <div>
                                        <FluentButton Id="@($"{vdRowKey}-btn")"
                                        Appearance="Appearance.Outline"
                                        OnClick="@(() => TogglePopover(vdRowKey))">
                                            @(vdRelationship?.ToString() ?? "-")
                                        </FluentButton>

                                        <FluentPopover AnchorId="@($"{vdRowKey}-btn")"
                                        VerticalPosition="VerticalPosition.Top"
                                        FixedPlacement="true"
                                        Open="@IsPopoverOpen(vdRowKey)"
                                        OpenChanged="@((value) => SetPopoverState(vdRowKey, value))">
                                            <Header>
                                                <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                            </Header>
                                            <Body>
                                                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                    <FluentCombobox Items="@_relationships"
                                                    Name="@($"{vdRowKey}-combo")"
                                                    Width="950px"
                                                                    Height="700px"
                                                                    Placeholder="Search for a relationship..."
                                                    OptionValue="@(i => i.Value.ToString() ?? string.Empty)"
                                                    OptionText="@(i => i.Text)"
                                                    Multiple="false"
                                                    Autocomplete="ComboboxAutocomplete.Inline"
                                                    Autofocus="true"
                                                    Open="true"
                                                    SelectedOptionChanged="@(EventCallback.Factory.Create<Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>>(this, (value) => UpdateSdRelationship(value, "vd")))" />
                                                </FluentStack>
                                            </Body>
                                        </FluentPopover>
                                    </div>
                                }

                                <FluentLabel Typo="Typography.H5">Structure Mapping Message:</FluentLabel>
                                <FluentTextField Label="Message" @bind-Value="@selectedComparison.Message" Class="full-width" />

                                @* // add a div so that the combo box will display - otherwise it is truncated *@
                                <div class="fluent-pop-container-spacer-short"></div>
                            </FluentStack>

                        </FluentCard>

                        <FluentCard Width="100%">
                            <FluentStack Orientation="Orientation.Vertical">
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentLabel Typo="Typography.H5">Element Mapping</FluentLabel>
                                    <FluentButton IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Save())" Appearance="Appearance.Outline" Title="Mark Reviewd and Save Changes" OnClick="@(() => SaveChanges())">
                                        Mark Reviewed and Save Changes
                                    </FluentButton>
                                    <FluentSwitch Label="Apply to inverse" @bind-Value="ApplyToInverse"></FluentSwitch>
                                </FluentStack>

                                <FluentDataGrid Items="_mappings" class="mapping-grid" RowSize="@DataGridRowSize.Large" GridTemplateColumns="1fr" MultiLine="true">
                                    <TemplateColumn Sortable="false">
                                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                                            <FluentLabel Typo="Typography.H4">@context.Text</FluentLabel>
                                             <details class="almost-full-width" id="@($"details-{context.Element.Id.Replace('.', '-')}")">
                                                <summary>Element Details</summary>
                                                 <FluentGrid Justify="JustifyContent.FlexStart" Spacing="4">
                                                    <FluentGridItem xs="2">Path</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.Path</code></FluentGridItem>

                                                    <FluentGridItem xs="2">Base Path</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.BasePath</code></FluentGridItem>

                                                    <FluentGridItem xs="2">Cardinality</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.FhirCardinalityString</code></FluentGridItem>

                                                    <FluentGridItem xs="2">Type</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.CollatedTypeLiteral</code></FluentGridItem>

                                                    <FluentGridItem xs="2">Short</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.Short</code></FluentGridItem>

                                                    <FluentGridItem xs="2">Definition</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.Definition</code></FluentGridItem>

                                                    <FluentGridItem xs="2">Binding Strength</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.ValueSetBindingStrength?.ToString()</code></FluentGridItem>

                                                    <FluentGridItem xs="2">Binding ValueSet</FluentGridItem>
                                                    <FluentGridItem xs="10"><code>@context.Element.BindingValueSet</code></FluentGridItem>
                                                </FluentGrid>
                                            </details> 
                                            <br/>

                                            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => AddElementRow(context.Element))" IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.AddSquare())">
                                                Add new mapping
                                            </FluentButton>

                                            <FluentDataGrid Items="context.ElementProjections" GridTemplateColumns="1fr" MultiLine="true">
                                                <TemplateColumn Sortable="false" Context="rowContext">
                                                    <details class="full-width" id="@($"details-ep-{rowContext.Row.RowNumber}")">
                                                        <summary>@($"Mapping Record {rowContext.Row.RowNumber} (DB: {rowContext.Comparison.Key})")</summary>
                                                        <FluentCard Class="full-width">
                                                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                                                            <div>
                                                                <FluentButton Id="@($"{rowContext.DelKey}-btn")"
                                                                                BackgroundColor="var(--error)" Color="#ffffff"
                                                                                OnClick="@(() => TogglePopover(rowContext.DelKey))"
                                                                                Title="Delete this row">
                                                                    Delete this mapping
                                                                </FluentButton>

                                                                <FluentPopover AnchorId="@($"{rowContext.DelKey}-btn")"
                                                                                VerticalPosition="VerticalPosition.Bottom"
                                                                                FixedPlacement="true"
                                                                               Open="@IsPopoverOpen(rowContext.DelKey)"
                                                                                OpenChanged="@((value) => SetPopoverState(rowContext.DelKey, value))">
                                                                    <Body>
                                                                        <FluentButton IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.CheckmarkCircleWarning())"
                                                                                        Appearance="Appearance.Outline"
                                                                                        OnClick="@(() => DeleteElementRow(rowContext.Row))">
                                                                            Confirm Delete
                                                                        </FluentButton>
                                                                    </Body>
                                                                </FluentPopover>
                                                            </div>

                                                            <FluentCheckbox Label="No Map" Value="@(rowContext.Comparison.NoMap ?? false)" CheckStateChanged="@(EventCallback.Factory.Create<bool?>(this, (value) => { UpdateNoMap(rowContext.Row, value); StateHasChanged(); }))" />

                                                            @if (rowContext.Comparison.NoMap != true)
                                                            {
                                                                string rMessage = rowContext.Comparison.Message ?? string.Empty;

                                                                <FluentLabel Typo="Typography.H6">Overall Relationship</FluentLabel>
                                                                <div>
                                                                    <FluentButton Id="@($"{rowContext.RelKey}-btn")"
                                                                                    Appearance="Appearance.Outline"
                                                                                  OnClick="@(() => TogglePopover(rowContext.RelKey))">
                                                                        @(rowContext.Comparison.Relationship?.ToString() ?? "-")
                                                                    </FluentButton>

                                                                    <FluentPopover AnchorId="@($"{rowContext.RelKey}-btn")"
                                                                                    VerticalPosition="VerticalPosition.Bottom"
                                                                                    FixedPlacement="true"
                                                                                       Open="@IsPopoverOpen(rowContext.RelKey)"
                                                                                       OpenChanged="@((value) => SetPopoverState(rowContext.RelKey, value))">
                                                                        <Header>
                                                                            <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                                                        </Header>
                                                                        <Body>
                                                                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                                                <FluentCombobox Items="@_relationships"
                                                                                                    Name="@($"{rowContext.RelKey}-combo")"
                                                                                                Width="950px"
                                                                                                    Height="700px"
