@page "/valuesets/{FhirPackageKey:int}/{ValueSetKey:int}"

@using Microsoft.Health.Fhir.Comparison.Models
@using xver_editor.Services
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Diagnostics.CodeAnalysis
@using System.Collections.Concurrent;
@using System.Text;

@inject IXverDbService DbService
@inject NavigationManager NavigationManager

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H4">Value Set details for @ValueSetName (DB Key: @ValueSetKey)</FluentLabel>

    @if (vsUiRec == null)
    {
        <FluentLabel Typo="Typography.Body">Loading...</FluentLabel>
    }
    else
    {
        <FluentTabs Width="100%" @ref="tabsComponent" ActiveTabId="@activeTabId">
            <FluentTab Id="overview" Label="Overview">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">Value Set Info</FluentLabel>
                    <FluentCard Width="100%">
                        <div style="padding: 16px;">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                                <FluentGrid Columns="2" ColumnSpan="2">
                                    <FluentGridItem>
                                        <FluentTextField Label="Name" Value="@vsUiRec.Vs.Name" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="ID" Value="@vsUiRec.Vs.Id" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="URL" Value="@vsUiRec.Vs.UnversionedUrl" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Version" Value="@vsUiRec.Vs.Version" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Description" Value="@vsUiRec.Vs.Description" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Publication Status" Value="@vsUiRec.Vs.Status.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Total Concepts" Value="@vsUiRec.Vs.ConceptCount.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Active Concrete Concepts" Value="@vsUiRec.Vs.ActiveConcreteConceptCount.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Can Expand" Value="@vsUiRec.Vs.CanExpand.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Has Escape-Value Code" Value="@vsUiRec.Vs.HasEscapeValveCode.ToString()" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Strongest Binding Core" Value="@(vsUiRec.Vs.StrongestBindingCore?.ToString() ?? "None")" ReadOnly="true" />
                                    </FluentGridItem>
                                    <FluentGridItem>
                                        <FluentTextField Label="Message" Value="@(vsUiRec.Vs.Message ?? "None")" ReadOnly="true" />
                                    </FluentGridItem>
                                </FluentGrid>
                            </FluentStack>
                        </div>
                    </FluentCard>

                    <FluentLabel Typo="Typography.H5">Referenced Systems</FluentLabel>
                    <FluentCard Width="100%">
                        <ul>
                            @foreach (string referencedSystem in (vsUiRec.Vs.ReferencedSystems ?? string.Empty).Split(", "))
                            {
                                <li><FluentTextField Value="@referencedSystem" ReadOnly="true" /></li>
                            }
                        </ul>
                    </FluentCard>

                    <FluentLabel Typo="Typography.H5">Bindings</FluentLabel>
                    <FluentCard Width="100%">
                        <div style="padding: 16px;">
                            <FluentDataGrid Items="@_boundElements" GridTemplateColumns="1fr 1.5fr 1fr 0.8fr 2fr" class="alternating-grid">
                                <PropertyColumn Title="Element" Property="@(e => e.Path)" Sortable="true" />
                                <PropertyColumn Title="Structure URL" Property="@(e => GetElementStructureUrl(e))" Sortable="true" />
                                <PropertyColumn Title="Binding" Property="@(e => e.BindingValueSet ?? string.Empty)" Sortable="true" />
                                <PropertyColumn Title="Strength" Property="@(e => e.ValueSetBindingStrength == null ? string.Empty : e.ValueSetBindingStrength.ToString())" Sortable="true" />
                                <PropertyColumn Title="Short Description" Property="@(e => e.Short ?? string.Empty)" Sortable="true" />
                            </FluentDataGrid>
                        </div>
                    </FluentCard>

                </FluentStack>
            </FluentTab>
            <FluentTab Id="mappingTable" Label="All-Version Mapping Table">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">All-Version Mapping Table</FluentLabel>
                    <FluentCard Width="100%">
                        <div class="grid-container" style="padding: 16px;">
                            @if (vsUiRec.Projection.Count == 0)
                            {
                                <p>No mapping data available for this ValueSet.</p>
                            }
                            else
                            {
                                <FluentDataGrid Items="@graphProjection" ResizableColumns="true" GridTemplateColumns="@GetMappingTableColumns()" MultiLine="true" class="alternating-grid">
                                    @for (int i = 0; i < _packages.Count; i++)
                                    {
                                        int packageIndex = i;
                                        <TemplateColumn Title="@_packages[packageIndex].ShortName">
                                            @{
                                                DbVsCell? cell = context[packageIndex];
                                            }
                                            @if (cell != null)
                                            {
                                                <div>
                                                    <div><strong>@cell.Vs.Name</strong></div>
                                                    <div>@cell.Vs.Id</div>
                                                    <div>
                                                        <FluentBadge Appearance="@(cell.Vs.Key == ValueSetKey ? Appearance.Outline : Appearance.Neutral)">
                                                            Concepts: @cell.Concepts.Count
                                                        </FluentBadge>
                                                    </div>
                                                </div>
                                            }
                                        </TemplateColumn>

                                        @if (i < _packages.Count - 1)
                                        {
                                            <TemplateColumn Title="Comparison" TGridItem="DbVsRow">
                                                @{
                                                    DbVsCell? cell = context[packageIndex];
                                                    int cellIndex = packageIndex;
                                                    DbValueSetComparison? toRight = context[packageIndex]?.RightComparison;
                                                    DbValueSetComparison? fromRight = packageIndex < _packages.Count - 1 ? context[packageIndex + 1]?.LeftComparison : null;
                                                }
                                                @if (cell != null)
                                                {
                                                    @if (toRight != null)
                                                    {
                                                        <FluentStack Orientation="Orientation.Vertical">
                                                            <FluentIcon Value="@(new Icons.Regular.Size24.ArrowRight())" />
                                                            <FluentBadge Appearance="@(toRight.LastReviewedOn == null ? Appearance.Outline : Appearance.Neutral)">
                                                                @(toRight.LastReviewedOn == null ? "Unreviewed" : "Reviewed")
                                                            </FluentBadge>
                                                            <FluentButton OnClick="@(() => SelectComparison(context, toRight, cellIndex, cellIndex + 1))"
                                                            Appearance="Appearance.Outline" IconEnd="@(new Icons.Regular.Size16.WindowDevEdit())">
                                                                Details
                                                            </FluentButton>
                                                            <FluentLabel Typo="Typography.Body">DB Key: @toRight.Key</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@toRight.Relationship</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(toRight.LastReviewedOn?.ToLongTimeString() ?? string.Empty)</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(toRight.LastReviewedBy ?? string.Empty)</FluentLabel>
                                                        </FluentStack>
                                                    }

                                                    @if (fromRight != null)
                                                    {
                                                        <FluentStack Orientation="Orientation.Vertical">
                                                            <FluentIcon Value="@(new Icons.Regular.Size24.ArrowLeft())" />
                                                            <FluentBadge Appearance="@(fromRight.LastReviewedOn == null ? Appearance.Outline : Appearance.Neutral)">
                                                                @(fromRight.LastReviewedOn == null ? "Unreviewed" : "Reviewed")
                                                            </FluentBadge>
                                                            <FluentButton OnClick="@(() => SelectComparison(context, fromRight, cellIndex + 1, cellIndex))"
                                                            Appearance="Appearance.Outline"
                                                            IconEnd="@(new Icons.Regular.Size16.WindowDevEdit())">
                                                                Details
                                                            </FluentButton>
                                                            <FluentLabel Typo="Typography.Body">DB Key: @fromRight.Key</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@fromRight.Relationship</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(fromRight.LastReviewedOn?.ToLongTimeString() ?? string.Empty)</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@(fromRight.LastReviewedBy ?? string.Empty)</FluentLabel>
                                                        </FluentStack>
                                                    }
                                                }
                                            </TemplateColumn>
                                        }
                                    }
                                </FluentDataGrid>
                            }
                        </div>
                    </FluentCard>
                </FluentStack>
            </FluentTab>
            <FluentTab Id="comparisonDetails" Label="Comparison Details">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H5">Comparison Details</FluentLabel>
                    @if ((selectedComparison == null) || (csCell == null) || (ctCell == null))
                    {
                        <FluentCard>
                            <FluentLabel Typo="Typography.Body">Please select a comparison to review.</FluentLabel>
                        </FluentCard>
                    }
                    else
                    {
                        <FluentCard Width="100%">
                            <FluentLabel Typo="Typography.H5">@selectedComparison.CompositeName</FluentLabel>
                            <br />

                            <FluentTextField Label="Comparison DB Key" Value="@selectedComparison.Key.ToString()" ReadOnly="true" />

                            <FluentDataGrid GenerateHeader="GenerateHeaderOption.None" TGridItem="string" DisplayMode="DataGridDisplayMode.Table" role="grid" class="full-width">
                                <FluentDataGridRow RowType="DataGridRowType.Header">
                                    <FluentDataGridCell GridColumn=1 CellType="DataGridCellType.ColumnHeader" Style="width: 20%;"></FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2 CellType="DataGridCellType.ColumnHeader" Style="width: 40%;">Source</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3 CellType="DataGridCellType.ColumnHeader" Style="width: 40%;">Target</FluentDataGridCell>
                                </FluentDataGridRow>
                                <FluentDataGridRow>
                                    <FluentDataGridCell GridColumn=1>Package</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2>@(csPackage?.NpmId ?? string.Empty)</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3>@(ctPackage?.NpmId ?? string.Empty)</FluentDataGridCell>
                                </FluentDataGridRow>
                                <FluentDataGridRow>
                                    <FluentDataGridCell GridColumn=1>Id</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2>@csCell.Vs.Id</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3>@ctCell.Vs.Id</FluentDataGridCell>
                                </FluentDataGridRow>
                                <FluentDataGridRow>
                                    <FluentDataGridCell GridColumn=1>Name</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2>@csCell.Vs.Name</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3>@ctCell.Vs.Name</FluentDataGridCell>
                                </FluentDataGridRow>
                                <FluentDataGridRow>
                                    <FluentDataGridCell GridColumn=1>URL</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2>@csCell.Vs.UnversionedUrl</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3>@ctCell.Vs.UnversionedUrl</FluentDataGridCell>
                                </FluentDataGridRow>
                                <FluentDataGridRow>
                                    <FluentDataGridCell GridColumn=1>Version</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2>@csCell.Vs.Version</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3>@ctCell.Vs.Version</FluentDataGridCell>
                                </FluentDataGridRow>
                                <FluentDataGridRow>
                                    <FluentDataGridCell GridColumn=1>Concept Count</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2>@csCell.Vs.ConceptCount</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3>@ctCell.Vs.ConceptCount</FluentDataGridCell>
                                </FluentDataGridRow>
                                <FluentDataGridRow>
                                    <FluentDataGridCell GridColumn=1>Active and Concrete</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=2>@csCell.Vs.ActiveConcreteConceptCount</FluentDataGridCell>
                                    <FluentDataGridCell GridColumn=3>@ctCell.Vs.ActiveConcreteConceptCount</FluentDataGridCell>
                                </FluentDataGridRow>
                            </FluentDataGrid>
                        </FluentCard>

                        <FluentCard Width="100%">
                            <FluentLabel Typo="Typography.H5">Concept Mapping</FluentLabel>
                            <br />
                            <div class="grid-container">
                                <FluentDataGrid Items="conceptProjection" ShowHover="true" class="mapping-grid" RowSize="@DataGridRowSize.Large" GridTemplateColumns="2fr 0.5fr 1fr 2fr" >
                                    <TemplateColumn Title="Source" Sortable="true" Tooltip="true" TooltipText="@(e => e[sourceColIndex]!.Concept.Display ?? e[sourceColIndex]!.Concept.FhirKey)">
                                        <FluentLabel Typo="Typography.Body">@context[sourceColIndex]!.Concept.UiDisplay</FluentLabel>
                                    </TemplateColumn>

                                    <TemplateColumn Title="NoMap" Sortable="false">
                                        @if (compareRight)
                                        {
                                            <FluentCheckbox Value="@(context[sourceColIndex]!.RightComparison?.NoMap ?? true)" />
                                        }
                                        else
                                        {
                                            <FluentCheckbox Value="@(context[sourceColIndex]!.LeftComparison?.NoMap ?? true)" />
                                        }
                                    </TemplateColumn>

                                    <TemplateColumn Title="Relationship" Sortable="false">
                                        @if (compareRight)
                                        {
                                            var rowKey = $"right-{context[sourceColIndex]!.Concept.Key}";
                                            var relationship = context[sourceColIndex]!.RightComparison?.Relationship ?? Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.NotRelatedTo;
                                            <div>
                                                <FluentButton Id="@($"rel-btn-{rowKey}")"
                                                              Appearance="Appearance.Outline"
                                                              OnClick="@(() => TogglePopover(rowKey))">
                                                    @relationship.ToString()
                                                </FluentButton>

                                                <FluentPopover AnchorId="@($"rel-btn-{rowKey}")"
                                                        VerticalPosition="VerticalPosition.Bottom"
                                                        Open="@IsPopoverOpen(rowKey)"
                                                        OpenChanged="@((value) => SetPopoverState(rowKey, value))">
                                                    <Header>
                                                        <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                                    </Header>
                                                    <Body>
                                                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                            <FluentRadioGroup Value="@relationship"
                                                                    Name="@($"rel-group-{rowKey}")"
                                                                    Orientation="Orientation.Vertical"
                                                                    ValueChanged="@(EventCallback.Factory.Create<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship>(this, (value) => UpdateRelationship(context, value, true)))">
                                                                @foreach (var rel in _relationships)
                                                                {
                                                                    <FluentRadio Value="@rel">@rel.ToString()</FluentRadio>
                                                                }
                                                            </FluentRadioGroup>
                                                        </FluentStack>
                                                    </Body>
                                                </FluentPopover>
                                            </div>
                                        }
                                        else
                                        {
                                            var rowKey = $"left-{context[sourceColIndex]!.Concept.Key}";
                                            var relationship = context[sourceColIndex]!.LeftComparison?.Relationship ?? Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.NotRelatedTo;
                                            <div>
                                                <FluentButton Id="@($"rel-btn-{rowKey}")"
                                                              Appearance="Appearance.Outline"
                                                              OnClick="@(() => TogglePopover(rowKey))">
                                                    @relationship.ToString()
                                                </FluentButton>

                                                <FluentPopover AnchorId="@($"rel-btn-{rowKey}")"
                                                               VerticalPosition="VerticalPosition.Bottom"
                                                               Open="@IsPopoverOpen(rowKey)"
                                                               OpenChanged="@((value) => SetPopoverState(rowKey, value))">
                                                    <Header>
                                                        <FluentLabel Typo="Typography.Body">Select Relationship</FluentLabel>
                                                    </Header>
                                                    <Body>
                                                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                            <FluentRadioGroup Value="@relationship"
                                                            Name="@($"rel-group-{rowKey}")"
                                                            Orientation="Orientation.Vertical"
                                                            ValueChanged="@(EventCallback.Factory.Create<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship>(this, (value) => UpdateRelationship(context, value, false)))">
                                                                @foreach (var rel in _relationships)
                                                                {
                                                                    <FluentRadio Value="@rel">@rel.ToString()</FluentRadio>
                                                                }
                                                            </FluentRadioGroup>
                                                        </FluentStack>
                                                    </Body>
                                                </FluentPopover>
                                            </div>
                                        }
                                    </TemplateColumn>

                                    <TemplateColumn Title="Target" Sortable="true" Tooltip="true" TooltipText="@(e => e[targetColIndex]!.Concept.Display ?? e[targetColIndex]!.Concept.FhirKey)">
                                        @{
                                            var rowKey = $"target-{context[sourceColIndex]!.Concept.Key}";
                                            var concept = context[targetColIndex]!.Concept;
                                            <div>
                                                <FluentButton Id="@($"target-btn-{rowKey}")"
                                                        Appearance="Appearance.Outline"
                                                        OnClick="@(() => TogglePopover(rowKey))">
                                                    @concept.UiDisplay
                                                </FluentButton>

                                                <FluentPopover AnchorId="@($"target-btn-{rowKey}")"
                                                               VerticalPosition="VerticalPosition.Bottom"
                                                               Open="@IsPopoverOpen(rowKey)"
                                                               OpenChanged="@((value) => SetPopoverState(rowKey, value))"
                                                               class="concept-popover-container">
                                                    <Header>
                                                        <FluentLabel Typo="Typography.Body">Select Target Concept</FluentLabel>
                                                    </Header>
                                                    <Body>
                                                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                            <FluentRadioGroup
                                                                    Value="@concept.Key"
                                                                    Name="@($"target-group-{rowKey}")"
                                                                    Orientation="Orientation.Vertical"
                                                                    ValueChanged="@(EventCallback.Factory.Create<int>(this, (value) => UpdateTargetConcept(context, value)))">
                                                                @foreach (var cpt in ctConcepts)
                                                                {
                                                                    <FluentRadio Value="@cpt.Key">@cpt.UiDisplayLong</FluentRadio>
                                                                }
                                                            </FluentRadioGroup>
                                                        </FluentStack>
                                                    </Body>
                                                </FluentPopover>
                                            </div>
                                        }
                                    </TemplateColumn>


                                </FluentDataGrid>
                            </div>
                        </FluentCard>
                    }
                </FluentStack>
            </FluentTab>

        </FluentTabs>
    }
</FluentStack>

@code {
    [Parameter]
    public int FhirPackageKey { get; set; }

    [Parameter]
    public int ValueSetKey { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "packageShort")]
    public string PackageShortName { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "vsName")]
    public string ValueSetName { get; set; } = string.Empty;

    [CascadingParameter]
    public INavTracker? NavTracker { get; set; } = null;

    private NavPageInfoRec[] _navPages => new NavPageInfoRec[]
    {
        new() { Display = $"{PackageShortName}: Value Sets", Link = $"/valuesets/{FhirPackageKey}?packageShort={PackageShortName}" },
        new() { Display = ValueSetName, Link = $"/valuesets/{FhirPackageKey}/{ValueSetKey}/?packageShort={PackageShortName}&vsName={ValueSetName}" },
    };

    private FluentTabs? tabsComponent;
    private string activeTabId = "overview";

    private VsRecForUi? vsUiRec = null;
    private List<DbFhirPackage> _packages = [];
    private IQueryable<DbElement> _boundElements = Enumerable.Empty<DbElement>().AsQueryable();
    private Dictionary<int, DbStructureDefinition> _boundStructures = [];
    private IQueryable<DbVsRow>? graphProjection = null;

    private Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship[] _relationships = [
        Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.Equivalent,
        Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.SourceIsNarrowerThanTarget,
        Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.SourceIsBroaderThanTarget,
        Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.RelatedTo,
        Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.NotRelatedTo,
    ];

    private DbVsRow comparisonFilteredVsRow = new(0, 0);
    private DbValueSetComparison? selectedComparison = null;
    private int sourceColIndex = 0;
    private int targetColIndex = 0;
    private DbVsCell? csCell = null;
    private DbVsCell? ctCell = null;
    private DbFhirPackage? csPackage = null;
    private DbFhirPackage? ctPackage = null;
    private IQueryable<DbVsConceptRow> conceptProjection = Enumerable.Empty<DbVsConceptRow>().AsQueryable();
    private bool compareRight = true;
    private List<DbValueSetConcept> ctConcepts = [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        NavTracker?.NotifyNav(_navPages);
        LoadValueSet();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        LoadValueSet();
    }

    private string GetElementStructureUrl(DbElement e) => _boundStructures.TryGetValue(e.StructureKey, out DbStructureDefinition? structure)
            ? structure.UnversionedUrl
            : string.Empty;

    private string GetMappingTableColumns()
    {
        // Calculate the columns - we need one for each package plus comparison columns between them
        int packageCount = _packages.Count;
        int comparisonCount = packageCount - 1; // One less comparison column than packages

        // Build column template: package (1fr) + comparison (0.8fr) + package (1fr) + ...
        System.Text.StringBuilder sb = new();
        for (int i = 0; i < packageCount; i++)
        {
            sb.Append("1fr"); // Package column

            if (i < comparisonCount)
            {
                sb.Append(" 0.8fr"); // Comparison column
            }
        }

        return sb.ToString();
    }


    // Track open state of popovers
    private Dictionary<string, bool> _popoverStates = new();

    private bool IsPopoverOpen(string key)
    {
        return _popoverStates.TryGetValue(key, out bool value) && value;
    }

    private void SetPopoverState(string key, bool value)
    {
        _popoverStates[key] = value;
        StateHasChanged();
    }

    private void TogglePopover(string key)
    {
        if (!_popoverStates.TryGetValue(key, out bool currentValue))
        {
            currentValue = false;
        }
        _popoverStates[key] = !currentValue;
        StateHasChanged();
    }

    private void UpdateRelationship(DbVsConceptRow conceptRow, object? newRelationship, bool isRightComparison)
    {
        if (newRelationship is Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship relationship &&
            conceptRow != null &&
            conceptRow[sourceColIndex] != null)
        {
            if (isRightComparison && conceptRow[sourceColIndex]!.RightComparison != null)
            {
                conceptRow[sourceColIndex]!.RightComparison!.Relationship = relationship;
            }
            else if (!isRightComparison && conceptRow[sourceColIndex]!.LeftComparison != null)
            {
                conceptRow[sourceColIndex]!.LeftComparison!.Relationship = relationship;
            }

            // Close the popover after selection
            string key = isRightComparison
                ? $"right-{conceptRow[sourceColIndex]!.Concept.Key}"
                : $"left-{conceptRow[sourceColIndex]!.Concept.Key}";
            SetPopoverState(key, false);
        }
    }

    private void UpdateTargetConcept(DbVsConceptRow conceptRow, int conceptKey)
    {
        if ((conceptRow != null) &&
            (conceptRow[targetColIndex] != null) &&
            (ctConcepts.Find(c => c.Key == conceptKey) is DbValueSetConcept newConcept))
        {
            // Update the concept in the target cell
            conceptRow[targetColIndex]!.Concept = newConcept;

            // Close the popover after selection
            string key = $"target-{conceptRow[sourceColIndex]!.Concept.Key}";
            SetPopoverState(key, false);
            StateHasChanged();
        }
    }

    private void SelectComparison(
        DbVsRow valueSetRow,
        DbValueSetComparison comparison,
        int sourceCellIndex,
        int targetCellIndex)
    {
        comparisonFilteredVsRow = valueSetRow.ShallowCopy(sourceCellIndex, targetCellIndex);

        compareRight = sourceCellIndex < targetCellIndex;
        selectedComparison = comparison;

        sourceColIndex = sourceCellIndex;
        csCell = valueSetRow[sourceCellIndex];
        csPackage = _packages[sourceCellIndex];

        targetColIndex = targetCellIndex;
        ctCell = valueSetRow[targetCellIndex];
        ctPackage = _packages[targetCellIndex];

        ctConcepts = DbValueSetConcept.SelectList(
            DbService.DB,
            FhirPackageKey: ctCell!.Vs.FhirPackageKey,
            ValueSetKey: ctCell!.Vs.Key,
            orderByProperties: [nameof(DbValueSetConcept.System), nameof(DbValueSetConcept.Code)]);

        // grab the current projection
        List<DbVsConceptRow> cp = vsUiRec!.Graph.ProjectConcepts(comparisonFilteredVsRow, sourceCellIndex);

        // make sure we have cells for targets
        foreach (DbVsConceptRow conceptRow in cp)
        {
            if (conceptRow[targetColIndex] == null)
            {
                conceptRow[targetColIndex] = new()
                {
                    VsCell = valueSetRow[targetCellIndex]!,
                    Concept = DbValueSetConcept.EmptyCopy,
                };

                if (compareRight)
                {
                    conceptRow[targetColIndex]!.LeftCell = conceptRow[sourceColIndex];
                    conceptRow[targetColIndex]!.LeftComparison = DbValueSetConceptComparison.EmptyCopy;
                    conceptRow[targetColIndex]!.LeftConcept = conceptRow[sourceColIndex]!.Concept;
                }
                else
                {
                    conceptRow[targetColIndex]!.RightCell = conceptRow[sourceColIndex];
                    conceptRow[targetColIndex]!.RightComparison = DbValueSetConceptComparison.EmptyCopy;
                    conceptRow[targetColIndex]!.RightConcept = conceptRow[sourceColIndex]!.Concept;
                }
            }
        }

        conceptProjection = cp.AsQueryable();

        activeTabId = "comparisonDetails";
        StateHasChanged();
    }

    private void LoadPackages()
    {
        try
        {
            _packages = DbFhirPackage.SelectList(
                DbService.DB,
                orderByProperties: [nameof(DbFhirPackage.ShortName)]);
        }
        catch (Exception)
        {
            _packages = [];
        }
    }

    private void LoadValueSet()
    {
        try
        {
            if (vsUiRec != null)
            {
                return;
            }

            if (_packages.Count == 0)
            {
                LoadPackages();
            }

            // Query ValueSets for the specified FhirPackageKey
            DbValueSet? vs = DbValueSet.SelectSingle(
                DbService.DB,
                FhirPackageKey: FhirPackageKey,
                Key: ValueSetKey);

            if (vs == null)
            {
                return;
            }

            _boundElements = DbElement.SelectList(
                DbService.DB,
                BindingValueSetKey: ValueSetKey,
                orderByProperties: [nameof(DbElement.Key)])
                .AsQueryable();

            foreach (DbElement element in _boundElements)
            {
                if (_boundStructures.ContainsKey(element.StructureKey))
                {
                    continue;
                }

                DbStructureDefinition? structure = DbStructureDefinition.SelectSingle(
                    DbService.DB,
                    Key: element.StructureKey);
                if (structure != null)
                {
                    _boundStructures[element.StructureKey] = structure;
                }
            }

            vsUiRec = new(DbService.DB, vs, _packages);
            graphProjection = vsUiRec.Projection.AsQueryable();
        }
        catch (Exception)
        {
        }
    }
}
