    private void BuildConceptTrees(DbGraphVs.DbVsConceptRow focusRow, int sourceCol, int targetCol)
    {
        mappingLeftSelected = null;
        mappingRightSelected = null;

        if ((_selectedVsRow == null) ||
            (_selectedVsRow[sourceCol] == null) ||
            (_selectedVsRow[targetCol] == null))
        {
            ClearConceptSelection();

            return;
        }

        bool isLeftToRight = sourceCol < targetCol;

        mappingLeftColId = isLeftToRight ? sourceCol : targetCol;
        mappingRightColId = isLeftToRight ? targetCol : sourceCol;

        mappingLeftSd = _selectedVsRow[mappingLeftColId];
        mapLRComparison = isLeftToRight ? focusRow[mappingLeftColId]?.RightComparison : focusRow[mappingRightColId]?.LeftComparison;
        mappingRightSd = _selectedVsRow[mappingRightColId];
        mapRLComparison = isLeftToRight ? focusRow[mappingRightColId]?.LeftComparison : focusRow[mappingLeftColId]?.RightComparison;

        (mappingLeftItems, mappingLeftSelected) = BuildTreeItemsForVs(mappingLeftSd!, focusRow[mappingLeftColId]?.Concept, mappingLeftColId);
        (mappingRightItems, mappingRightSelected) = BuildTreeItemsForVs(mappingRightSd!, focusRow[mappingRightColId]?.Concept, mappingRightColId);

        mapLRRelationship = mapLRComparison?.Relationship == null
            ? null
            : _relationships.FirstOrDefault(ro => ro.Value == mapLRComparison.Relationship);
        mapLRMessage = mapLRComparison?.Message;

        mapRLRelationship = mapRLComparison?.Relationship == null
            ? null
            : _relationships.FirstOrDefault(ro => ro.Value == mapRLComparison.Relationship);
        mapRLMessage = mapRLComparison?.Message;
    }

    private Icon IconFolderCollapsed = new Icons.Regular.Size20.Folder();
    private Icon IconFolderExpanded = new Icons.Regular.Size20.FolderOpen();
    private Icon IconElement = new Icons.Regular.Size20.CodeBlock();
    private Icon IconNoMap = new Icons.Regular.Size20.Prohibited();

    private (List<ITreeViewItem> items, ITreeViewItem? selectedItem) BuildTreeItemsForVs(DbGraphVs.DbVsCell vsCell, DbValueSetConcept? selectedConcept, int packageIndex)
    {
        if (vsCell.Concepts.Count == 0)
        {
            return ([], null);
        }

        ILookup<int, DbValueSetConcept> elementsByKey = vsCell.Concepts.ToLookup(e => e.Key);
        ILookup<string, DbValueSetConcept> conceptsBySystem = vsCell.Concepts.ToLookup(e => e.System);
        Dictionary<string, TreeViewItem> itemsByFhirKey = [];

        ITreeViewItem? selectedItem = null;
        List<TreeViewItem> rootItems = [];

        // add a 'remove mapping' root
        rootItems.Add(new TreeViewItem
            {
                Id = string.Empty,
                Text = "No Map",
                Items = new List<TreeViewItem>(),
                Expanded = true,
                IconCollapsed = IconNoMap,
                IconExpanded = IconNoMap,
            });

        if (selectedConcept == null)
        {
            selectedItem = rootItems[0];
        }

        foreach (DbValueSetConcept concept in vsCell.Concepts.OrderBy(c => c.Code))
        {
            if (!itemsByFhirKey.TryGetValue(concept.System, out TreeViewItem? systemItem))
            {
                systemItem = new TreeViewItem
                    {
                        Id = concept.System,
                        Text = $"System: {concept.System}",
                        Items = new List<TreeViewItem>(),
                        Expanded = true,
                        IconCollapsed = IconFolderCollapsed,
                        IconExpanded = IconFolderExpanded,
                    };
                itemsByFhirKey[concept.System] = systemItem;
                rootItems.Add(systemItem);
            }

            TreeViewItem currentItem = new TreeViewItem
                {
                    Id = concept.FhirKey,
                    Text = concept.UiDisplayLong,
                    Items = new List<TreeViewItem>(),
                    Expanded = true,
                    IconCollapsed = IconElement,
                    IconExpanded = IconElement,
                };

            itemsByFhirKey[concept.FhirKey] = currentItem;
            if ((selectedConcept != null) &&
                (selectedConcept.Key == concept.Key))
            {
                selectedItem = currentItem;
            }

            if (systemItem.Items is null)
            {
                systemItem.Items = new List<TreeViewItem>
                {
                    currentItem,
                };
            }
            else if (systemItem.Items is List<TreeViewItem> childItems)
            {
                childItems.Add(currentItem);
            }
            else
            {
                currentItem.Items = [.. systemItem.Items, currentItem];
            }
        }

        return (rootItems.ToList<ITreeViewItem>(), selectedItem);
    }

    private void HandleLeftMappingSelectionChanged(FluentTreeItem item)
    {
        HandleMappingElementSelectionChanged(item, isLeft: true);
    }

    private void HandleRightMappingSelectionChanged(FluentTreeItem item)
    {
        HandleMappingElementSelectionChanged(item, isLeft: false);
    }

    private void HandleMappingElementSelectionChanged(FluentTreeItem item, bool isLeft)
    {
        if ((item == null) || (item.Id == null))
        {
            return;
        }

        string fhirKey = item.Id;

        foreach (ITreeViewItem tvItem in isLeft ? mappingLeftItems : mappingRightItems)
        {
            ITreeViewItem? foundItem = findItem(tvItem, fhirKey);
            if (foundItem != null)
            {
                if (isLeft)
                {
                    mappingLeftSelected = foundItem;
                }
                else
                {
                    mappingRightSelected = foundItem;
                }
                break;
            }
        }

        StateHasChanged();

        return;

        ITreeViewItem? findItem(ITreeViewItem currentItem, string fhirKey)
        {
            if (currentItem.Id == fhirKey)
            {
                return currentItem;
            }

            if ((!fhirKey.StartsWith(currentItem.Id)) ||
                (currentItem.Items == null))
            {
                return null;
            }

            foreach (ITreeViewItem childItem in currentItem.Items)
            {
                ITreeViewItem? foundItem = findItem(childItem, fhirKey);
                if (foundItem != null)
                {
                    return foundItem;
                }
            }

            return null;
        }
    }

