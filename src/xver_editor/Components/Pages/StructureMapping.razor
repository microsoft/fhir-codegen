    private async Task DeleteElementMapping()
    {
        if ((mapLRComparison == null) &&
            (mapRLComparison == null))
        {
            ClearElementSelection();
        }

        // need to hide the dialog because these all use the same dialog service
        visibleDialog = VisibleDialogCodes.Confirmation;

        IDialogReference dialog = await DialogService.ShowConfirmationAsync(
            $"This will delete the comparison records between:<br/>" +
                $"<code>{mappingLeftSelected?.Text}</code><br/>" +
                $" - and -<br/>" +
                $"<code>{mappingRightSelected?.Text}</code>",
            "Confirm Delete",
            "Cancel",
            "Element Mapping");
        DialogResult result = await dialog.Result;

        if (result.Cancelled == true)
        {
            // go back to mapping window
            visibleDialog = VisibleDialogCodes.ElementMapping;
            return;
        }

        try
        {
            mapLRComparison?.Delete(Xver.ComparisonDb.DbConnection);
        }
        catch { }

        try
        {
            mapRLComparison?.Delete(Xver.ComparisonDb.DbConnection);
        }
        catch { }

        // force a reload of the content to get updated mappings
        if (_selectedSdRow != null)
        {
            LoadMappingRow(_selectedSdRow);
        }

        ClearElementSelection();
    }

    private void UpdateElementMapping()
    {
        if ((_focusElementRow == null) ||
            (_selectedSdRow == null) ||
            (_selectedSdRow[mappingLeftColId] == null) ||
            (_selectedSdRow[mappingRightColId] == null))
        {
            ClearElementSelection();
            return;
        }

        // resolve the selected tree items
        DbElement? leftTreeElement = (mappingLeftSelected == null) || string.IsNullOrEmpty(mappingLeftSelected.Id)
            ? null
            : _selectedSdRow[mappingLeftColId]!.Elements.FirstOrDefault(e => e.Id == mappingLeftSelected.Id);

        DbElement? rightTreeElement = (mappingRightSelected == null) || string.IsNullOrEmpty(mappingRightSelected.Id)
            ? null
            : _selectedSdRow[mappingRightColId]!.Elements.FirstOrDefault(e => e.Id == mappingRightSelected.Id);

        bool isLeftToRight = mappingLeftColId < mappingRightColId;

        bool addingLR = false;
        bool deletingLR = false;
        bool addingRL = false;
        bool deletingRL = false;

        // check if there is no left element selected
        if (leftTreeElement == null)
        {
            // check if we need to delete the Left to Right comparison record
            deletingLR = mapLRComparison != null;
        }
        else
        {
            // check if we need to create the Left to Right comparison record
            if (mapLRComparison == null)
            {
                mapLRComparison = DbElementComparison.EmptyCopy;
                mapLRComparison.Key = Xver.ComparisonDb.GetElementComparisonKey();
                addingLR = true;
            }

            mapLRComparison.PackageComparisonKey = _selectedSdRow[mappingLeftColId]!.RightComparison!.PackageComparisonKey;
            mapLRComparison.StructureComparisonKey = _selectedSdRow[mappingLeftColId]!.RightComparison!.Key;
            mapLRComparison.SourceFhirPackageKey = _selectedSdRow[mappingLeftColId]!.Sd.FhirPackageKey;
            mapLRComparison.SourceStructureKey = _selectedSdRow[mappingLeftColId]!.Sd.Key;
            mapLRComparison.SourceStructureUrl = _selectedSdRow[mappingLeftColId]!.Sd.UnversionedUrl;
            mapLRComparison.TargetFhirPackageKey = _selectedSdRow[mappingRightColId]!.Sd.FhirPackageKey;
            mapLRComparison.TargetStructureKey = _selectedSdRow[mappingRightColId]!.Sd.Key;
            mapLRComparison.TargetStructureUrl = _selectedSdRow[mappingRightColId]!.Sd.UnversionedUrl;
            mapLRComparison.SourceElementKey = leftTreeElement.Key;
            mapLRComparison.SourceElementToken = leftTreeElement.Id;
            mapLRComparison.TargetElementKey = rightTreeElement?.Key;
            mapLRComparison.TargetElementToken = rightTreeElement?.Id;
            mapLRComparison.Relationship = deletingRL ? null : mapLRRelationship?.Value;
            mapLRComparison.ConceptDomainRelationship = deletingRL ? null : mapLRConceptRelationship?.Value;
            // mapLRComparison.ValueDomainRelationship = null;
            mapLRComparison.TechnicalMessage = mapLRMessage;
            mapLRComparison.UserMessage = mapLRUserMessage;
            mapLRComparison.NoMap = deletingRL ? true : null;
            mapLRComparison.IsGenerated = false;

            // if the comparison has changed, we cannot rely on the existing comparison information
            if (mapLRComparison.Key != _focusElementRow[mappingLeftColId]?.RightComparison?.Key)
            {
                mapLRComparison.IsIdentical = null;
                mapLRComparison.ElementTypeComparisonKey = null;
                mapLRComparison.BoundValueSetComparisonKey = null;
            }
        }

        // check if there is no right element selected
        if (rightTreeElement == null)
        {
            // check if we need to delete the Right to Left comparison record
            deletingRL = mapRLComparison != null;
        }
        else
        { 
            if (mapRLComparison == null)
            {
                mapRLComparison = DbElementComparison.EmptyCopy;
                mapRLComparison.Key = Xver.ComparisonDb.GetElementComparisonKey();
                addingRL = true;
            }

            mapRLComparison.PackageComparisonKey = _selectedSdRow[mappingRightColId]!.LeftComparison!.PackageComparisonKey;
            mapRLComparison.StructureComparisonKey = _selectedSdRow[mappingRightColId]!.LeftComparison!.Key;
            mapRLComparison.SourceFhirPackageKey = _selectedSdRow[mappingRightColId]!.Sd.FhirPackageKey;
            mapRLComparison.SourceStructureKey = _selectedSdRow[mappingRightColId]!.Sd.Key;
            mapRLComparison.SourceStructureUrl = _selectedSdRow[mappingRightColId]!.Sd.UnversionedUrl;
            mapRLComparison.TargetFhirPackageKey = _selectedSdRow[mappingLeftColId]!.Sd.FhirPackageKey;
            mapRLComparison.TargetStructureKey = _selectedSdRow[mappingLeftColId]!.Sd.Key;
            mapRLComparison.TargetStructureUrl = _selectedSdRow[mappingLeftColId]!.Sd.UnversionedUrl;
            mapRLComparison.SourceElementKey = rightTreeElement.Key;
            mapRLComparison.SourceElementToken = rightTreeElement.Id;
            mapRLComparison.TargetElementKey = leftTreeElement?.Key;
            mapRLComparison.TargetElementToken = leftTreeElement?.Id;
            mapRLComparison.Relationship = deletingLR ? null : mapRLRelationship?.Value;
            mapRLComparison.ConceptDomainRelationship = deletingLR ? null : mapRLConceptRelationship?.Value;
            // mapRLComparison.ValueDomainRelationship = null;
            mapRLComparison.TechnicalMessage = mapRLMessage;
            mapRLComparison.UserMessage = mapRLUserMessage;
            mapRLComparison.NoMap = deletingLR ? true : null;
            mapRLComparison.IsGenerated = false;

            // if the comparison has changed, we cannot rely on the existing comparison information
            if (mapRLComparison.Key != _focusElementRow[mappingRightColId]?.LeftComparison?.Key)
            {
                mapRLComparison.IsIdentical = null;
                mapRLComparison.ElementTypeComparisonKey = null;
                mapRLComparison.BoundValueSetComparisonKey = null;
            }
        }

        // fix inverse keys
        if (mapLRComparison != null)
        {
            mapLRComparison.InverseComparisonKey = mapRLComparison?.Key;
        }

        if (mapRLComparison != null)
        {
            mapRLComparison.InverseComparisonKey = mapLRComparison?.Key;
        }

        // update the database
        if (deletingLR)
        {
            mapLRComparison?.Delete(Xver.ComparisonDb.DbConnection);
        }
        else if (addingLR)
        {
            mapLRComparison!.Insert(Xver.ComparisonDb.DbConnection);
        }
        else
        {
            mapLRComparison!.Update(Xver.ComparisonDb.DbConnection);
        }

        if (deletingRL)
        {
            mapRLComparison?.Delete(Xver.ComparisonDb.DbConnection);
        }
        else if (addingRL)
        {
            mapRLComparison!.Insert(Xver.ComparisonDb.DbConnection);
        }
        else
        {
            mapRLComparison!.Update(Xver.ComparisonDb.DbConnection);
        }

        // force a reload of the content to get updating mappings
        LoadMappingRow(_selectedSdRow);

        // go back to the main UI
        ClearElementSelection();
    }

    private async Task MarkReviewed()
    {
        if (_selectedSdRow == null)
        {
            return;
        }

        string reviewer = ServerConfig.UserName;

        Xver.Comparer.MarkSdMappingsReviewed(
            _selectedSdRow,
            initialElementProjection,
            reviewer);

        IDialogReference dialog = await DialogService.ShowSuccessAsync(
            "All mappings for the currently selected mapping group have been marked as reviewed.");
        DialogResult result = await dialog.Result;
        _ = dialog.CloseAsync();

        // force reload of the mapping table
        LoadStructure(true);

        // move the UI back to default
        visibleDialog = VisibleDialogCodes.None;
        StateHasChanged();

        return;
    }

