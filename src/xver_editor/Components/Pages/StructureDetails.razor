<FluentDialog @ref="structureSelectionDialog"
Modal="true"
Hidden="@dialogHidden"
Class="sd-dialog-container">
    <FluentDialogHeader Visible="true">@structureDialogTitle</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentTextField @bind-Value="structureSearchText"
            Placeholder="Type to filter structures..."
            @oninput="FilterStructures" />

            <div style="height: 400px; overflow-y: auto; margin-bottom: 16px;">
                <FluentDataGrid Items="@filteredStructures"
                ResizableColumns="true"
                GridTemplateColumns="1fr 2fr 1fr"
                TGridItem="DbStructureDefinition">
                    <SelectColumn TGridItem="DbStructureDefinition"
                    SelectMode="DataGridSelectMode.Single"
                    SelectFromEntireRow="true"
                    @bind-SelectedItems="@selectedStructures" />
                    <PropertyColumn Title="Name" Property="@(vs => vs.Name)" Sortable="true" />
                    <PropertyColumn Title="URL" Property="@(vs => vs.UnversionedUrl)" Sortable="true" />
                    <PropertyColumn Title="Version" Property="@(vs => vs.Version)" Sortable="true" />
                </FluentDataGrid>
            </div>

            @if (selectedStructure != null)
            {
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                        <FluentLabel Typo="Typography.H6">Selected Structure</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Name: @selectedStructure.Name</FluentLabel>
                        <FluentLabel Typo="Typography.Body">URL: @selectedStructure.UnversionedUrl</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Snapshot: @selectedStructure.SnapshotCount</FluentLabel>
                        <FluentLabel Typo="Typography.Body">Differential: @selectedStructure.DifferentialCount</FluentLabel>
                    </FluentStack>
                </FluentCard>
            }

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.End">
                <FluentButton Appearance="Appearance.Outline" OnClick="CancelStructureSelection">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="SelectStructure" Disabled="@(selectedStructure == null)">Select</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentDialogBody>

</FluentDialog>


@code {
    [Parameter]
    public int FhirPackageKey { get; set; }

    [Parameter]
    public int StructureKey { get; set; }

    private int _loadedStructureKey = -1;

    [Parameter]
    [SupplyParameterFromQuery(Name = "packageShort")]
    public string PackageShortName { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "vsName")]
    public string StructureName { get; set; } = string.Empty;

    [CascadingParameter]
    public INavTracker? NavTracker { get; set; } = null;

    private NavPageInfoRec[] _navPages => new NavPageInfoRec[]
    {
        new() { Display = $"{PackageShortName}: Structures", Link = $"/structures/{FhirPackageKey}?packageShort={PackageShortName}" },
        new() { Display = StructureName, Link = $"/structures/{FhirPackageKey}/{StructureKey}/?packageShort={PackageShortName}&vsName={StructureName}" },
    };

    private FluentTabs? tabsComponent;
    private string activeTabId = "overview";

    private SdRecForUi? sdUiRec = null;
    private List<DbFhirPackage> _packages = [];
    private IQueryable<DbSdRow>? graphProjection = null;

    private Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?>[] _relationships = [
        new() { Text = "- No Relationship -", Value = null },
        new() { Text = "Equivalent", Value = Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.Equivalent },
        new() { Text = "Source is Narrower", Value = Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.SourceIsNarrowerThanTarget },
        new() { Text = "Source is Broader", Value = Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.SourceIsBroaderThanTarget },
        new() { Text = "Related To", Value = Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.RelatedTo },
        new() { Text = "NOT related To", Value = Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship.NotRelatedTo },
    ];

    private bool ApplyToInverse { get; set; } = true;

    private DbSdRow comparisonFilteredSdRow = new(0, 0, 0);
    private DbStructureComparison? selectedComparison = null;
    private Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship? initialSdRelationship = null;
    private Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship? manualSdRelationship = null;
    private int sourceColIndex = 0;
    private int targetColIndex = 0;
    private DbSdCell? csCell = null;
    private DbSdCell? ctCell = null;
    private DbFhirPackage? csPackage = null;
    private DbFhirPackage? ctPackage = null;
    private List<DbElementRow> originalProjection = [];
    private List<DbElementRow> elementProjection = [];
    private bool compareRight = true;
    private List<Option<DbElement>> _sourceElements = [];
    private List<Option<DbElement>> _targetElements = [];
    private IQueryable<ElementRecForUi> _mappings = Enumerable.Empty<ElementRecForUi>().AsQueryable();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        NavTracker?.NotifyNav(_navPages);
        LoadStructure();
    }

    protected override void OnParametersSet()
    {
        if (StructureKey != _loadedStructureKey)
        {
            NavTracker?.NotifyNav(_navPages);
        }

        base.OnParametersSet();
        LoadStructure();
    }

    private string GetMappingTableColumns()
    {
        // Calculate the columns - we need one for each package plus comparison columns between them
        int packageCount = _packages.Count;
        int comparisonCount = packageCount - 1; // One less comparison column than packages

        // Build column template: package (1fr) + comparison (0.8fr) + package (1fr) + ...
        System.Text.StringBuilder sb = new();
        for (int i = 0; i < packageCount; i++)
        {
            sb.Append("1fr"); // Package column

            if (i < comparisonCount)
            {
                sb.Append(" 0.8fr"); // Comparison column
            }
        }

        return sb.ToString();
    }

    // Track open state of popovers
    private Dictionary<string, bool> _popoverStates = new();

    private bool IsPopoverOpen(string key)
    {
        return _popoverStates.TryGetValue(key, out bool value) && value;
    }

    private void SetPopoverState(string key, bool value)
    {
        _popoverStates[key] = value;
        StateHasChanged();
    }

    private void TogglePopover(string key)
    {
        if (!_popoverStates.TryGetValue(key, out bool currentValue))
        {
            currentValue = false;
        }
        _popoverStates[key] = !currentValue;
        StateHasChanged();
    }


    // New fields for the Structure selection dialog
    private FluentDialog? structureSelectionDialog;
    private string structureDialogTitle = "Select Target Structure...";
    private string structureSearchText = "";
    private List<DbStructureDefinition> allStructures = [];
    private IQueryable<DbStructureDefinition> filteredStructures = Enumerable.Empty<DbStructureDefinition>().AsQueryable();
    private DbStructureDefinition? selectedStructure => selectedStructures.FirstOrDefault();
    private IEnumerable<DbStructureDefinition> selectedStructures = [];
    private bool dialogHidden = true;

    // Dialog context data
    private string currentDialogKey = "";
    private int currentSourceStructureKey;
    private int currentSourcePackageIndex;
    private int currentTargetPackageIndex;

    // Show the Structure selection dialog with appropriate context
    private void ShowStructureSelectionDialog(string dialogKey, int sourceStructureKey, int sourcePackageIndex, int targetPackageIndex)
    {
        currentDialogKey = dialogKey;
        currentSourceStructureKey = sourceStructureKey;
        currentSourcePackageIndex = sourcePackageIndex;
        currentTargetPackageIndex = targetPackageIndex;

        // Set dialog title based on direction
        structureDialogTitle = $"Select Structure from {_packages[targetPackageIndex].ShortName}";

        // Reset selection
        selectedStructures = [];
        structureSearchText = "";

        // Load value sets for the target package
        LoadStructuresForPackage(targetPackageIndex);

        // Show dialog
        // valueSetSelectionDialog?.Show();
        dialogHidden = false;
    }

    // Primary action handler for the dialog
    private void SelectStructure()
    {
        if (selectedStructure != null)
        {
            // Create a similar option object as used in the original code for compatibility
            var selectedOption = new Option<DbStructureDefinition>
                {
                    Text = selectedStructure.Name + " - " + selectedStructure.UnversionedUrl,
                    Value = selectedStructure
                };

            // Call the existing AddVsMapping with our selected value
            AddVsMapping(currentDialogKey, currentSourceStructureKey, currentSourcePackageIndex, currentTargetPackageIndex, selectedOption);
        }

        // valueSetSelectionDialog!.Hide();
        dialogHidden = true;
    }

    // Secondary action handler for the dialog
    private void CancelStructureSelection()
    {
        // valueSetSelectionDialog!.Hide();
        dialogHidden = true;
    }

    // Load value sets for a specific package
    private void LoadStructuresForPackage(int packageIndex)
    {
        try
        {
            allStructures = DbStructureDefinition.SelectList(
                Xver.DbConnection,
                FhirPackageKey: packageIndex,
                orderByProperties: [nameof(DbStructureDefinition.Name)]);

            filteredStructures = allStructures.AsQueryable();
        }
        catch (Exception)
        {
            allStructures = [];
            filteredStructures = Enumerable.Empty<DbStructureDefinition>().AsQueryable();
        }
    }

    // Filter value sets based on search text
    private void FilterStructures(ChangeEventArgs e)
    {
        string? searchText = e.Value?.ToString()?.ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredStructures = allStructures.AsQueryable();
        }
        else
        {
            filteredStructures = allStructures
                .Where(vs =>
                    vs.Name.ToLowerInvariant().Contains(searchText!) ||
                    vs.UnversionedUrl.ToLowerInvariant().Contains(searchText!) ||
                    (vs.Id?.ToLowerInvariant()?.Contains(searchText!) ?? false))
                .AsQueryable();
        }
    }

    private string GetDateDisplay(DateTime? date) => date == null
        ? string.Empty
        : date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private async Task SaveChanges()
    {
        if (selectedComparison == null)
        {
            return;
        }

        string reviewer = ServerConfig.UserName;

        Xver.Comparer.ApplySdConceptChanges(
            originalProjection,
            elementProjection,
            sourceColIndex,
            compareRight,
            reviewer);

        // re-aggregate the element comparisons for the value set if not manually set
        _ = Xver.Comparer.AggregateStructureRelationships(selectedComparison);

        // check for rules trying to override a manually-set relationship
        if ((manualSdRelationship != null) &&
            (manualSdRelationship != selectedComparison.Relationship))
        {
            IDialogReference dialog = await DialogService.ShowConfirmationAsync(
                $"The Structure comparison wants to update to to <code>{selectedComparison.Relationship}</code>.",
                $"Computed: {selectedComparison.Relationship}",
                $"Specified: {manualSdRelationship}",
                "Structure Relationship");
            DialogResult result = await dialog.Result;

            if (result.Cancelled == true)
            {
                selectedComparison.Relationship = manualSdRelationship;
            }
        }
        else if ((initialSdRelationship != null) &&
                 (initialSdRelationship != selectedComparison.Relationship))
        {
            IDialogReference dialog = await DialogService.ShowConfirmationAsync(
                $"The Structure comparison wants to update to to <code>{selectedComparison.Relationship}</code>.",
                $"Computed: {selectedComparison.Relationship}",
                $"Old: {initialSdRelationship}",
                "Structure Relationship");
            DialogResult result = await dialog.Result;

            if (result.Cancelled == true)
            {
                selectedComparison.Relationship = manualSdRelationship;
            }
        }

        // mark this value set comparison as reviewed
        selectedComparison.LastReviewedOn = DateTime.UtcNow;
        selectedComparison.LastReviewedBy = reviewer;
        selectedComparison.Update(Xver.DbConnection);

        // check if the user wants to apply the inverse changes
        if (ApplyToInverse == true)
        {
            (DbStructureComparison? inverse, bool? hasChanges) = Xver.Comparer.UpdateInversion(selectedComparison);

            // if there is an inverse and it is not reviewed or changed because of these changes, bring it up
            if ((inverse != null) &&
                ((inverse.LastReviewedOn == null) || (hasChanges == true)))
            {
                // find the correct value set row in the projection
                DbSdRow? sdRow = graphProjection?.FirstOrDefault(v => v.RowNumber == comparisonFilteredSdRow.RowNumber);

                if (sdRow != null)
                {
                    // move the UI
                    SelectComparison(comparisonFilteredSdRow, inverse, targetColIndex, sourceColIndex);
                    return;
                }
            }
        }

        // clear our selected comparison
        ClearSelectedComparison();

        // force reload of the mapping table
        LoadStructure(true);

        // move the UI back to the mapping table
        activeTabId = "mappingTable";
        StateHasChanged();

        return;
    }

    private void ClearSelectedComparison()
    {
        selectedComparison = null;
        _sourceElements = [];
        _targetElements = [];
        originalProjection = [];
        elementProjection = [];
        _mappings = Enumerable.Empty<ElementRecForUi>().AsQueryable();
    }

    private async Task DeleteCurrentMapping()
    {
        if (selectedComparison == null)
        {
            return;
        }

        IDialogReference dialog = await DialogService.ShowConfirmationAsync(
            $"Deleting this mapping cannot be undone!<br/>Are you sure you wish to delete <code>{selectedComparison.CompositeName}</code>",
            "Confirm Delete",
            "Cancel",
            "Delete Mapping Confirmation");
        DialogResult result = await dialog.Result;

        if (result.Cancelled == true)
        {
            StateHasChanged();
            return;
        }

        // check for an inverse comaprison
        DbStructureComparison? inverseComparison = selectedComparison.InverseComparisonKey != null
            ? DbStructureComparison.SelectSingle(
                Xver.DbConnection,
                Key: selectedComparison.InverseComparisonKey)
            : null;

        if (inverseComparison != null)
        {
            IDialogReference inverseDialog = await DialogService.ShowConfirmationAsync(
                $"Would you also like to delete the inverse comparison: {inverseComparison.CompositeName} ({inverseComparison.Key})",
                "Yes",
                "No",
                "Delete Inverse");
            DialogResult inverseResult = await dialog.Result;

            // delete the inverse comparison if needed
            if (inverseResult.Cancelled == false)
            {
                // delete all the element comparisons for this structure comparison
                List<DbElementComparison> inverseElementComparisonsToDelete = DbElementComparison.SelectList(
                        Xver.DbConnection,
                        StructureComparisonKey: inverseComparison.Key);

                if (inverseElementComparisonsToDelete.Count > 0)
                {
                    inverseElementComparisonsToDelete.Delete(Xver.DbConnection);
                }

                // delete this element comparison
                inverseComparison.Delete(Xver.DbConnection);
            }
        }

        // delete all the element comparisons for this structure comparison
        List<DbElementComparison> elementComparisonsToDelete = DbElementComparison.SelectList(
                Xver.DbConnection,
                StructureComparisonKey: selectedComparison.Key);

        if (elementComparisonsToDelete.Count > 0)
        {
            elementComparisonsToDelete.Delete(Xver.DbConnection);
        }

        // delete this structure comparison
        selectedComparison.Delete(Xver.DbConnection);

        // clear our selected comparison
        ClearSelectedComparison();

        // force reload of the mapping table
        LoadStructure(true);

        // move the UI back to the mapping table
        activeTabId = "mappingTable";
        StateHasChanged();

        return;
    }

    private void AddVsMapping(string popKey, int sourceStructureKey, int sourcePackageIndex, int targetPackageIndex, object? selectedValue)
    {
        if ((selectedValue == null) ||
            (selectedValue is not Option<DbStructureDefinition> selectedOption) ||
            (selectedOption.Value == null) ||
            (selectedOption.Value is not DbStructureDefinition targetVs))
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        // resolve the package comparison
        DbFhirPackageComparisonPair? packagePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[sourcePackageIndex].Key,
            TargetPackageKey: _packages[targetPackageIndex].Key);

        if (packagePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        DbFhirPackageComparisonPair? reversePair = DbFhirPackageComparisonPair.SelectSingle(
            Xver.DbConnection,
            SourcePackageKey: _packages[targetPackageIndex].Key,
            TargetPackageKey: _packages[sourcePackageIndex].Key);

        if (reversePair == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // resolve the source value set
        DbStructureDefinition? sourceSd = DbStructureDefinition.SelectSingle(
            Xver.DbConnection,
            FhirPackageKey: _packages[sourcePackageIndex].Key,
            Key: sourceStructureKey);

        if (sourceSd == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();
            return;
        }

        // create a new value set comparison
        DbStructureComparison sdComparison = new()
            {
                Key = Xver.ComparisonDb.GetStructureComparisonKey(),
                PackageComparisonKey = packagePair.Key,
                SourceFhirPackageKey = packagePair.SourcePackageKey,
                TargetFhirPackageKey = packagePair.TargetPackageKey,
                SourceStructureKey = sourceStructureKey,
                SourceCanonicalVersioned = sourceSd.VersionedUrl,
                SourceCanonicalUnversioned = sourceSd.UnversionedUrl,
                SourceVersion = sourceSd.Version,
                SourceName = sourceSd.Name,
                TargetStructureKey = targetVs.Key,
                TargetCanonicalVersioned = targetVs.VersionedUrl,
                TargetCanonicalUnversioned = targetVs.UnversionedUrl,
                TargetVersion = targetVs.Version,
                TargetName = targetVs.Name,
                CompositeName = ComparisonDatabase.GetCompositeName(_packages[sourcePackageIndex], sourceSd, _packages[targetPackageIndex], targetVs),
                Relationship = null,
                ConceptDomainRelationship = null,
                ValueDomainRelationship = null,
                IsGenerated = false,
                LastReviewedOn = null,
                LastReviewedBy = null,
                Message = null,
                IsIdentical = false,
                SourceOverviewConceptMapUrl = null,
                SourceStructureFmlUrl = null,
            };

        DbComparisonCache<DbStructureComparison> sdComparisons = new();
        DbComparisonCache<DbElementComparison> elementComparisons = new();
        DbComparisonCache<DbElementTypeComparison> elementTypeComparisons = new();

        sdComparisons.CacheAdd(sdComparison);

        // run through the built-in comparison testing
        Xver.Comparer.DoStructureComparison(
            sdComparisons,
            elementComparisons,
            elementTypeComparisons,
            _packages[sourcePackageIndex],
            sourceSd,
            _packages[targetPackageIndex],
            targetVs,
            sdComparison,
            packagePair,
            reversePair);

        // apply our changes
        sdComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        sdComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        sdComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        elementComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        elementComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        elementComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        elementTypeComparisons.ComparisonsToAdd.Insert(Xver.DbConnection);
        elementTypeComparisons.ComparisonsToUpdate.Update(Xver.DbConnection);
        elementTypeComparisons.ComparisonsToDelete.Delete(Xver.DbConnection);

        // force reload of our UI contents
        LoadStructure(true);

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    private void UpdateSdRelationship(object? selectedValue, string? relationshipCategory = null)
    {
        string popKey = relationshipCategory switch
        {
            "cd" => "rel-cd",
            "vd" => "rel-vd",
            _ => $"rel-sd"
        };

        if (selectedComparison == null)
        {
            // Close the popover after selection
            SetPopoverState(popKey, false);
            StateHasChanged();

            return;
        }

        if ((selectedValue != null) &&
            (selectedValue is Option<Hl7.Fhir.Model.ConceptMap.ConceptMapRelationship?> r))
        {
            switch (relationshipCategory)
            {
                case "cd":
                    selectedComparison.ConceptDomainRelationship = r.Value;
                    break;
                case "vd":
                    selectedComparison.ValueDomainRelationship = r.Value;
                    break;
                default:
                    selectedComparison.Relationship = r.Value;
                    break;
            }
            manualSdRelationship = r.Value;
        }

        // Close the popover after selection
        SetPopoverState(popKey, false);
        StateHasChanged();
    }

    private void AddElementRow(object? selectedValue)
    {
        if ((csCell != null) &&
            (ctCell != null) &&
            (selectedValue != null) &&
            (selectedValue is Option<DbElement> element) &&
            (element.Value != null))
        {
            DbElementRow row = new(_packages.Count, sourceColIndex, elementProjection.Count());
            row[sourceColIndex] = new()
                {
                    SdCell = csCell,
                    Element = element.Value,
                };

            row[targetColIndex] = new()
                {
                    SdCell = ctCell,
                    Element = DbElement.EmptyCopy,
                };

            if (compareRight)
            {
                row[targetColIndex]!.LeftCell = row[sourceColIndex];
                row[targetColIndex]!.LeftComparison = DbElementComparison.EmptyCopy;
                row[targetColIndex]!.LeftElement = row[sourceColIndex]!.Element;
            }
            else
            {
                row[targetColIndex]!.RightCell = row[sourceColIndex];
                row[targetColIndex]!.RightComparison = DbElementComparison.EmptyCopy;
                row[targetColIndex]!.RightElement = row[sourceColIndex]!.Element;
            }

            UpdateMappingTracking([row, .. elementProjection]);
        }

        // Close the popover after selection
        string key = $"add-element-row";
        SetPopoverState(key, false);
        StateHasChanged();
    }

    private void DeleteElementRow(DbElementRow rowToRemove)
    {
        List<DbElementRow> cp = [];
        foreach (DbElementRow row in elementProjection)
        {
            if (row.RowNumber != rowToRemove.RowNumber)
            {
                cp.Add(row);
            }
        }

        UpdateMappingTracking(cp);

        // Close the popover after selection
        string key = $"del-{rowToRemove.RowNumber}";
        SetPopoverState(key, false);
        StateHasChanged();
        StateHasChanged();
    }

